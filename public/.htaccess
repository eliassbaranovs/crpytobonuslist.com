# Prevent LiteSpeed from auto-adding trailing slashes to directories
DirectorySlash Off

RewriteEngine On

# 1. Strip trailing slashes (301 redirect)
RewriteRule ^(.*)/$ /$1 [R=301,L]

# 2. Strip .html extension (301 redirect)
RewriteCond %{THE_REQUEST} \.html[\s?] [NC]
RewriteRule ^(.*)\.html$ /$1 [R=301,L]

# 3. Serve clean URLs by internally mapping to .html files
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.*)$ $1.html [L]
