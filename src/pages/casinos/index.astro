---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getReviews, getRatingBg, getReviewUrl, getClaimUrl } from "../../lib/casino-filters";
import { buildBonusMap, getBonusInfo } from "../../lib/posts";

const allPosts = await getCollection("posts");
const reviews = getReviews(allPosts);
const bonusMap = buildBonusMap(allPosts);

const latestDate = reviews.reduce((latest, item) => {
  const d = new Date(item.data.updatedAt || item.data.publishedAt || 0);
  return d > latest ? d : latest;
}, new Date(0));

const latestMonth = latestDate.toLocaleDateString("en-US", { month: "long", year: "numeric" });

const siteUrl = "https://cryptobonuslist.com";
const canonical = `${siteUrl}/casinos`;

const schemas: Record<string, any>[] = [];

// CollectionPage + ItemList
schemas.push({
  "@type": "CollectionPage",
  name: "Crypto Casino Reviews",
  description: "Honest, deposit-tested crypto casino reviews. Ratings, withdrawal speeds, bonus breakdowns, and everything you need before you play.",
  url: `${siteUrl}/casinos`,
  dateModified: latestDate.toISOString(),
  numberOfItems: reviews.length,
  author: {
    "@type": "Person",
    name: "Thomas Mullberg",
    url: "https://cryptobonuslist.com/team/thomas-mullberg",
    jobTitle: "Senior Crypto & iGaming Analyst",
  },
  publisher: {
    "@type": "Organization",
    name: "CryptoBonusList",
    url: "https://cryptobonuslist.com",
    logo: {
      "@type": "ImageObject",
      url: "https://cryptobonuslist.com/cryptobonuslist.png",
    },
  },
  itemListElement: reviews.map((r, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteUrl}${getReviewUrl(r)}`,
    name: r.data.casino_name || r.data.casinoName || r.data.title,
  })),
});

// BreadcrumbList
schemas.push({
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Casino Reviews" },
  ],
});

// FAQPage
const faqItems = [
  {
    q: "Are crypto casinos legal?",
    a: "Legality depends on your jurisdiction. Many crypto casinos operate under licenses from authorities like Curacao, Malta, or Isle of Man. Always check local gambling laws before playing and verify the casino holds a valid license from a recognized regulator.",
  },
  {
    q: "Are crypto casinos safe?",
    a: "Licensed crypto casinos with transparent ownership, provably fair games, and segregated player funds are generally safe. Look for valid licensing, two-factor authentication, cold wallet storage, and a track record of paying out withdrawals on time.",
  },
  {
    q: "How do I deposit Bitcoin at an online casino?",
    a: "Copy the casino's Bitcoin deposit address from the cashier page, then send BTC from your wallet to that address. Most casinos credit deposits after 1-3 network confirmations, which typically takes 10-30 minutes depending on network congestion.",
  },
  {
    q: "What is the best crypto casino for fast withdrawals?",
    a: "The fastest crypto casinos process withdrawals in under 10 minutes with no manual review hold. Check our individual reviews for tested withdrawal times. We measure actual payout speed with real deposits, not what the casino claims.",
  },
  {
    q: "Do crypto casinos require KYC verification?",
    a: "Some do, some don't. Casinos licensed by strict regulators like the MGA typically require KYC. Many Curacao-licensed casinos allow play without verification up to certain thresholds. Check our no-KYC casino page for options.",
  },
  {
    q: "Can I play casino games with Ethereum?",
    a: "Yes. Most crypto casinos accept ETH deposits and withdrawals. Ethereum transactions typically confirm faster than Bitcoin, often crediting within a few minutes. Some casinos also support ERC-20 tokens like USDT and USDC.",
  },
  {
    q: "What licenses should a crypto casino have?",
    a: "The strongest licenses come from Malta Gaming Authority, Isle of Man GSC, and the reformed Curacao Gaming Authority. These regulators enforce player protections, fund segregation, and dispute resolution. Avoid casinos with no license or licenses from jurisdictions with no real oversight.",
  },
  {
    q: "How do provably fair games work?",
    a: "Provably fair games use cryptographic hashes to let you verify each bet outcome was not manipulated. Before a round, the casino commits to a server seed hash. After the round, you can check the unhashed seed against the committed hash to confirm the result was predetermined and fair.",
  },
];

schemas.push({
  "@type": "FAQPage",
  mainEntity: faqItems.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: {
      "@type": "Answer",
      text: a,
    },
  })),
});

const jsonLd = JSON.stringify({ "@context": "https://schema.org", "@graph": schemas });
---

<Layout
  title="Crypto Casino Reviews 2026 | Tested and Rated | CryptoBonusList"
  description="Honest, deposit-tested crypto casino reviews for 2026. Real ratings, timed withdrawal speeds, bonus breakdowns, and game library checks. Updated monthly."
  jsonld={jsonLd}
  canonical={canonical}
>
  <!-- Hero -->
  <section class="px-6 pt-16 pb-10">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-5xl md:text-7xl font-black tracking-tight mb-6">
        CRYPTO CASINO <span class="text-[#39FF14]">REVIEWS</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg md:text-xl max-w-3xl leading-relaxed mb-4">
        Every casino on this page was tested with real crypto deposits. We checked withdrawal speeds, bonus terms, game libraries, and support quality so you do not have to gamble on where you gamble.
      </p>
      <p class="font-[JetBrains_Mono] text-sm text-[#FAFF00]">
        {reviews.length} casinos reviewed and rated on a 0-10 scale
      </p>
    </div>
  </section>

  <!-- Author Attribution + Freshness -->
  <section class="px-6 pb-4">
    <div class="max-w-7xl mx-auto flex flex-wrap items-center gap-x-6 gap-y-2 text-sm font-[Public_Sans] text-[#D4D4D4]">
      <span>
        Reviewed by <a href="/team/thomas-mullberg" class="text-[#39FF14] underline underline-offset-4 decoration-2 hover:text-white transition-colors">Thomas Mullberg</a>, Senior Crypto &amp; iGaming Analyst
      </span>
      <span class="text-white/30 hidden sm:inline">|</span>
      <span class="font-[JetBrains_Mono]">Last updated: {latestMonth}</span>
      <span class="text-white/30 hidden sm:inline">|</span>
      <span class="font-[JetBrains_Mono]">{reviews.length} casinos tested with real deposits</span>
    </div>
  </section>

  <!-- Affiliate Disclosure -->
  <section class="px-6 pb-8">
    <div class="max-w-7xl mx-auto">
      <p class="text-xs font-[Public_Sans] text-[#D4D4D4]/70 leading-relaxed border border-white/10 px-4 py-3 bg-[#1a1a1a]">
        Some links on this page are affiliate links. We earn a commission if you sign up through them. This does not affect our ratings or rankings. All reviews are independent and based on real deposits. Read our full <a href="/affiliate-disclosure" class="text-[#39FF14] underline underline-offset-2 hover:text-white transition-colors">affiliate disclosure</a>.
      </p>
    </div>
  </section>


  <!-- Top 3 Quick Picks -->
  <section class="px-6 pb-8">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-black mb-6">
        TOP 3 <span class="text-[#39FF14]">QUICK PICKS</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {reviews.slice(0, 3).map((review, i) => {
          const name = review.data.casino_name || review.data.casinoName || review.data.title;
          const rating = review.data.ourRating || 0;
          const ratingBg = getRatingBg(rating);
          const firstPro = (review.data.pros || [])[0] || "Top-rated crypto casino";
          const logo = review.data.logo;
          const shadowColors = ["#39FF14", "#FAFF00", "#A855F7"];
          const rankColors = ["bg-[#39FF14] text-black", "bg-[#FAFF00] text-black", "bg-[#A855F7] text-white"];
          const shadowColor = shadowColors[i];
          const rankColor = rankColors[i];

          return (
            <div class={`bg-[#0A0A0A] border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_${shadowColor}]`} style={`box-shadow: 6px 6px 0px 0px ${shadowColor}`}>
              <div class="flex items-center gap-3 mb-4">
                <span class={`${rankColor} font-[JetBrains_Mono] font-bold text-lg w-9 h-9 flex items-center justify-center shrink-0`}>
                  {i + 1}
                </span>
                {logo && (
                  <img
                    src={logo}
                    alt={`${name} logo`}
                    width="48"
                    height="48"
                    class="w-12 h-12 object-cover border border-white/20 shrink-0"
                    loading="lazy"
                  />
                )}
                <div class="min-w-0">
                  <h3 class="font-[Space_Grotesk] font-bold text-white text-lg truncate">{name}</h3>
                  <span class={`${ratingBg} font-[JetBrains_Mono] text-xs font-bold px-2 py-0.5 inline-block mt-1`}>
                    {rating.toFixed(1)}/10
                  </span>
                </div>
              </div>
              <p class="text-[#D4D4D4] font-[Public_Sans] text-sm mb-5 line-clamp-2">{firstPro}</p>
              <div class="flex gap-3">
                <a
                  href={getReviewUrl(review)}
                  class="flex-1 text-center font-[Space_Grotesk] font-bold text-xs py-2.5 border-2 border-white text-white hover:bg-white hover:text-black transition-colors uppercase"
                >
                  Read Review
                </a>
                <a
                  href={getClaimUrl(review)}
                  target="_blank"
                  rel="noopener noreferrer nofollow sponsored"
                  class="flex-1 text-center font-[Space_Grotesk] font-bold text-xs py-2.5 bg-[#39FF14] text-black border-2 border-[#39FF14] hover:bg-[#2ECC0F] transition-colors uppercase"
                >
                  Visit Casino
                </a>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Comparison Table -->
  <section class="px-6 pb-10">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-black mb-6">
        CASINO <span class="text-[#FAFF00]">COMPARISON</span>
      </h2>
      <div class="overflow-x-auto border-[3px] border-white">
        <table class="w-full min-w-[700px] text-left" role="table" aria-label="Casino comparison table">
          <thead>
            <tr class="bg-[#1a1a1a]">
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Casino</th>
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Rating</th>
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Welcome Bonus</th>
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Wagering</th>
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Min Deposit</th>
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">License</th>
              <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3 text-right">Link</th>
            </tr>
          </thead>
          <tbody>
            {reviews.map((review) => {
              const name = review.data.casino_name || review.data.casinoName || review.data.title;
              const rating = review.data.ourRating || 0;
              const ratingBg = getRatingBg(rating);
              const bonusInfo = getBonusInfo(review, bonusMap);
              const wagering = review.data.wageringRequirements || "N/A";
              const minDeposit = review.data.minimumDeposit || "N/A";
              const licence = review.data.licences || "Unknown";
              const logo = review.data.logo;

              return (
                <tr class="border-b border-white/10 hover:bg-white/5 transition-colors">
                  <td class="px-4 py-3">
                    <div class="flex items-center gap-2">
                      {logo && (
                        <img src={logo} alt="" width="28" height="28" class="w-7 h-7 object-cover border border-white/20 shrink-0" loading="lazy" />
                      )}
                      <span class="font-[Space_Grotesk] font-bold text-white text-sm">{name}</span>
                    </div>
                  </td>
                  <td class="px-4 py-3">
                    <span class={`${ratingBg} font-[JetBrains_Mono] text-xs font-bold px-2 py-0.5`}>{rating.toFixed(1)}</span>
                  </td>
                  <td class="px-4 py-3 font-[Public_Sans] text-sm text-[#D4D4D4] max-w-[200px] truncate">{bonusInfo.text}</td>
                  <td class="px-4 py-3 font-[JetBrains_Mono] text-xs text-white">{wagering}</td>
                  <td class="px-4 py-3 font-[JetBrains_Mono] text-xs text-white">{minDeposit}</td>
                  <td class="px-4 py-3 font-[Public_Sans] text-xs text-[#D4D4D4]">{licence}</td>
                  <td class="px-4 py-3 text-right">
                    <a href={getReviewUrl(review)} class="font-[JetBrains_Mono] text-[#39FF14] text-xs underline underline-offset-2 hover:text-white transition-colors">Review</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Casino Cards -->
  <section class="px-6 pb-16">
    <div class="max-w-7xl mx-auto">
      {reviews.length > 0 ? (
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
          {reviews.map((review) => {
            const name = review.data.casino_name || review.data.casinoName || review.data.title;
            const rating = review.data.ourRating || 0;
            const ratingBg = getRatingBg(rating);
            const pros = (review.data.pros || []).slice(0, 3);
            const wagering = review.data.wageringRequirements || "N/A";
            const bonusInfo = getBonusInfo(review, bonusMap);
            const licence = review.data.licences || "Unknown";
            const established = review.data.established || "N/A";
            const logo = review.data.logo;

            return (
              <article class="bg-[#0A0A0A] border-[3px] border-white shadow-[6px_6px_0px_0px_#A855F7] hover:shadow-[8px_8px_0px_0px_#39FF14] transition-shadow duration-200">
                <!-- Header -->
                <div class="flex items-start gap-5 p-6 pb-4 border-b border-white/10">
                  {logo && (
                    <img
                      src={logo}
                      alt={`${name} logo`}
                      width="80"
                      height="80"
                      class="w-20 h-20 object-cover border border-white/20 shrink-0"
                      loading="lazy"
                    />
                  )}
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between gap-3 mb-2">
                      <h2 class="font-[Space_Grotesk] text-2xl font-bold text-white truncate">{name}</h2>
                      <span class={`${ratingBg} font-[JetBrains_Mono] text-lg font-bold px-3 py-1 shrink-0`}>
                        {rating.toFixed(1)}
                      </span>
                    </div>
                    <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-[JetBrains_Mono] text-[#D4D4D4]">
                      <span>Est. {established}</span>
                      <span class="text-white/30">|</span>
                      <span>{licence}</span>
                    </div>
                  </div>
                </div>

                <!-- Details -->
                <div class="p-6 pt-4 space-y-4">
                  <!-- Bonus -->
                  <div>
                    <p class="text-xs font-[JetBrains_Mono] text-[#FAFF00] uppercase tracking-wider mb-1">Welcome Bonus</p>
                    <p class="font-[Public_Sans] text-white text-sm">
                      {bonusInfo.url ? (
                        <a href={bonusInfo.url} class="text-[#FAFF00] hover:underline">{bonusInfo.text}</a>
                      ) : bonusInfo.text}
                    </p>
                  </div>

                  <!-- Wagering -->
                  <div>
                    <p class="text-xs font-[JetBrains_Mono] text-[#FAFF00] uppercase tracking-wider mb-1">Wagering</p>
                    <p class="font-[JetBrains_Mono] text-white text-sm">{wagering}</p>
                  </div>

                  <!-- Pros -->
                  {pros.length > 0 && (
                    <div>
                      <p class="text-xs font-[JetBrains_Mono] text-[#39FF14] uppercase tracking-wider mb-2">Highlights</p>
                      <ul class="space-y-1">
                        {pros.map((pro) => (
                          <li class="flex items-start gap-2 text-sm font-[Public_Sans] text-[#D4D4D4]">
                            <span class="text-[#39FF14] mt-0.5 shrink-0">+</span>
                            <span>{pro}</span>
                          </li>
                        ))}
                      </ul>
                    </div>
                  )}


                  {/* Cons */}
                  {(() => {
                    const cons = (review.data.cons || []).slice(0, 2);
                    return cons.length > 0 ? (
                      <div>
                        <p class="text-xs font-[JetBrains_Mono] text-[#EF4444] uppercase tracking-wider mb-2">Watch Out</p>
                        <ul class="space-y-1">
                          {cons.map((con) => (
                            <li class="flex items-start gap-2 text-sm font-[Public_Sans] text-[#D4D4D4]">
                              <span class="text-[#EF4444] mt-0.5 shrink-0">-</span>
                              <span>{con}</span>
                            </li>
                          ))}
                        </ul>
                      </div>
                    ) : null;
                  })()}

                  <!-- Buttons -->
                  <div class="flex gap-3 pt-2">
                    <a
                      href={getReviewUrl(review)}
                      class={`${getClaimUrl(review) ? 'flex-1' : 'w-full'} text-center font-[Space_Grotesk] font-bold text-sm py-3 border-2 border-white text-white hover:bg-white hover:text-black transition-colors`}
                    >
                      READ REVIEW
                    </a>
                    {getClaimUrl(review) && (
                      <a
                        href={getClaimUrl(review)}
                        target="_blank"
                        rel="noopener noreferrer nofollow sponsored"
                        class="flex-1 text-center font-[Space_Grotesk] font-bold text-sm py-3 bg-[#39FF14] text-black border-2 border-[#39FF14] hover:bg-[#2ECC0F] transition-colors"
                      >
                        VISIT CASINO
                      </a>
                    )}
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg">
          Casino reviews are on the way. Check back soon.
        </p>
      )}
    </div>
  </section>

  <!-- How We Test Crypto Casinos -->
  <section class="px-6 py-12" id="methodology">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-black mb-8">
        HOW WE TEST <span class="text-[#39FF14]">CRYPTO CASINOS</span>
      </h2>
      <div class="max-w-3xl space-y-4 font-[Public_Sans] text-[#D4D4D4] text-base leading-relaxed">
        <p>
          We deposit real crypto at every casino we review. Not test funds. Not demo accounts. Actual Bitcoin, Ethereum, and USDT sent from our own wallets. That is the only way to know what the experience actually feels like for a player.
        </p>
        <p>
          After depositing, we test withdrawal speeds by requesting a cashout and timing it from submission to wallet confirmation. We record the exact duration. Some casinos pay out in under 10 minutes. Others hold funds for days with manual review queues and vague "processing" statuses. You will see the real numbers in each review.
        </p>
        <p>
          We evaluate game libraries by checking provider diversity. A casino with 50 slots from one provider is not the same as one with thousands of games across Pragmatic Play, Evolution, Hacksaw, Play'n GO, and others. We also look for provably fair originals and live dealer coverage.
        </p>
        <p>
          Support gets tested too. We open live chat tickets with real questions and measure response time and quality. A bot that sends you to the FAQ is not the same as a human who actually resolves your issue. We note the difference.
        </p>
        <p>
          Licensing verification is not optional. We check every casino's claimed license against the regulator's public database. If a casino claims a Curacao license but does not appear in the CGA registry, that gets flagged. We also verify whether the license is active or expired.
        </p>
        <p>
          Every casino receives a score on a 0-10 scale across multiple criteria: security, payout speed, bonus value, game selection, support quality, and crypto integration. The final rating is a weighted average that favors safety and payout reliability over flashy bonus numbers.
        </p>
        <p>
          <a href="/methodology" class="text-[#39FF14] underline underline-offset-4 decoration-2 font-[Space_Grotesk] font-bold hover:text-white transition-colors">Read our full testing methodology</a>
        </p>
      </div>
    </div>
  </section>

  <!-- What Makes a Top Crypto Casino -->
  <section class="px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-black mb-8">
        WHAT MAKES A <span class="text-[#FAFF00]">TOP CRYPTO CASINO</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <!-- Criterion 1 -->
        <div class="border-[3px] border-white p-6 bg-[#0A0A0A] shadow-[4px_4px_0px_0px_#39FF14]">
          <p class="font-[JetBrains_Mono] text-[#39FF14] text-xs uppercase tracking-wider mb-2">01</p>
          <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">Security and Licensing</h3>
          <p class="font-[Public_Sans] text-[#D4D4D4] text-sm leading-relaxed">
            A valid gambling license from a recognized authority is the minimum. We look for regulators that actually enforce rules, not ones that sell paperwork. Beyond licensing, we check for two-factor authentication, cold wallet storage for player funds, and SSL encryption. If a casino stores your crypto in a hot wallet with no insurance, that is a red flag regardless of what license they hold.
          </p>
        </div>
        <!-- Criterion 2 -->
        <div class="border-[3px] border-white p-6 bg-[#0A0A0A] shadow-[4px_4px_0px_0px_#FAFF00]">
          <p class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider mb-2">02</p>
          <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">Withdrawal Speed</h3>
          <p class="font-[Public_Sans] text-[#D4D4D4] text-sm leading-relaxed">
            The whole point of using crypto at a casino is fast payouts. Under 10 minutes from request to wallet is excellent. Under an hour is acceptable. Anything over 24 hours and you are dealing with manual review bottlenecks that defeat the purpose. We time every withdrawal we make and publish the actual results. No estimates, no "up to" claims.
          </p>
        </div>
        <!-- Criterion 3 -->
        <div class="border-[3px] border-white p-6 bg-[#0A0A0A] shadow-[4px_4px_0px_0px_#A855F7]">
          <p class="font-[JetBrains_Mono] text-[#A855F7] text-xs uppercase tracking-wider mb-2">03</p>
          <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">Bonus Value</h3>
          <p class="font-[Public_Sans] text-[#D4D4D4] text-sm leading-relaxed">
            A 500% bonus sounds great until you read the 60x wagering requirement. We evaluate bonuses by their actual value after you factor in wagering, game weighting, max bet limits, and time restrictions. A 100% bonus with 25x wagering and no max cashout is worth more than most 300% offers with restrictive terms. We break down the math in every review.
          </p>
        </div>
        <!-- Criterion 4 -->
        <div class="border-[3px] border-white p-6 bg-[#0A0A0A] shadow-[4px_4px_0px_0px_#39FF14]">
          <p class="font-[JetBrains_Mono] text-[#39FF14] text-xs uppercase tracking-wider mb-2">04</p>
          <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">Game Library</h3>
          <p class="font-[Public_Sans] text-[#D4D4D4] text-sm leading-relaxed">
            Provider diversity matters more than raw game count. A casino with 3,000 games from Pragmatic Play, Evolution, Hacksaw Gaming, Play'n GO, and NoLimit City offers a genuinely different experience than one padded with 8,000 no-name slots. We also look for provably fair originals, live dealer tables, and whether popular titles are actually available in your region.
          </p>
        </div>
        <!-- Criterion 5 -->
        <div class="border-[3px] border-white p-6 bg-[#0A0A0A] shadow-[4px_4px_0px_0px_#FAFF00]">
          <p class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider mb-2">05</p>
