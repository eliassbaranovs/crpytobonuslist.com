---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isReview, isBonus, sortByDate } from "../../lib/posts";

const allPosts = await getCollection("posts");
const reviews = sortByDate(allPosts.filter(isReview));
const bonuses = sortByDate(allPosts.filter(isBonus));
---

<Layout title="Crypto Casinos | CryptoBonusList" description="Crypto casino directory. The ones worth your time and BTC.">
  <section class="px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        CRYPTO <span class="text-[#8A2BE2]">CASINOS</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-2xl">
        {reviews.length > 0
          ? "Full casino reviews tested with real deposits. Withdrawal times, support quality, and the details that matter."
          : "Full casino directory coming soon. For now, check the bonus reviews for details on individual platforms."}
      </p>

      {reviews.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {reviews.map((review) => (
            <a href={`/casinos/${review.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#8A2BE2]">
              <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-2">{review.data.title}</h2>
              <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-3 line-clamp-3">{review.data.description}</p>
              {review.data.ourRating && (
                <div class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">Rating: {review.data.ourRating}/10</div>
              )}
            </a>
          ))}
        </div>
      ) : (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {bonuses.slice(0, 6).map((bonus) => (
            <a href={`/bonus/${bonus.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#8A2BE2]">
              <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-2">{bonus.data.title}</h2>
              <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-3 line-clamp-3">{bonus.data.description}</p>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
