---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isReview } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.filter(isReview).map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const siteUrl = "https://cryptobonuslist.com";
const pageUrl = `${siteUrl}/casinos/${d.slug}`;
const canonical = pageUrl;

const lastUpdated = d.updatedAt || d.publishedAt;
const lastUpdatedFormatted = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : null;
const robots = d.robots || (d.noIndex ? "noindex, nofollow" : "index, follow");

// Author data
const authors = await getCollection("authors");
const authorData = authors.find((a) => a.data.slug === d.authorSlug);

// Format crypto withdrawal speed for display
const cryptoPayoutLabel = (() => {
  if (!d.cryptoWithdrawalSpeedMinutes) return null;
  const mins = d.cryptoWithdrawalSpeedMinutes;
  if (mins < 60) return `${mins} min`;
  const hrs = Math.round(mins / 60);
  return hrs === 1 ? "1 hour" : `${hrs} hours`;
})();

// Build JSON-LD programmatically
const schemas: Record<string, any>[] = [];

// Review schema with itemReviewed as CasinoAndGamblingBusiness
const reviewSchema: Record<string, any> = {
  "@type": "Review",
  name: d.seoTitle || d.title,
  description: d.description,
  url: pageUrl,
  datePublished: d.publishedAt ? new Date(d.publishedAt).toISOString() : undefined,
  dateModified: lastUpdated ? new Date(lastUpdated).toISOString() : undefined,
  itemReviewed: {
    "@type": "CasinoAndGamblingBusiness",
    name: d.casino_name || d.casinoName || d.title,
    ...(d.website ? { url: d.website } : {}),
    ...(d.image ? { image: d.image.startsWith("http") ? d.image : `${siteUrl}${d.image}` } : {}),
  },
  publisher: { "@type": "Organization", name: "cryptobonuslist.com", url: siteUrl },
};

if (d.author) {
  const authorPerson: Record<string, any> = {
    "@type": "Person",
    name: d.author,
    ...(d.authorSlug ? { url: `${siteUrl}/team/${d.authorSlug}` } : {}),
  };

  // Author E-E-A-T enhancements
  if (authorData?.data?.credentials && authorData.data.credentials.length > 0) {
    authorPerson.hasCredential = authorData.data.credentials.map((cred: string) => ({
      "@type": "EducationalOccupationalCredential",
      credentialCategory: cred,
    }));
  }
  if (authorData?.data?.yearsExperience) {
    authorPerson.hasOccupationalExperience = {
      "@type": "OccupationalExperienceRequirements",
      monthsOfExperience: authorData.data.yearsExperience * 12,
    };
  }

  reviewSchema.author = authorPerson;
}

if (d.ourRating) {
  reviewSchema.reviewRating = {
    "@type": "Rating",
    ratingValue: String(d.ourRating),
    bestRating: "10",
    worstRating: "0",
  };
}

if (d.playerRating && d.playerRatingCount) {
  (reviewSchema.itemReviewed as Record<string, any>).aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: String(d.playerRating),
    bestRating: "10",
    worstRating: "0",
    ratingCount: String(d.playerRatingCount),
  };
} else if (d.ourRating) {
  (reviewSchema.itemReviewed as Record<string, any>).aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: String(d.ourRating),
    bestRating: "10",
    worstRating: "0",
    ratingCount: "1",
  };
}

// Add acceptedCryptos to itemReviewed as paymentAccepted and currenciesAccepted
if (d.acceptedCryptos && d.acceptedCryptos.length > 0) {
  (reviewSchema.itemReviewed as Record<string, any>).paymentAccepted = d.acceptedCryptos;
  (reviewSchema.itemReviewed as Record<string, any>).currenciesAccepted = d.acceptedCryptos.join(", ");
}

if (d.image) {
  reviewSchema.image = {
    "@type": "ImageObject",
    url: d.image.startsWith("http") ? d.image : `${siteUrl}${d.image}`,
    width: d.imageWidth || 1792,
    height: d.imageHeight || 1024,
    ...(d.imageAlt ? { caption: d.imageAlt } : {}),
  };
}

schemas.push(reviewSchema);

// FAQ schema
if (d.faqs && d.faqs.length > 0) {
  schemas.push({
    "@type": "FAQPage",
    mainEntity: d.faqs.map((faq: { question: string; answer: string }) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: { "@type": "Answer", text: faq.answer },
    })),
  });
}

// BreadcrumbList schema
schemas.push({
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Casino Reviews", item: `${siteUrl}/casinos` },
    { "@type": "ListItem", position: 3, name: d.title },
  ],
});

const jsonld = JSON.stringify({ "@context": "https://schema.org", "@graph": schemas });
---

<Layout
  title={d.seoTitle}
  description={d.description}
  jsonld={jsonld}
  ogType="article"
  ogImage={d.image || "/favicon.svg"}
  canonical={canonical}
  robots={robots}
>
  <article class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm font-[JetBrains_Mono]">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="text-[#D4D4D4] hover:text-[#39FF14]">Home</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li><a href="/casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Casinos</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li class="text-white" aria-current="page">{d.title}</li>
        </ol>
      </nav>

      <header class="border-[3px] border-white bg-black p-8 mb-8 shadow-[6px_6px_0px_0px_#8A2BE2]">
        <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight mb-4">{d.title}</h1>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-4">{d.description}</p>
        {d.best_for && (
          <p class="text-[#39FF14] font-[JetBrains_Mono] text-sm mb-4">BEST FOR: {d.best_for}</p>
        )}
        <div class="flex flex-wrap items-center gap-6 mb-4">
          {d.ourRating && (
            <div class="flex items-center gap-2">
              <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">OUR RATING:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-3xl">{d.ourRating}</span>
              <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">/10</span>
            </div>
          )}
          {d.trustScore && d.trustBadge && (
            <div class="flex items-center gap-2">
              <span class="text-[#8A2BE2] font-[JetBrains_Mono] text-sm">TRUST:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-3xl">{d.trustScore}</span>
              <span class="text-[#8A2BE2] font-[JetBrains_Mono] text-sm">{d.trustBadge}</span>
            </div>
          )}
          {cryptoPayoutLabel && (
            <div class="flex items-center gap-2">
              <span class="text-[#39FF14] font-[JetBrains_Mono] text-sm">CRYPTO PAYOUT:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-xl">{cryptoPayoutLabel}</span>
            </div>
          )}
          {d.wageringMultiplier != null && (
            <div class="flex items-center gap-2">
              <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">WAGERING:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-xl">{d.wageringMultiplier}x</span>
            </div>
          )}
        </div>
        {lastUpdatedFormatted && (
          <div class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">Last Tested: {lastUpdatedFormatted}</div>
        )}
      </header>

      {d.acceptedCryptos && d.acceptedCryptos.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {d.acceptedCryptos.map((crypto: string) => (
            <span class="border-[2px] border-[#8A2BE2] bg-black text-[#D4D4D4] font-[JetBrains_Mono] text-xs px-3 py-1">{crypto}</span>
          ))}
        </div>
      )}

      {d.image && (
        <div class="mb-8">
          <img src={d.image} alt={d.imageAlt} width={d.imageWidth} height={d.imageHeight} loading="eager" fetchpriority="high" class="w-full h-auto border-[3px] border-white shadow-[6px_6px_0px_0px_#8A2BE2]" />
        </div>
      )}

      {(d.pros || d.cons) && (
        <div class="grid md:grid-cols-2 gap-6 mb-8">
          {d.pros && (
            <div class="border-[3px] border-[#39FF14] bg-black p-6">
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#39FF14] mb-4">PROS</h3>
              <ul class="space-y-2">
                {d.pros.map((pro: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-[#39FF14] mt-1">+</span><span>{pro.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.cons && (
            <div class="border-[3px] border-white bg-black p-6">
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-4">CONS</h3>
              <ul class="space-y-2">
                {d.cons.map((con: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-white mt-1">-</span><span>{con.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      {d.sectionImages && d.sectionImages.length > 0 && (
        <details class="border-[3px] border-[#8A2BE2] bg-black mb-8">
          <summary class="font-[Space_Grotesk] text-lg font-bold text-white p-4 cursor-pointer hover:text-[#8A2BE2] select-none">
            Screenshots ({d.sectionImages.length})
          </summary>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 pt-0">
            {d.sectionImages.map((img: { section: string; path: string }) => (
              <figure class="border-[2px] border-white">
                <img src={img.path} alt={img.section} loading="lazy" class="w-full h-auto" />
                <figcaption class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs p-2 bg-black">{img.section}</figcaption>
              </figure>
            ))}
          </div>
        </details>
      )}

      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#8A2BE2] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-[#D4D4D4] prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
      ">
        <Content />
      </div>
    </div>
  </article>
</Layout>
