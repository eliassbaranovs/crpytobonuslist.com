---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isReview, sortByDate } from "../../lib/posts";
import { getReviewUrl, getClaimUrl, getRatingBg } from "../../lib/casino-filters";
import { generatePairs, getCasinoName } from "../../lib/compare";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.filter(isReview).map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const siteUrl = "https://cryptobonuslist.com";
const pageUrl = `${siteUrl}/casinos/${d.slug}`;
const canonical = pageUrl;

const lastUpdated = d.updatedAt || d.publishedAt;
const lastUpdatedFormatted = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : null;
const robots = d.robots || (d.noIndex ? "noindex, nofollow" : "index, follow");

// Author data
const authors = await getCollection("authors");
const authorData = authors.find((a) => a.data.slug === d.authorSlug);

// CTA URL - use /go/{slug} redirect pattern
const claimUrl = d.claim_url
  ? (d.claim_url.includes("/") ? `/go/${d.slug}` : `/go/${d.claim_url}`)
  : d.website
    ? `/go/${d.slug}`
    : null;

// Format crypto withdrawal speed for display
const cryptoPayoutLabel = (() => {
  if (!d.cryptoWithdrawalSpeedMinutes) return null;
  const mins = d.cryptoWithdrawalSpeedMinutes;
  if (mins < 60) return `${mins} min`;
  const hrs = Math.round(mins / 60);
  return hrs === 1 ? "1 hour" : `${hrs} hours`;
})();

// Related reviews - 3 other casino reviews, sorted by date
const allPosts = await getCollection("posts");
const relatedReviews = sortByDate(
  allPosts
    .filter(isReview)
    .filter((r) => r.data.slug !== d.slug && !r.data.draft)
).slice(0, 3);

// Comparison pairs for this casino
const comparisonPairs = generatePairs(allPosts)
  .filter((p) => p.slugA === d.slug || p.slugB === d.slug)
  .slice(0, 6);
const comparisonReviews = allPosts.filter(isReview).filter((r) => !r.data.draft);

// Reading time
const wordCount = d.wordCount || (post.body ? post.body.split(/\s+/).filter(Boolean).length : 0);
const readingTime = d.readingTime || (Math.ceil(wordCount / 200) || 1) + " min read";

// Build JSON-LD programmatically
const schemas: Record<string, any>[] = [];

// Review schema with itemReviewed as CasinoAndGamblingBusiness
const reviewSchema: Record<string, any> = {
  "@type": "Review",
  name: d.seoTitle || d.title,
  description: d.description,
  url: pageUrl,
  datePublished: d.publishedAt ? new Date(d.publishedAt).toISOString() : undefined,
  dateModified: lastUpdated ? new Date(lastUpdated).toISOString() : undefined,
  itemReviewed: {
    "@type": "CasinoAndGamblingBusiness",
    name: d.casino_name || d.casinoName || d.title,
    ...(d.website ? { url: d.website } : {}),
    ...(d.image ? { image: d.image.startsWith("http") ? d.image : `${siteUrl}${d.image}` } : {}),
  },
  publisher: { "@type": "Organization", name: "cryptobonuslist.com", url: siteUrl },
};

if (d.author) {
  const authorPerson: Record<string, any> = {
    "@type": "Person",
    name: d.author,
    ...(d.authorSlug ? { url: `${siteUrl}/team/${d.authorSlug}` } : {}),
  };

  // Author E-E-A-T enhancements
  if (authorData?.data?.credentials && authorData.data.credentials.length > 0) {
    authorPerson.hasCredential = authorData.data.credentials.map((cred: string) => ({
      "@type": "EducationalOccupationalCredential",
      credentialCategory: cred,
    }));
  }
  if (authorData?.data?.yearsExperience) {
    authorPerson.hasOccupationalExperience = {
      "@type": "OccupationalExperienceRequirements",
      monthsOfExperience: authorData.data.yearsExperience * 12,
    };
  }

  reviewSchema.author = authorPerson;
}

if (d.ourRating) {
  reviewSchema.reviewRating = {
    "@type": "Rating",
    ratingValue: String(d.ourRating),
    bestRating: "10",
    worstRating: "0",
  };
}

if (d.playerRating && d.playerRatingCount) {
  (reviewSchema.itemReviewed as Record<string, any>).aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: String(d.playerRating),
    bestRating: "10",
    worstRating: "0",
    ratingCount: String(d.playerRatingCount),
  };
} else if (d.ourRating) {
  (reviewSchema.itemReviewed as Record<string, any>).aggregateRating = {
    "@type": "AggregateRating",
    ratingValue: String(d.ourRating),
    bestRating: "10",
    worstRating: "0",
    ratingCount: "1",
  };
}

// Add acceptedCryptos to itemReviewed as paymentAccepted and currenciesAccepted
if (d.acceptedCryptos && d.acceptedCryptos.length > 0) {
  (reviewSchema.itemReviewed as Record<string, any>).paymentAccepted = d.acceptedCryptos;
  (reviewSchema.itemReviewed as Record<string, any>).currenciesAccepted = d.acceptedCryptos.join(", ");
}

if (d.image) {
  reviewSchema.image = {
    "@type": "ImageObject",
    url: d.image.startsWith("http") ? d.image : `${siteUrl}${d.image}`,
    width: d.imageWidth || 1792,
    height: d.imageHeight || 1024,
    ...(d.imageAlt ? { caption: d.imageAlt } : {}),
  };
}

schemas.push(reviewSchema);

// FAQ schema
if (d.faqs && d.faqs.length > 0) {
  schemas.push({
    "@type": "FAQPage",
    mainEntity: d.faqs.map((faq: { question: string; answer: string }) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: { "@type": "Answer", text: faq.answer },
    })),
  });
}

// BreadcrumbList schema
schemas.push({
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Casino Reviews", item: `${siteUrl}/casinos` },
    { "@type": "ListItem", position: 3, name: d.title },
  ],
});

const jsonld = JSON.stringify({ "@context": "https://schema.org", "@graph": schemas });
---

<Layout
  title={d.seoTitle || d.title}
  description={d.description}
  jsonld={jsonld}
  ogType="article"
  ogImage={d.image || "/images/og-default.jpg"}
  canonical={canonical}
  robots={robots}
>
  {/* Reading progress bar */}
  <div id="progress-bar" role="progressbar" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100" aria-label="Reading progress" class="fixed top-0 left-0 h-[3px] bg-[#A855F7] z-[100] transition-all duration-100" style="width: 0%"></div>

  <article class="px-6 py-12 pb-24 md:pb-12">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm font-[JetBrains_Mono]">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="text-[#D4D4D4] hover:text-[#39FF14]">Home</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li><a href="/casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Casinos</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li class="text-white truncate max-w-[300px]" aria-current="page">{d.title}</li>
        </ol>
      </nav>

      {/* Hero image */}
      {d.image && (
        <div class="relative">
          <img
            src={d.image}
            alt={d.imageAlt || d.title}
            width={d.imageWidth}
            height={d.imageHeight}
            loading="eager"
            fetchpriority="high"
            decoding="async"
            class="w-full h-auto border-[3px] border-white"
          />
          {/* Badges overlay */}
          <div class="absolute top-0 left-0 flex gap-2 p-3">
            {d.verified && (
              <span class="bg-[#39FF14] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                VERIFIED
              </span>
            )}
            {d.exclusive && (
              <span class="bg-[#FAFF00] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                EXCLUSIVE
              </span>
            )}
          </div>
          {/* Rating overlay */}
          {d.ourRating && (
            <div class="absolute top-0 right-0 p-3">
              <div class="bg-black/80 border-2 border-[#FAFF00] px-3 py-2 flex items-center gap-1.5">
                <span class="text-[#FAFF00] font-[Space_Grotesk] font-bold text-2xl">{d.ourRating}</span>
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">/10</span>
              </div>
            </div>
          )}
        </div>
      )}

      <header class={`border-[3px] border-white bg-black p-6 md:p-8 mb-8 shadow-[6px_6px_0px_0px_#A855F7] ${d.image ? '-mt-[3px]' : ''}`}>
        {/* Meta row */}
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {lastUpdatedFormatted && (
            <div class="inline-flex items-center gap-2 bg-[#1a1a1a] border border-[#333] px-3 py-1.5">
              <span class="text-[#A855F7] font-[JetBrains_Mono] text-xs font-bold">LAST TESTED:</span>
              <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">{lastUpdatedFormatted}</span>
            </div>
          )}
          <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">{readingTime}</span>
        </div>

        {/* Title row with logo */}
        <div class="flex items-start gap-4 mb-4">
          {d.logo && (
            <img src={d.logo} alt={d.casinoName || d.title} class="w-14 h-14 md:w-16 md:h-16 object-contain border-2 border-white bg-white shrink-0 mt-1" />
          )}
          <div class="flex-1">
            <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight">
              {d.title}
            </h1>
          </div>
        </div>

        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-4">{d.description}</p>

        {d.best_for && (
          <p class="text-[#39FF14] font-[JetBrains_Mono] text-sm mb-4">BEST FOR: {d.best_for}</p>
        )}

        {/* Stats row */}
        <div class="flex flex-wrap items-center gap-6 mb-6">
          {d.ourRating && !d.image && (
            <div class="flex items-center gap-2">
              <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">OUR RATING:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-3xl">{d.ourRating}</span>
              <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">/10</span>
            </div>
          )}
          {d.trustScore && d.trustBadge && (
            <div class="flex items-center gap-2">
              <span class="text-[#A855F7] font-[JetBrains_Mono] text-sm">TRUST:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-3xl">{d.trustScore}</span>
              <span class="text-[#A855F7] font-[JetBrains_Mono] text-sm">{d.trustBadge}</span>
            </div>
          )}
          {cryptoPayoutLabel && (
            <div class="flex items-center gap-2">
              <span class="text-[#39FF14] font-[JetBrains_Mono] text-sm">CRYPTO PAYOUT:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-xl">{cryptoPayoutLabel}</span>
            </div>
          )}
          {d.wageringMultiplier != null && (
            <div class="flex items-center gap-2">
              <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">WAGERING:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-xl">{d.wageringMultiplier}x</span>
            </div>
          )}
        </div>

        {/* CTA Button */}
        {claimUrl && (
          <div class="mb-4">
            <a
              href={claimUrl}
              target="_blank"
              rel="nofollow sponsored"
              class="block w-full bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-8 py-5 text-center text-xl md:text-2xl border-[3px] border-black shadow-[8px_8px_0px_0px_#000000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[4px_4px_0px_0px_#000000] transition-all uppercase tracking-wide"
            >
              VISIT CASINO
            </a>
          </div>
        )}

        {/* Casino + rating footer */}
        <div class="flex items-center justify-between flex-wrap gap-4 pt-4 border-t-2 border-[#333]">
          <div class="flex items-center gap-4">
            {d.playerRating && Number(d.playerRating) > 0 && (
              <div class="flex items-center gap-2">
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">PLAYERS:</span>
                <span class="text-white font-[Space_Grotesk] font-bold text-lg">{d.playerRating}</span>
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">/10</span>
                {d.playerRatingCount && Number(d.playerRatingCount) > 0 && (
                  <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">({d.playerRatingCount} votes)</span>
                )}
              </div>
            )}
          </div>
          {d.website && (
            <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">{d.website.replace(/^https?:\/\/(www\.)?/, '')}</span>
          )}
        </div>
      </header>

      {d.acceptedCryptos && d.acceptedCryptos.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8" aria-label="Accepted cryptocurrencies">
          {d.acceptedCryptos.map((crypto: string) => (
            <span class="border-[2px] border-[#A855F7] bg-black text-[#D4D4D4] font-[JetBrains_Mono] text-xs px-3 py-1">{crypto}</span>
          ))}
        </div>
      )}

      {(d.pros || d.cons) && (
        <div class="grid md:grid-cols-2 gap-6 mb-8">
          {d.pros && d.pros.length > 0 && (
            <div class="border-[3px] border-[#39FF14] bg-black p-6">
              <h2 class="font-[Space_Grotesk] text-xl font-bold text-[#39FF14] mb-4">PROS</h2>
              <ul class="space-y-2">
                {d.pros.map((pro: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-[#39FF14] mt-0.5 shrink-0">+</span>
                    <span>{pro.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.cons && d.cons.length > 0 && (
            <div class="border-[3px] border-white bg-black p-6">
              <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-4">CONS</h2>
              <ul class="space-y-2">
                {d.cons.map((con: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-[#D4D4D4] mt-0.5 shrink-0">&minus;</span>
                    <span>{con.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      {d.sectionImages && d.sectionImages.length > 0 && (
        <details id="screenshots" class="border-[3px] border-[#A855F7] bg-black mb-8">
          <summary class="font-[Space_Grotesk] text-lg font-bold text-white p-4 cursor-pointer hover:text-[#A855F7] select-none">
            Screenshots ({d.sectionImages.length})
          </summary>
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 p-4 pt-0">
            {d.sectionImages.map((img: { section: string; path: string }) => (
              <figure class="border-[2px] border-white">
                <img src={img.path} alt={img.section} loading="lazy" class="w-full h-auto" />
                <figcaption class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs p-2 bg-black">{img.section}</figcaption>
              </figure>
            ))}
          </div>
        </details>
      )}

      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#A855F7] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:text-[17px] prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-[#D4D4D4] prose-li:text-[17px] prose-li:leading-relaxed
        prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
        prose-blockquote:border-l-[3px] prose-blockquote:border-[#A855F7] prose-blockquote:bg-[#1a1a1a] prose-blockquote:py-4 prose-blockquote:px-6
        prose-a:text-[#A855F7] prose-a:underline prose-a:decoration-[#A855F7]/50 hover:prose-a:text-[#39FF14]
        prose-img:border-[2px] prose-img:border-white prose-img:shadow-[6px_6px_0px_0px_#A855F7]
        prose-hr:border-[#A855F7]
      ">
        <Content />
      </div>

      {/* Mid-article CTA */}
      {claimUrl && (
        <div class="mt-10 mb-4 border-[3px] border-[#A855F7] bg-black p-6 text-center">
          <p class="text-white font-[Space_Grotesk] font-bold text-lg md:text-xl mb-4">
            Ready to try {d.casinoName || d.title}?
          </p>
          <a
            href={claimUrl}
            target="_blank"
            rel="nofollow sponsored"
            class="inline-block bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-10 py-4 text-lg border-[3px] border-black shadow-[6px_6px_0px_0px_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[3px_3px_0px_0px_#000] transition-all uppercase tracking-wide"
          >
            VISIT CASINO
          </a>
        </div>
      )}

      {/* Author card */}
      {authorData ? (
        <div class="mt-8 border-[3px] border-white bg-black p-6 md:p-8">
          <div class="flex items-start gap-5">
            {authorData.data.avatar ? (
              <img src={authorData.data.avatar} alt={authorData.data.name} class="w-16 h-16 md:w-20 md:h-20 border-[3px] border-[#A855F7] object-cover shrink-0" />
            ) : (
              <div class="w-16 h-16 md:w-20 md:h-20 border-[3px] border-[#A855F7] bg-[#1a1a1a] flex items-center justify-center shrink-0">
                <span class="text-[#A855F7] font-[Space_Grotesk] font-bold text-2xl">{authorData.data.name.charAt(0)}</span>
              </div>
            )}
            <div class="flex-1">
              <span class="text-[#A855F7] font-[JetBrains_Mono] text-xs font-bold tracking-wider">REVIEWED BY</span>
              <a href={`/team/${authorData.data.slug}`} class="block font-[Space_Grotesk] text-xl md:text-2xl font-bold text-white hover:text-[#A855F7] transition-colors mt-1">
                {authorData.data.name}
              </a>
              {authorData.data.role && (
                <p class="text-[#D4D4D4] text-sm font-[JetBrains_Mono] mt-1">{authorData.data.role}</p>
              )}
              {authorData.data.bio && (
                <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mt-3 leading-relaxed">{authorData.data.bio}</p>
              )}
              {authorData.data.expertise && authorData.data.expertise.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-3">
                  {authorData.data.expertise.map((exp: string) => (
                    <span class="text-[#A855F7] text-xs font-[JetBrains_Mono] border border-[#A855F7]/40 px-2 py-0.5">{exp}</span>
                  ))}
                </div>
              )}
              {lastUpdatedFormatted && (
                <p class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs mt-3">Last updated: {lastUpdatedFormatted}</p>
              )}
            </div>
          </div>
        </div>
      ) : (
        <aside class="mt-8 p-6 border-[3px] border-[#333] bg-[#0d0d0d]">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-3">
              <span class="text-[#D4D4D4] font-[Public_Sans] text-sm">Reviewed by:</span>
              {d.authorSlug ? (
                <a href={`/team/${d.authorSlug}`} class="text-[#A855F7] font-[Space_Grotesk] font-bold hover:underline">
                  {d.author}
                </a>
              ) : (
                <span class="text-white font-[Space_Grotesk] font-bold">{d.author}</span>
              )}
            </div>
            {lastUpdatedFormatted && (
              <div class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">Last updated: {lastUpdatedFormatted}</div>
            )}
          </div>
        </aside>
      )}

      {/* Related Reviews */}
      {relatedReviews.length > 0 && (
        <section class="mt-12 pt-8 border-t-[3px] border-white" aria-label="Related casino reviews">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-6 text-[#FAFF00]">RELATED REVIEWS</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {relatedReviews.map((review) => {
              const name = review.data.casino_name || review.data.casinoName || review.data.title;
              const rating = review.data.ourRating || 0;
              const ratingBg = getRatingBg(rating);
              const pros = (review.data.pros || []).slice(0, 2);
              const bonus = review.data.bonus;

              return (
                <a href={`/casinos/${review.data.slug}`} class="group block bg-black border-[3px] border-white shadow-none hover:shadow-[6px_6px_0px_0px_#A855F7] transition-all">
                  {review.data.image && (
                    <div class="overflow-hidden border-b-[3px] border-white">
                      <img
                        src={review.data.image}
                        alt={review.data.imageAlt || review.data.title}
                        width={review.data.imageWidth}
                        height={review.data.imageHeight}
                        loading="lazy"
                        class="w-full h-auto group-hover:scale-[1.02] transition-transform duration-300"
                      />
                    </div>
                  )}
                  <div class="p-4">
                    <div class="flex items-center justify-between gap-2 mb-2">
                      <h3 class="font-[Space_Grotesk] text-sm font-bold text-white line-clamp-2 group-hover:text-[#A855F7] transition-colors">{name}</h3>
                      {rating > 0 && (
                        <span class={`${ratingBg} font-[JetBrains_Mono] text-xs font-bold px-2 py-0.5 shrink-0`}>
                          {rating.toFixed(1)}
                        </span>
                      )}
                    </div>
                    {bonus && (
                      <p class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold mb-2">{bonus}</p>
                    )}
                    {pros.length > 0 && (
                      <ul class="space-y-1">
                        {pros.map((pro) => (
                          <li class="flex items-start gap-1.5 text-xs font-[Public_Sans] text-[#D4D4D4]">
                            <span class="text-[#39FF14] mt-0.5 shrink-0">+</span>
                            <span class="line-clamp-1">{pro}</span>
                          </li>
                        ))}
                      </ul>
                    )}
                  </div>
                </a>
              );
            })}
          </div>
        </section>
      )}

      {/* Compare with other casinos */}
      {comparisonPairs.length > 0 && (
        <section class="mt-12 pt-8 border-t-[3px] border-white">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-6 text-[#FAFF00]">
            COMPARE {(d.casino_name || d.casinoName || d.title.replace(/ Review.*$/i, "")).toUpperCase()}
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {comparisonPairs.map((pair) => {
              const otherSlug = pair.slugA === d.slug ? pair.slugB : pair.slugA;
              const otherReview = comparisonReviews.find((r) => r.data.slug === otherSlug);
              if (!otherReview) return null;
              const otherName = getCasinoName(otherReview);
              return (
                <a href={`/compare/${pair.compareSlug}`} class="group block bg-black border-[3px] border-white p-4 shadow-none hover:shadow-[6px_6px_0px_0px_#8A2BE2] transition-all">
                  <p class="font-[Space_Grotesk] text-sm font-bold text-white group-hover:text-[#8A2BE2] transition-colors">
                    vs {otherName}
                  </p>
                  <p class="text-[#D4D4D4] text-xs font-[JetBrains_Mono] mt-1">
                    {(otherReview.data.ourRating || 0).toFixed(1)}/10
                  </p>
                </a>
              );
            })}
          </div>
        </section>
      )}

      <div class="mt-12 pt-8 border-t-[3px] border-white">
        <a href="/casinos" class="inline-block bg-transparent text-white font-[Space_Grotesk] font-bold px-6 py-3 border-[3px] border-white shadow-[6px_6px_0px_0px_#A855F7] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#A855F7] transition-all">
          BACK TO CASINO REVIEWS
        </a>
      </div>
    </div>
  </article>

  {/* Sticky Mobile CTA */}
  {claimUrl && (
    <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-black border-t-[3px] border-[#39FF14] p-4 shadow-[0_-4px_20px_rgba(57,255,20,0.3)]">
      <a href={claimUrl} target="_blank" rel="nofollow sponsored" class="block w-full bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-6 py-4 text-center text-lg border-[3px] border-white shadow-[4px_4px_0px_0px_#FFFFFF] uppercase">
        VISIT CASINO
      </a>
    </div>
  )}

  {/* Reading progress script */}
  <script>
    const bar = document.getElementById('progress-bar');
    if (bar) {
      window.addEventListener('scroll', () => {
        const docH = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docH > 0 ? Math.min((window.scrollY / docH) * 100, 100) : 0;
        bar.style.width = pct + '%';
      }, { passive: true });
    }
  </script>
</Layout>
