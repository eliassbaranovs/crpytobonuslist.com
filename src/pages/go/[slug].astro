---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  const paths = [];
  for (const post of posts) {
    // Route by claim_url if it's a plain slug (not a full URL)
    if (post.data.claim_url && !post.data.claim_url.includes("/")) {
      paths.push({
        params: { slug: post.data.claim_url },
        props: { affiliateUrl: post.data.website || "#", casinoName: post.data.casino || post.data.casino_name || post.data.title },
      });
    }
    // Route by post slug — use claim_url as destination if it's a full URL, otherwise website
    if (post.data.website || post.data.claim_url) {
      const destination = (post.data.claim_url && post.data.claim_url.includes("/")) ? post.data.claim_url : post.data.website || "#";
      paths.push({
        params: { slug: post.data.slug },
        props: { affiliateUrl: destination, casinoName: post.data.casino || post.data.casino_name || post.data.title },
      });
    }
  }
  return paths;
}

const { affiliateUrl, casinoName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta http-equiv="refresh" content={`0; url=${affiliateUrl}`} />
    <title>Redirecting to {casinoName}...</title>
    <style>
      body { background: #0A0A0A; color: #fff; font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
      .redirect-box { text-align: center; border: 3px solid #39FF14; padding: 2rem; background: #000; }
      a { color: #39FF14; }
    </style>
  </head>
  <body>
    <div class="redirect-box">
      <p>Redirecting to {casinoName}...</p>
      <p>If you are not redirected, <a href={affiliateUrl}>click here</a>.</p>
    </div>
  </body>
</html>
