---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("posts");

  // Use a Map to deduplicate by slug
  const pathMap = new Map<string, { params: { slug: string }; props: { affiliateUrl: string; casinoName: string } }>();

  for (const post of posts) {
    const casinoName = post.data.casinoName || post.data.casino || post.data.casino_name || post.data.title;

    // Route by claim_url if it's a plain slug (not a full URL)
    if (post.data.claim_url && !post.data.claim_url.includes("/")) {
      const dest = post.data.website || "";
      if (dest.startsWith("https://")) {
        pathMap.set(post.data.claim_url, {
          params: { slug: post.data.claim_url },
          props: { affiliateUrl: dest, casinoName },
        });
      }
    }

    // Route by post slug
    if (post.data.website || post.data.claim_url) {
      const claimIsExternal =
        post.data.claim_url &&
        post.data.claim_url.startsWith("https://");
      const destination = claimIsExternal ? post.data.claim_url! : post.data.website || "";

      // Only generate the page if destination is a valid https URL
      if (destination.startsWith("https://")) {
        pathMap.set(post.data.slug, {
          params: { slug: post.data.slug },
          props: { affiliateUrl: destination, casinoName },
        });
      }
    }
  }

  return Array.from(pathMap.values());
}

const { affiliateUrl, casinoName } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="robots" content="noindex, nofollow" />
    <meta http-equiv="refresh" content={`0; url=${affiliateUrl}`} />
    <title>Redirecting to {casinoName}...</title>
    <style>
      body { background: #0A0A0A; color: #fff; font-family: system-ui, sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; }
      .redirect-box { text-align: center; border: 3px solid #39FF14; padding: 2rem; background: #000; }
      a { color: #39FF14; }
    </style>
  </head>
  <body>
    <div class="redirect-box">
      <p>Redirecting to {casinoName}...</p>
      <p>If you are not redirected, <a href={affiliateUrl}>click here</a>.</p>
    </div>
  </body>
</html>
