---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import { getAllNews, getPostUrl, isBonus, isGuide, isReview, sortByDate } from "../lib/posts";

const allPosts = await getCollection("posts");
const latestBonuses = sortByDate(allPosts.filter(isBonus)).slice(0, 3);
const latestReviews = sortByDate(allPosts.filter(isReview)).slice(0, 3);
const latestGuides = sortByDate(allPosts.filter(isGuide)).slice(0, 3);
const latestNews = (await getAllNews()).slice(0, 2);

const totalReviews = allPosts.filter(isReview).length;
const totalBonuses = allPosts.filter(isBonus).length;

const schemaJsonLd = JSON.stringify([
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "CryptoBonusList",
    "url": "https://cryptobonuslist.com",
    "description": "Independent crypto casino reviews and bonus comparisons. Real deposits, honest ratings, no fluff.",
    "publisher": {
      "@type": "Organization",
      "name": "CryptoBonusList",
      "url": "https://cryptobonuslist.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://cryptobonuslist.com/favicon.svg"
      }
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "CryptoBonusList",
    "url": "https://cryptobonuslist.com",
    "logo": "https://cryptobonuslist.com/favicon.svg",
    "foundingDate": "2025",
    "description": "Independent crypto casino review and bonus comparison site.",
    "ethicsPolicy": "https://cryptobonuslist.com/affiliate-disclosure",
    "publishingPrinciples": "https://cryptobonuslist.com/methodology"
  },
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What is CryptoBonusList?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "CryptoBonusList is an independent review site for crypto casinos and their bonuses. We test every casino with real deposits, play through wagering requirements, and attempt withdrawals before publishing a review."
        }
      },
      {
        "@type": "Question",
        "name": "How do you rate crypto casinos?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "We use a 0-10 rating scale based on six weighted categories: bonus value (20%), withdrawal speed (20%), terms fairness (20%), licensing and trust (20%), game selection (10%), and customer support (10%). Every casino goes through the same testing process."
        }
      },
      {
        "@type": "Question",
        "name": "Are your casino reviews independent?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Yes. We earn affiliate commissions when users sign up through our links, but commission rates do not affect scores. We have declined partnerships with casinos that asked for guaranteed minimum ratings."
        }
      },
      {
        "@type": "Question",
        "name": "How often are reviews updated?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Reviews are updated when casino conditions change, such as modified bonus terms, new withdrawal policies, or licensing changes. Every review displays its last update date."
        }
      }
    ]
  }
]);
---

<Layout
  title="CryptoBonusList | Crypto Casino Reviews and Bonuses 2026"
  description="Independent crypto casino reviews and bonus comparisons. Real deposits, real wagering tests, honest 0-10 ratings. Find the best crypto casinos in 2026."
  jsonld={schemaJsonLd}
>
  <!-- Hero -->
  <section class="px-6 py-16 md:py-24 border-b-[3px] border-white">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-5xl md:text-7xl lg:text-8xl font-bold leading-none tracking-tight">
        CRYPTO CASINO REVIEWS.<br />
        <span class="text-[#39FF14]">TESTED WITH REAL MONEY.</span>
      </h1>
      <p class="mt-6 text-[#D4D4D4] font-[Public_Sans] text-lg md:text-xl max-w-2xl">
        We deposit, play, and withdraw at every casino before writing a review. Wagering breakdowns, payout speeds, and honest ratings on a 0-10 scale.
      </p>
      <div class="mt-8 flex flex-wrap gap-4">
        <a href="/casinos" class="inline-block bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-8 py-4 text-lg border-[3px] border-white shadow-[6px_6px_0px_0px_#FFFFFF] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#FFFFFF] transition-all">VIEW CASINOS</a>
        <a href="/bonus" class="inline-block bg-transparent text-white font-[Space_Grotesk] font-bold px-8 py-4 text-lg border-[3px] border-white shadow-[6px_6px_0px_0px_#39FF14] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#39FF14] transition-all">VIEW BONUSES</a>
      </div>
    </div>
  </section>

  <!-- Trust Strip -->
  <section class="border-b-[3px] border-white">
    <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-white">
      <div class="p-6 text-center">
        <p class="font-[JetBrains_Mono] text-3xl font-bold text-[#39FF14]">{totalReviews}</p>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-sm mt-1">Casinos Reviewed</p>
      </div>
      <div class="p-6 text-center">
        <p class="font-[JetBrains_Mono] text-3xl font-bold text-[#39FF14]">{totalBonuses}</p>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-sm mt-1">Bonuses Tested</p>
      </div>
      <div class="p-6 text-center">
        <p class="font-[JetBrains_Mono] text-3xl font-bold text-[#39FF14]">0-10</p>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-sm mt-1">Rating Scale</p>
      </div>
      <div class="p-6 text-center">
        <p class="font-[JetBrains_Mono] text-3xl font-bold text-[#39FF14]">100%</p>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-sm mt-1">Real Deposits</p>
      </div>
    </div>
  </section>

  <!-- Casino Reviews -->
  {latestReviews.length > 0 && (
    <section class="px-6 py-12">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold text-white">
            CASINO <span class="text-[#39FF14]">REVIEWS</span>
          </h2>
          <a href="/casinos" class="text-[#39FF14] font-[JetBrains_Mono] text-sm font-bold hover:underline">VIEW ALL</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestReviews.map((review) => (
            <a href={getPostUrl(review)} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#39FF14]">
              <div class="flex items-center justify-between mb-3">
                <div class="flex gap-2 items-center">
                  {review.data.logo && (
                    <img src={review.data.logo} alt={review.data.casinoName || ""} class="w-8 h-8 rounded object-cover" loading="lazy" />
                  )}
                  <span class="text-[#39FF14] text-xs font-[JetBrains_Mono] font-bold uppercase">Review</span>
                </div>
                {review.data.ourRating && (
                  <span class={`font-[JetBrains_Mono] font-bold text-lg ${review.data.ourRating >= 8 ? "text-[#39FF14]" : review.data.ourRating >= 6 ? "text-[#FAFF00]" : "text-white"}`}>
                    {review.data.ourRating}/10
                  </span>
                )}
              </div>
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{review.data.casinoName || review.data.title}</h3>
              <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-4 line-clamp-2">{review.data.description}</p>
              <div class="flex flex-wrap gap-2">
                {review.data.licences && (
                  <span class="text-[#D4D4D4] text-xs font-[JetBrains_Mono] border border-white px-2 py-1">{review.data.licences}</span>
                )}
                {review.data.established && (
                  <span class="text-[#D4D4D4] text-xs font-[JetBrains_Mono] border border-white px-2 py-1">Est. {review.data.established}</span>
                )}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest Bonuses -->
  <section class="px-6 py-12 border-t-[3px] border-white">
    <div class="max-w-7xl mx-auto">
      <div class="flex items-center justify-between mb-8">
        <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold text-white">
          LATEST <span class="text-[#8A2BE2]">BONUSES</span>
        </h2>
        <a href="/bonus" class="text-[#39FF14] font-[JetBrains_Mono] text-sm font-bold hover:underline">VIEW ALL</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {latestBonuses.map((bonus) => (
          <a href={getPostUrl(bonus)} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#8A2BE2]">
            <div class="mb-3 flex gap-2 items-center">
              {bonus.data.bonusType && (
                <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">{bonus.data.bonusType}</span>
              )}
              {bonus.data.verified && (
                <span class="inline-block bg-[#39FF14] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">VERIFIED</span>
              )}
            </div>
            <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{bonus.data.title}</h3>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-4 line-clamp-2">{bonus.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {bonus.data.bonus && (
                <span class="text-white text-xs font-[JetBrains_Mono] border border-white px-2 py-1">{bonus.data.bonus}</span>
              )}
              {bonus.data.wageringRequirements && (
                <span class="text-[#FAFF00] text-xs font-[JetBrains_Mono] border border-[#FAFF00] px-2 py-1">{bonus.data.wageringRequirements} WR</span>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Guides -->
  {latestGuides.length > 0 && (
    <section class="px-6 py-12 border-t-[3px] border-white">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold text-white">
            <span class="text-[#39FF14]">GUIDES</span>
          </h2>
          <a href="/guides" class="text-[#39FF14] font-[JetBrains_Mono] text-sm font-bold hover:underline">VIEW ALL</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {latestGuides.map((guide) => (
            <a href={getPostUrl(guide)} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#39FF14]">
              <span class="text-[#39FF14] text-xs font-[JetBrains_Mono] font-bold uppercase mb-3 block">Guide</span>
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{guide.data.title}</h3>
              <p class="text-[#D4D4D4] text-sm font-[Public_Sans] line-clamp-3">{guide.data.description}</p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Latest News -->
  {latestNews.length > 0 && (
    <section class="px-6 py-12 border-t-[3px] border-white">
      <div class="max-w-7xl mx-auto">
        <div class="flex items-center justify-between mb-8">
          <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold text-white">
            LATEST <span class="text-[#FAFF00]">NEWS</span>
          </h2>
          <a href="/news" class="text-[#39FF14] font-[JetBrains_Mono] text-sm font-bold hover:underline">VIEW ALL</a>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          {latestNews.map((article) => (
            <a href={`/news/${article.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#FAFF00]">
              <div class="flex items-center gap-3 mb-3">
                <span class="text-[#39FF14] text-xs font-[JetBrains_Mono]">
                  {new Date(article.data.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
                </span>
                <span class="text-[#D4D4D4] text-xs font-[Public_Sans]">{article.data.author}</span>
              </div>
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{article.data.title}</h3>
              <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-4 line-clamp-3">{article.data.description}</p>
              <div class="flex flex-wrap gap-2">
                {article.data.tags.slice(0, 3).map((tag: string) => (
                  <span class="text-[#FAFF00] text-xs font-[JetBrains_Mono] border border-[#FAFF00] px-2 py-1">{tag}</span>
                ))}
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- How We Work -->
  <section class="px-6 py-12 border-t-[3px] border-white">
    <div class="max-w-7xl mx-auto">
      <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold mb-8 text-white">
        HOW WE <span class="text-[#39FF14]">WORK</span>
      </h2>
      <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="border-[3px] border-white p-6">
          <span class="bg-[#39FF14] text-black font-[JetBrains_Mono] font-bold text-xl w-10 h-10 flex items-center justify-center mb-4">1</span>
          <h3 class="font-[Space_Grotesk] text-lg font-bold text-white mb-2">DEPOSIT</h3>
          <p class="text-[#D4D4D4] font-[Public_Sans] text-sm">We deposit real crypto at every casino. BTC, ETH, or USDT. Transaction times and fees recorded.</p>
        </div>
        <div class="border-[3px] border-white p-6">
          <span class="bg-[#8A2BE2] text-white font-[JetBrains_Mono] font-bold text-xl w-10 h-10 flex items-center justify-center mb-4">2</span>
          <h3 class="font-[Space_Grotesk] text-lg font-bold text-white mb-2">PLAY</h3>
          <p class="text-[#D4D4D4] font-[Public_Sans] text-sm">Claim bonuses, test wagering requirements, check game contributions and max bet rules.</p>
        </div>
        <div class="border-[3px] border-white p-6">
          <span class="bg-[#FAFF00] text-black font-[JetBrains_Mono] font-bold text-xl w-10 h-10 flex items-center justify-center mb-4">3</span>
          <h3 class="font-[Space_Grotesk] text-lg font-bold text-white mb-2">WITHDRAW</h3>
          <p class="text-[#D4D4D4] font-[Public_Sans] text-sm">Request a payout and time it. KYC process, pending periods, and actual withdrawal speed documented.</p>
        </div>
        <div class="border-[3px] border-white p-6">
          <span class="bg-[#39FF14] text-black font-[JetBrains_Mono] font-bold text-xl w-10 h-10 flex items-center justify-center mb-4">4</span>
          <h3 class="font-[Space_Grotesk] text-lg font-bold text-white mb-2">RATE</h3>
          <p class="text-[#D4D4D4] font-[Public_Sans] text-sm">Score on a 0-10 scale across six categories. Pros, cons, and evidence. No paid ratings.</p>
        </div>
      </div>
      <div class="mt-6 text-right">
        <a href="/methodology" class="text-[#39FF14] font-[JetBrains_Mono] text-sm font-bold hover:underline">READ FULL METHODOLOGY</a>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="px-6 py-12 border-t-[3px] border-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-[Space_Grotesk] text-3xl md:text-4xl font-bold mb-8 text-white">
        FREQUENTLY ASKED <span class="text-[#39FF14]">QUESTIONS</span>
      </h2>

      <div class="space-y-4">
        <details class="border-[3px] border-white bg-black group" open>
          <summary class="p-6 cursor-pointer font-[Space_Grotesk] font-bold text-lg text-white flex items-center justify-between">
            <h3>What is CryptoBonusList?</h3>
            <span class="text-[#39FF14] font-[JetBrains_Mono] text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
              CryptoBonusList is an independent review site for crypto casinos and their bonuses. We test every casino with real deposits, play through wagering requirements, and attempt withdrawals before publishing a review. No copy-paste from casino websites.
            </p>
          </div>
        </details>

        <details class="border-[3px] border-white bg-black group">
          <summary class="p-6 cursor-pointer font-[Space_Grotesk] font-bold text-lg text-white flex items-center justify-between">
            <h3>How do you rate crypto casinos?</h3>
            <span class="text-[#39FF14] font-[JetBrains_Mono] text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
              We use a 0-10 rating scale based on six weighted categories: bonus value (20%), withdrawal speed (20%), terms fairness (20%), licensing and trust (20%), game selection (10%), and customer support (10%). Every casino goes through the same testing process. Full details on our <a href="/methodology" class="text-[#39FF14] underline">methodology page</a>.
            </p>
          </div>
        </details>

        <details class="border-[3px] border-white bg-black group">
          <summary class="p-6 cursor-pointer font-[Space_Grotesk] font-bold text-lg text-white flex items-center justify-between">
            <h3>Are your casino reviews independent?</h3>
            <span class="text-[#39FF14] font-[JetBrains_Mono] text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
              Yes. We earn affiliate commissions when users sign up through our links, but commission rates do not affect scores. We have declined partnerships with casinos that asked for guaranteed minimum ratings. Full transparency in our <a href="/affiliate-disclosure" class="text-[#39FF14] underline">affiliate disclosure</a>.
            </p>
          </div>
        </details>

        <details class="border-[3px] border-white bg-black group">
          <summary class="p-6 cursor-pointer font-[Space_Grotesk] font-bold text-lg text-white flex items-center justify-between">
            <h3>How often are reviews updated?</h3>
            <span class="text-[#39FF14] font-[JetBrains_Mono] text-xl group-open:rotate-45 transition-transform">+</span>
          </summary>
          <div class="px-6 pb-6">
            <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
              Reviews are updated when casino conditions change. Bonus terms get modified, withdrawal policies shift, licenses get suspended. Every review displays its last update date so you know how current the information is.
            </p>
          </div>
        </details>
      </div>
    </div>
  </section>
</Layout>
