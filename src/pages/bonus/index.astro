---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isBonus, sortByDate } from "../../lib/posts";

const allPosts = await getCollection("posts");
const bonuses = sortByDate(allPosts.filter(isBonus));

const siteUrl = "https://cryptobonuslist.com";
const canonical = `${siteUrl}/bonus`;

const schemas: Record<string, any>[] = [];

// CollectionPage + ItemList
schemas.push({
  "@type": "CollectionPage",
  name: "Crypto Casino Bonuses",
  description: "Every crypto casino bonus worth looking at. Match deposits, free spins, rakeback, and reload offers reviewed.",
  url: `${siteUrl}/bonus`,
  numberOfItems: bonuses.length,
  itemListElement: bonuses.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteUrl}/bonus/${b.data.slug}`,
    name: b.data.title,
  })),
});

// BreadcrumbList
schemas.push({
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Bonuses" },
  ],
});

const jsonLd = JSON.stringify({ "@context": "https://schema.org", "@graph": schemas });
---

<Layout title="Crypto Casino Bonuses | CryptoBonusList" description="Every crypto casino bonus worth looking at. Match deposits, free spins, rakeback, and reload offers reviewed." jsonld={jsonLd} canonical={canonical}>
  <section class="px-6 py-12">
    <div class="max-w-5xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        CRYPTO <span class="text-[#39FF14]">BONUSES</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-2xl">
        Every crypto casino bonus worth looking at. Match deposits, free spins, rakeback, and reload offers. Reviewed with the numbers that matter.
      </p>

      <!-- Filter Controls -->
      <div class="flex flex-wrap gap-4 mb-8 p-6 border-[3px] border-white bg-[#0A0A0A]" id="bonus-filters">
        <div>
          <label class="block text-[#D4D4D4] text-xs uppercase font-[JetBrains_Mono] mb-2" for="sort-select">Sort by</label>
          <select id="sort-select" class="bg-[#1a1a1a] text-white border-[2px] border-white px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer focus:outline-none focus:border-[#39FF14]" aria-label="Sort bonuses">
            <option value="date">Newest First</option>
            <option value="rating">Highest Rated</option>
            <option value="title">A-Z</option>
          </select>
        </div>
        <div>
          <label class="block text-[#D4D4D4] text-xs uppercase font-[JetBrains_Mono] mb-2">Bonus Type</label>
          <div class="flex flex-wrap gap-2" id="type-filters" role="group" aria-label="Filter by bonus type">
            <button data-filter="all" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-[#39FF14] text-black border-[#39FF14] font-bold focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="true">All</button>
            <button data-filter="Welcome Bonus" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Welcome</button>
            <button data-filter="No Deposit" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">No Deposit</button>
            <button data-filter="Free Spins" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Free Spins</button>
            <button data-filter="Reload" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Reload</button>
            <button data-filter="Cashback" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Cashback</button>
            <button data-filter="Rakeback" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Rakeback</button>
          </div>
        </div>
      </div>

      <!-- Filter status -->
      <p id="filter-status" class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs uppercase mb-6" aria-live="polite">
        Showing {bonuses.length} of {bonuses.length} bonuses
      </p>

      <!-- No results message (hidden by default) -->
      <div id="no-results" class="hidden border-[3px] border-white/30 bg-[#1a1a1a] p-10 text-center mb-6">
        <p class="text-[#D4D4D4] font-[Space_Grotesk] text-lg">No bonuses match your filters.</p>
        <button id="reset-filters" class="mt-4 bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-6 py-2 border-[2px] border-black uppercase text-sm cursor-pointer hover:translate-x-0.5 hover:translate-y-0.5 transition-transform">Reset Filters</button>
      </div>

      <div class="space-y-6" id="bonus-grid">
        {bonuses.map((bonus) => {
          const d = bonus.data;
          const casinoName = d.casino_name || d.casinoName;
          const claimUrl = d.claim_url
            ? (d.claim_url.includes("/") ? `/go/${d.slug}` : `/go/${d.claim_url}`)
            : d.website ? `/go/${d.slug}` : null;

          return (
            <div
              class="bonus-card border-[3px] border-white bg-black shadow-[6px_6px_0px_0px_#39FF14]"
              data-rating={d.ourRating ?? d.rating ?? 0}
              data-date={new Date(d.publishedAt).toISOString()}
              data-bonus-type={d.bonusType || ""}
              data-title={d.title}
            >
              {/* Top row: badges */}
              <div class="flex items-center gap-2 px-5 pt-5 pb-0 flex-wrap">
                {d.bonusType && (
                  <span class="bg-[#A855F7] text-white text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                    {d.bonusType}
                  </span>
                )}
                {d.verified && (
                  <span class="bg-[#39FF14] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                    VERIFIED
                  </span>
                )}
                {d.exclusive && (
                  <span class="bg-[#FAFF00] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                    EXCLUSIVE
                  </span>
                )}
                {d.ourRating && (
                  <span class="ml-auto flex items-center gap-1">
                    <span class="text-[#FAFF00] font-[Space_Grotesk] font-bold text-xl">{d.ourRating}</span>
                    <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">/10</span>
                  </span>
                )}
              </div>

              {/* Main content row */}
              <div class="flex flex-col md:flex-row gap-5 p-5">
                {/* Left: logo + casino name */}
                <div class="flex md:flex-col items-center md:items-start gap-3 md:w-36 shrink-0">
                  {d.logo ? (
                    <img src={d.logo} alt={casinoName || d.title} class="w-16 h-16 md:w-20 md:h-20 object-contain border-2 border-white bg-white" />
                  ) : d.image ? (
                    <div class="w-16 h-16 md:w-20 md:h-20 overflow-hidden border-2 border-white">
                      <img src={d.image} alt={d.title} class="w-full h-full object-cover" />
                    </div>
                  ) : (
                    <div class="w-16 h-16 md:w-20 md:h-20 border-2 border-[#39FF14] bg-[#1a1a1a] flex items-center justify-center">
                      <span class="text-[#39FF14] font-[Space_Grotesk] font-bold text-lg">{(casinoName || d.title).charAt(0)}</span>
                    </div>
                  )}
                  {casinoName && (
                    <span class="text-white font-[Space_Grotesk] font-bold text-sm">{casinoName}</span>
                  )}
                </div>

                {/* Middle: title, description, quick stats */}
                <div class="flex-1 min-w-0">
                  <a href={`/bonus/${d.slug}`} class="group">
                    <h2 class="font-[Space_Grotesk] text-xl md:text-2xl font-bold text-white mb-2 leading-snug group-hover:text-[#39FF14] transition-colors">{d.title}</h2>
                  </a>
                  <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-4 line-clamp-2">{d.description}</p>

                  {/* Stats row */}
                  <div class="flex flex-wrap gap-3 mb-4">
                    {d.bonus && (
                      <div class="border border-[#39FF14] px-3 py-1.5">
                        <div class="text-[#39FF14] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">BONUS</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.bonus}</div>
                      </div>
                    )}
                    {d.freeSpins && d.freeSpins !== "None" && d.freeSpins !== "0" && (
                      <div class="border border-[#39FF14] px-3 py-1.5">
                        <div class="text-[#39FF14] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">FREE SPINS</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.freeSpins}</div>
                      </div>
                    )}
                    {d.wageringRequirements && (
                      <div class="border border-white/40 px-3 py-1.5">
                        <div class="text-[#FAFF00] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">WAGERING</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.wageringRequirements}</div>
                      </div>
                    )}
                    {(d.minimumDeposit || d.minimum_deposit) && (
                      <div class="border border-white/40 px-3 py-1.5">
                        <div class="text-[#FAFF00] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">MIN DEPOSIT</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.minimumDeposit || d.minimum_deposit}</div>
                      </div>
                    )}
                  </div>

                  {/* Code badge */}
                  {d.code && d.code.trim() !== "" && (
                    <div class="inline-flex items-center gap-2 bg-[#39FF14]/10 border border-[#39FF14] px-3 py-1 mb-3">
                      <span class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold">CODE:</span>
                      <span class="text-white font-[Space_Grotesk] font-bold text-sm">{d.code}</span>
                    </div>
                  )}
                </div>

                {/* Right: CTA */}
                <div class="flex flex-col items-stretch md:items-end justify-center gap-3 md:w-48 shrink-0">
                  {claimUrl && (
                    <a
                      href={claimUrl}
                      rel="nofollow sponsored"
                      class="block bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-6 py-3 text-center border-[3px] border-black shadow-[4px_4px_0px_0px_#000] hover:translate-x-0.5 hover:translate-y-0.5 hover:shadow-[2px_2px_0px_0px_#000] transition-all uppercase tracking-wide"
                    >
                      CLAIM BONUS
                    </a>
                  )}
                  <a
                    href={`/bonus/${d.slug}`}
                    class="block text-center text-[#D4D4D4] font-[JetBrains_Mono] text-xs hover:text-[#39FF14] transition-colors underline underline-offset-4"
                  >
                    Read Full Review
                  </a>
                </div>
              </div>

              {/* Bottom: pros preview */}
              {d.pros && d.pros.length > 0 && (
                <div class="border-t border-white/10 px-5 py-3 flex flex-wrap gap-x-6 gap-y-1">
                  {d.pros.slice(0, 3).map((pro: string) => (
                    <span class="text-[#D4D4D4] text-xs font-[Public_Sans] flex items-center gap-1.5">
                      <span class="text-[#39FF14]">+</span>
                      <span class="line-clamp-1">{pro.trim()}</span>
                    </span>
                  ))}
                </div>
              )}
            </div>
          );
        })}
      </div>

      <div class="mt-12 pt-8 border-t-[3px] border-white">
        <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-4 text-[#FAFF00]">ABOUT CRYPTO BONUSES</h2>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-sm leading-relaxed mb-4">
          Crypto casino bonuses come in many forms. Welcome bonuses match your first deposit, sometimes up to 200% or more. Free spins give you risk-free rounds on slot games. Rakeback returns a percentage of your wagering losses. Reload bonuses reward repeat deposits with smaller percentage matches.
        </p>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-sm leading-relaxed mb-6">
          Always check the wagering requirements before claiming. A 100% match bonus with 60x wagering is worse than a 50% match with 20x wagering. We list the wagering multiplier for every bonus so you can compare the actual value, not just the headline number.
        </p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <a href="/casinos" class="block bg-[#0A0A0A] border-[3px] border-white p-5 shadow-[4px_4px_0px_0px_#39FF14] hover:shadow-[6px_6px_0px_0px_#39FF14] transition-shadow">
            <p class="font-[Space_Grotesk] font-bold text-white mb-1">Casino Reviews</p>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Full reviews of every casino behind these bonuses.</p>
          </a>
          <a href="/best-crypto-casinos" class="block bg-[#0A0A0A] border-[3px] border-white p-5 shadow-[4px_4px_0px_0px_#FAFF00] hover:shadow-[6px_6px_0px_0px_#FAFF00] transition-shadow">
            <p class="font-[Space_Grotesk] font-bold text-white mb-1">Best Crypto Casinos</p>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Our top-rated picks ranked by overall score.</p>
          </a>
          <a href="/no-wagering-crypto-casinos" class="block bg-[#0A0A0A] border-[3px] border-white p-5 shadow-[4px_4px_0px_0px_#A855F7] hover:shadow-[6px_6px_0px_0px_#A855F7] transition-shadow">
            <p class="font-[Space_Grotesk] font-bold text-white mb-1">No Wagering Casinos</p>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Bonuses you can actually withdraw without jumping through hoops.</p>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.getElementById('bonus-grid');
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    const typeButtons = document.querySelectorAll('#type-filters button');
    const statusEl = document.getElementById('filter-status');
    const noResults = document.getElementById('no-results');
    const resetBtn = document.getElementById('reset-filters');

    if (!grid || !sortSelect || !statusEl || !noResults) return;

    let activeType = 'all';

    const ACTIVE_CLASSES = ['bg-[#39FF14]', 'text-black', 'border-[#39FF14]', 'font-bold'];
    const INACTIVE_CLASSES = ['bg-transparent', 'text-[#D4D4D4]', 'border-white', 'hover:border-[#39FF14]', 'hover:text-[#39FF14]'];

    function setActiveButton(btn: Element) {
      typeButtons.forEach(b => {
        ACTIVE_CLASSES.forEach(c => b.classList.remove(c));
        INACTIVE_CLASSES.forEach(c => b.classList.add(c));
        b.setAttribute('aria-pressed', 'false');
      });
      INACTIVE_CLASSES.forEach(c => btn.classList.remove(c));
      ACTIVE_CLASSES.forEach(c => btn.classList.add(c));
      btn.setAttribute('aria-pressed', 'true');
    }

    function getCards(): HTMLElement[] {
      return Array.from(grid!.querySelectorAll('.bonus-card'));
    }

    function applyFilters() {
      const cards = getCards();
      let visibleCount = 0;

      cards.forEach(card => {
        const bonusType = card.dataset.bonusType || '';
        const matchesType = activeType === 'all' || bonusType.toLowerCase() === activeType.toLowerCase();

        if (matchesType) {
          card.style.display = '';
          visibleCount++;
        } else {
          card.style.display = 'none';
        }
      });

      statusEl!.textContent = `Showing ${visibleCount} of ${cards.length} bonuses`;

      if (visibleCount === 0) {
        noResults!.classList.remove('hidden');
      } else {
        noResults!.classList.add('hidden');
      }
    }

    function applySorting() {
      const cards = getCards();
      const sortBy = sortSelect.value;

      cards.sort((a, b) => {
        if (sortBy === 'date') {
          return new Date(b.dataset.date || '').getTime() - new Date(a.dataset.date || '').getTime();
        }
        if (sortBy === 'rating') {
          return (parseFloat(b.dataset.rating || '0')) - (parseFloat(a.dataset.rating || '0'));
        }
        if (sortBy === 'title') {
          return (a.dataset.title || '').localeCompare(b.dataset.title || '');
        }
        return 0;
      });

      // Re-append in sorted order
      cards.forEach(card => grid!.appendChild(card));
    }

    // Event: sort change
    sortSelect.addEventListener('change', () => {
      applySorting();
      applyFilters();
    });

    // Event: type filter buttons
    typeButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        activeType = (btn as HTMLElement).dataset.filter || 'all';
        setActiveButton(btn);
        applyFilters();
      });
    });

    // Event: reset filters
    resetBtn?.addEventListener('click', () => {
      activeType = 'all';
      sortSelect.value = 'date';
      const allBtn = document.querySelector('#type-filters button[data-filter="all"]');
      if (allBtn) setActiveButton(allBtn);
      applySorting();
      applyFilters();
    });
  });
</script>
