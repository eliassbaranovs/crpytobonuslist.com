---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isBonus, sortByDate } from "../../lib/posts";
import { getRatingBg } from "../../lib/casino-filters";

const allPosts = await getCollection("posts");
const bonuses = sortByDate(allPosts.filter(isBonus));
const bonusesByRating = [...bonuses].sort((a, b) => ((b.data.ourRating ?? b.data.rating ?? 0) as number) - ((a.data.ourRating ?? a.data.rating ?? 0) as number));

const latestDate = bonuses.reduce((latest, item) => {
  const d = new Date(item.data.updatedAt || item.data.publishedAt || 0);
  return d > latest ? d : latest;
}, new Date(0));

const lastUpdatedStr = latestDate.toLocaleDateString("en-US", { month: "long", year: "numeric" });

const siteUrl = "https://cryptobonuslist.com";
const canonical = `${siteUrl}/bonus`;

const schemas: Record<string, any>[] = [];

// CollectionPage + ItemList
schemas.push({
  "@type": "CollectionPage",
  name: "Crypto Casino Bonuses",
  description: "Every crypto casino bonus worth looking at. Match deposits, free spins, rakeback, and reload offers reviewed.",
  url: `${siteUrl}/bonus`,
  dateModified: latestDate.toISOString(),
  numberOfItems: bonuses.length,
  author: {
    "@type": "Person",
    name: "Thomas Mullberg",
    url: "https://cryptobonuslist.com/team/thomas-mullberg",
    jobTitle: "Senior Crypto & iGaming Analyst",
  },
  publisher: {
    "@type": "Organization",
    name: "CryptoBonusList",
    url: "https://cryptobonuslist.com",
    logo: {
      "@type": "ImageObject",
      url: "https://cryptobonuslist.com/cryptobonuslist.png",
    },
  },
  itemListElement: bonuses.map((b, i) => ({
    "@type": "ListItem",
    position: i + 1,
    url: `${siteUrl}/bonus/${b.data.slug}`,
    name: b.data.title,
  })),
});

// BreadcrumbList
schemas.push({
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
    { "@type": "ListItem", position: 2, name: "Bonuses" },
  ],
});

// FAQPage
const faqItems = [
  {
    q: "What is a crypto casino welcome bonus?",
    a: "A crypto casino welcome bonus is an offer given to new players when they sign up and make their first deposit using cryptocurrency. It typically matches a percentage of your deposit, giving you extra funds to play with. Match rates range from 100% to 300%, with wagering requirements attached.",
  },
  {
    q: "How do wagering requirements work?",
    a: "Wagering requirements tell you how many times you must bet the bonus amount before you can withdraw winnings. A 30x requirement on a $100 bonus means you need to place $3,000 in total bets. Check whether the requirement applies to the bonus only or to the bonus plus your deposit.",
  },
  {
    q: "Can you withdraw a casino bonus immediately?",
    a: "No. Almost every casino bonus comes with wagering requirements that must be cleared first. The rare exceptions are no-wagering bonuses, which let you withdraw winnings right away. These are uncommon and usually come with lower bonus amounts.",
  },
  {
    q: "What is the best crypto casino bonus right now?",
    a: "The best bonus depends on your play style. For casual players, a low-wagering welcome bonus offers the most realistic value. For high-volume players, rakeback deals provide consistent returns. Check our rated list above for current top picks sorted by real value.",
  },
  {
    q: "Are no-deposit bonuses real?",
    a: "Yes, no-deposit bonuses exist. You sign up and receive a small amount of free funds or free spins without depositing. The catch is tight restrictions: high wagering (40x to 60x), low withdrawal caps ($50 to $200), and limited game selection. Treat them as a way to test a casino, not as free money.",
  },
  {
    q: "What does 30x wagering mean?",
    a: "It means you must bet 30 times the bonus amount before withdrawing. On a $100 bonus, that is $3,000 in total wagers. At a 3% house edge, you can expect to lose about $90 of that $100 bonus while clearing it. Anything under 35x is considered fair by industry standards.",
  },
  {
    q: "Do bonus codes expire?",
    a: "Yes. Most bonus codes have expiration dates, and the bonus itself usually has a time limit for clearing wagering requirements (typically 7 to 30 days). Always check the terms for both the code validity period and the wagering deadline before claiming.",
  },
  {
    q: "What is rakeback at a crypto casino?",
    a: "Rakeback returns a percentage of every bet you place, regardless of whether you win or lose. Typical rates range from 0.1% to 3% for regular players and up to 10% to 30% for VIPs. It is considered the most mathematically honest bonus type because it rewards play volume rather than luck.",
  },
];

schemas.push({
  "@type": "FAQPage",
  mainEntity: faqItems.map((item) => ({
    "@type": "Question",
    name: item.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: item.a,
    },
  })),
});

const jsonLd = JSON.stringify({ "@context": "https://schema.org", "@graph": schemas });
---

<Layout title="Best Crypto Casino Bonuses 2026 | Tested Offers | CryptoBonusList" description="Compare tested crypto casino bonuses for 2026. Welcome matches, free spins, rakeback deals. Wagering requirements analyzed with real math. Updated monthly." jsonld={jsonLd} canonical={canonical}>
  <section class="px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        CRYPTO CASINO <span class="text-[#39FF14]">BONUSES</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-6 max-w-2xl">
        Every crypto casino bonus worth looking at. Match deposits, free spins, rakeback, and reload offers. Reviewed with the numbers that matter.
      </p>

      <!-- Affiliate Disclosure -->
      <div class="border-[2px] border-white/20 bg-[#1a1a1a] px-5 py-3 mb-6">
        <p class="text-[#D4D4D4] font-[Public_Sans] text-xs leading-relaxed">
          Some links on this page are affiliate links. We earn a commission if you sign up through them. This does not affect our ratings or rankings. All bonuses are independently reviewed.
          <a href="/affiliate-disclosure" class="text-[#39FF14] underline underline-offset-2 hover:text-white transition-colors">Read our full affiliate disclosure</a>.
        </p>
      </div>

      <!-- Author Attribution + Freshness -->
      <div class="flex flex-wrap items-center gap-x-6 gap-y-2 mb-10 text-xs font-[JetBrains_Mono] uppercase tracking-wide">
        <span class="text-[#D4D4D4]">
          Reviewed by <a href="/team/thomas-mullberg" class="text-[#FAFF00] underline underline-offset-2 hover:text-white transition-colors">Thomas Mullberg</a>, Senior Crypto & iGaming Analyst
        </span>
        <span class="text-white/30 hidden sm:inline">|</span>
        <span class="text-[#D4D4D4]">Last updated: {lastUpdatedStr}</span>
        <span class="text-white/30 hidden sm:inline">|</span>
        <span class="text-[#39FF14]">{bonuses.length} bonuses reviewed</span>
      </div>


      <!-- Top 3 Quick Picks -->
      <div class="mb-10">
        <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-black mb-6">
          TOP 3 <span class="text-[#39FF14]">BONUS PICKS</span>
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {bonusesByRating.slice(0, 3).map((b, i) => {
            const d = b.data;
            const casinoName = d.casino_name || d.casinoName || d.title;
            const rating = (d.ourRating ?? d.rating ?? 0) as number;
            const ratingBg = getRatingBg(rating);
            const bonusText = d.bonus || d.title;
            const wagering = d.wageringRequirements || "N/A";
            const logo = d.logo;
            const shadowColors = ["#39FF14", "#FAFF00", "#A855F7"];
            const rankColors = ["bg-[#39FF14] text-black", "bg-[#FAFF00] text-black", "bg-[#A855F7] text-white"];
            const shadowColor = shadowColors[i];
            const rankColor = rankColors[i];
            const claimUrl = d.claim_url
              ? (d.claim_url.includes("/") ? `/go/${d.slug}` : `/go/${d.claim_url}`)
              : d.website ? `/go/${d.slug}` : null;

            return (
              <div class={`bg-[#0A0A0A] border-[3px] border-white p-6`} style={`box-shadow: 6px 6px 0px 0px ${shadowColor}`}>
                <div class="flex items-center gap-3 mb-4">
                  <span class={`${rankColor} font-[JetBrains_Mono] font-bold text-lg w-9 h-9 flex items-center justify-center shrink-0`}>
                    {i + 1}
                  </span>
                  {logo ? (
                    <img
                      src={logo}
                      alt={`${casinoName} logo`}
                      width="48"
                      height="48"
                      class="w-12 h-12 object-contain border border-white/20 shrink-0 bg-white"
                      loading="lazy"
                    />
                  ) : d.image ? (
                    <div class="w-12 h-12 overflow-hidden border border-white/20 shrink-0">
                      <img src={d.image} alt={casinoName} class="w-full h-full object-cover" loading="lazy" />
                    </div>
                  ) : null}
                  <div class="min-w-0">
                    <h3 class="font-[Space_Grotesk] font-bold text-white text-lg truncate">{casinoName}</h3>
                  </div>
                </div>
                <p class="text-[#FAFF00] font-[JetBrains_Mono] text-sm font-bold mb-1">{bonusText}</p>
                <div class="flex items-center gap-3 mb-4">
                  <span class={`${ratingBg} font-[JetBrains_Mono] text-xs font-bold px-2 py-0.5`}>
                    {typeof rating === 'number' ? rating.toFixed(1) : rating}/10
                  </span>
                  <span class="font-[JetBrains_Mono] text-xs text-[#D4D4D4]">Wagering: {wagering}</span>
                </div>
                <div class="flex gap-3">
                  {claimUrl && (
                    <a
                      href={claimUrl}
                      rel="nofollow sponsored"
                      class="flex-1 text-center font-[Space_Grotesk] font-bold text-xs py-2.5 bg-[#39FF14] text-black border-2 border-[#39FF14] hover:bg-[#2ECC0F] transition-colors uppercase"
                    >
                      Claim Bonus
                    </a>
                  )}
                  <a
                    href={`/bonus/${d.slug}`}
                    class="flex-1 text-center font-[Space_Grotesk] font-bold text-xs py-2.5 border-2 border-white text-white hover:bg-white hover:text-black transition-colors uppercase"
                  >
                    Read Review
                  </a>
                </div>
              </div>
            );
          })}
        </div>
      </div>

      <!-- Bonus Comparison Table -->
      <div class="mb-10">
        <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-black mb-6">
          BONUS <span class="text-[#FAFF00]">COMPARISON</span>
        </h2>
        <div class="overflow-x-auto border-[3px] border-white">
          <table class="w-full min-w-[700px] text-left" role="table" aria-label="Bonus comparison table">
            <thead>
              <tr class="bg-[#1a1a1a]">
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Casino / Bonus</th>
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Bonus Amount</th>
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Type</th>
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Wagering</th>
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Min Deposit</th>
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3">Rating</th>
                <th class="font-[JetBrains_Mono] text-[#FAFF00] text-xs uppercase tracking-wider px-4 py-3 text-right">Link</th>
              </tr>
            </thead>
            <tbody>
              {bonusesByRating.map((b) => {
                const d = b.data;
                const casinoName = d.casino_name || d.casinoName || d.title;
                const rating = (d.ourRating ?? d.rating ?? 0) as number;
                const ratingBg = getRatingBg(rating);
                const bonusText = d.bonus || "N/A";
                const bonusType = d.bonusType || "N/A";
                const wagering = d.wageringRequirements || "N/A";
                const minDeposit = d.minimumDeposit || d.minimum_deposit || "N/A";
                const logo = d.logo;

                return (
                  <tr class="border-b border-white/10 hover:bg-white/5 transition-colors">
                    <td class="px-4 py-3">
                      <div class="flex items-center gap-2">
                        {logo && (
                          <img src={logo} alt="" width="28" height="28" class="w-7 h-7 object-contain border border-white/20 shrink-0 bg-white" loading="lazy" />
                        )}
                        <span class="font-[Space_Grotesk] font-bold text-white text-sm truncate max-w-[160px]">{casinoName}</span>
                      </div>
                    </td>
                    <td class="px-4 py-3 font-[JetBrains_Mono] text-xs text-white max-w-[150px] truncate">{bonusText}</td>
                    <td class="px-4 py-3">
                      {bonusType !== "N/A" ? (
                        <span class="bg-[#A855F7]/20 text-[#A855F7] font-[JetBrains_Mono] text-xs px-2 py-0.5">{bonusType}</span>
                      ) : (
                        <span class="font-[JetBrains_Mono] text-xs text-[#D4D4D4]">N/A</span>
                      )}
                    </td>
                    <td class="px-4 py-3 font-[JetBrains_Mono] text-xs text-white">{wagering}</td>
                    <td class="px-4 py-3 font-[JetBrains_Mono] text-xs text-white">{minDeposit}</td>
                    <td class="px-4 py-3">
                      <span class={`${ratingBg} font-[JetBrains_Mono] text-xs font-bold px-2 py-0.5`}>{typeof rating === 'number' ? rating.toFixed(1) : rating}</span>
                    </td>
                    <td class="px-4 py-3 text-right">
                      <a href={`/bonus/${d.slug}`} class="font-[JetBrains_Mono] text-[#39FF14] text-xs underline underline-offset-2 hover:text-white transition-colors">Details</a>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>

      <!-- Filter Controls -->
      <div class="flex flex-wrap gap-4 mb-8 p-6 border-[3px] border-white bg-[#0A0A0A]" id="bonus-filters">
        <div>
          <label class="block text-[#D4D4D4] text-xs uppercase font-[JetBrains_Mono] mb-2" for="sort-select">Sort by</label>
          <select id="sort-select" class="bg-[#1a1a1a] text-white border-[2px] border-white px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer focus:outline-none focus:border-[#39FF14]" aria-label="Sort bonuses">
            <option value="date">Newest First</option>
            <option value="rating">Highest Rated</option>
            <option value="title">A-Z</option>
          </select>
        </div>
        <div>
          <label class="block text-[#D4D4D4] text-xs uppercase font-[JetBrains_Mono] mb-2">Bonus Type</label>
          <div class="flex flex-wrap gap-2" id="type-filters" role="group" aria-label="Filter by bonus type">
            <button data-filter="all" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-[#39FF14] text-black border-[#39FF14] font-bold focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="true">All</button>
            <button data-filter="Welcome Bonus" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Welcome</button>
            <button data-filter="No Deposit" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">No Deposit</button>
            <button data-filter="Free Spins" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Free Spins</button>
            <button data-filter="Reload" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Reload</button>
            <button data-filter="Cashback" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Cashback</button>
            <button data-filter="Rakeback" class="border-[2px] px-4 py-2 font-[JetBrains_Mono] text-sm uppercase cursor-pointer transition-colors bg-transparent text-[#D4D4D4] border-white hover:border-[#39FF14] hover:text-[#39FF14] focus:outline-2 focus:outline-[#39FF14] focus:outline-offset-2" aria-pressed="false">Rakeback</button>
          </div>
        </div>
      </div>

      <!-- Filter status -->
      <p id="filter-status" class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs uppercase mb-6" aria-live="polite">
        Showing {bonuses.length} of {bonuses.length} bonuses
      </p>

      <!-- No results message (hidden by default) -->
      <div id="no-results" class="hidden border-[3px] border-white/30 bg-[#1a1a1a] p-10 text-center mb-6">
        <p class="text-[#D4D4D4] font-[Space_Grotesk] text-lg">No bonuses match your filters.</p>
        <button id="reset-filters" class="mt-4 bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-6 py-2 border-[2px] border-black uppercase text-sm cursor-pointer hover:translate-x-0.5 hover:translate-y-0.5 transition-transform">Reset Filters</button>
      </div>

      <div class="space-y-6" id="bonus-grid">
        {bonuses.map((bonus) => {
          const d = bonus.data;
          const casinoName = d.casino_name || d.casinoName;
          const claimUrl = d.claim_url
            ? (d.claim_url.includes("/") ? `/go/${d.slug}` : `/go/${d.claim_url}`)
            : d.website ? `/go/${d.slug}` : null;

          return (
            <div
              class="bonus-card border-[3px] border-white bg-black shadow-[6px_6px_0px_0px_#39FF14]"
              data-rating={d.ourRating ?? d.rating ?? 0}
              data-date={new Date(d.publishedAt).toISOString()}
              data-bonus-type={d.bonusType || ""}
              data-title={d.title}
            >
              {/* Top row: badges */}
              <div class="flex items-center gap-2 px-5 pt-5 pb-0 flex-wrap">
                {d.bonusType && (
                  <span class="bg-[#A855F7] text-white text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                    {d.bonusType}
                  </span>
                )}
                {d.verified && (
                  <span class="bg-[#39FF14] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                    VERIFIED
                  </span>
                )}
                {d.exclusive && (
                  <span class="bg-[#FAFF00] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                    EXCLUSIVE
                  </span>
                )}
                {d.ourRating && (
                  <span class="ml-auto flex items-center gap-1">
                    <span class="text-[#FAFF00] font-[Space_Grotesk] font-bold text-xl">{d.ourRating}</span>
                    <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">/10</span>
                  </span>
                )}
              </div>

              {/* Main content row */}
              <div class="flex flex-col md:flex-row gap-5 p-5">
                {/* Left: logo + casino name */}
                <div class="flex md:flex-col items-center md:items-start gap-3 md:w-36 shrink-0">
                  {d.logo ? (
                    <img src={d.logo} alt={casinoName || d.title} class="w-16 h-16 md:w-20 md:h-20 object-contain border-2 border-white bg-white" />
                  ) : d.image ? (
                    <div class="w-16 h-16 md:w-20 md:h-20 overflow-hidden border-2 border-white">
                      <img src={d.image} alt={d.title} class="w-full h-full object-cover" />
                    </div>
                  ) : (
                    <div class="w-16 h-16 md:w-20 md:h-20 border-2 border-[#39FF14] bg-[#1a1a1a] flex items-center justify-center">
                      <span class="text-[#39FF14] font-[Space_Grotesk] font-bold text-lg">{(casinoName || d.title).charAt(0)}</span>
                    </div>
                  )}
                  {casinoName && (
                    <span class="text-white font-[Space_Grotesk] font-bold text-sm">{casinoName}</span>
                  )}
                </div>

                {/* Middle: title, description, quick stats */}
                <div class="flex-1 min-w-0">
                  <a href={`/bonus/${d.slug}`} class="group">
                    <h2 class="font-[Space_Grotesk] text-xl md:text-2xl font-bold text-white mb-2 leading-snug group-hover:text-[#39FF14] transition-colors">{d.title}</h2>
                  </a>
                  <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-4 line-clamp-2">{d.description}</p>

                  {/* Stats row */}
                  <div class="flex flex-wrap gap-3 mb-4">
                    {d.bonus && (
                      <div class="border border-[#39FF14] px-3 py-1.5">
                        <div class="text-[#39FF14] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">BONUS</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.bonus}</div>
                      </div>
                    )}
                    {d.freeSpins && d.freeSpins !== "None" && d.freeSpins !== "0" && (
                      <div class="border border-[#39FF14] px-3 py-1.5">
                        <div class="text-[#39FF14] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">FREE SPINS</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.freeSpins}</div>
                      </div>
                    )}
                    {d.wageringRequirements && (
                      <div class="border border-white/40 px-3 py-1.5">
                        <div class="text-[#FAFF00] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">WAGERING</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.wageringRequirements}</div>
                      </div>
                    )}
                    {(d.minimumDeposit || d.minimum_deposit) && (
                      <div class="border border-white/40 px-3 py-1.5">
                        <div class="text-[#FAFF00] text-[10px] font-[JetBrains_Mono] font-bold leading-none mb-0.5">MIN DEPOSIT</div>
                        <div class="text-white font-[JetBrains_Mono] font-bold text-sm leading-tight">{d.minimumDeposit || d.minimum_deposit}</div>
                      </div>
                    )}
                  </div>

                  {/* Code badge */}
                  {d.code && d.code.trim() !== "" && (
                    <div class="inline-flex items-center gap-2 bg-[#39FF14]/10 border border-[#39FF14] px-3 py-1 mb-3">
                      <span class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold">CODE:</span>
                      <span class="text-white font-[Space_Grotesk] font-bold text-sm">{d.code}</span>
                    </div>
                  )}
                </div>

                {/* Right: CTA */}
                <div class="flex flex-col items-stretch md:items-end justify-center gap-3 md:w-48 shrink-0">
                  {claimUrl && (
                    <a
                      href={claimUrl}
                      rel="nofollow sponsored"
