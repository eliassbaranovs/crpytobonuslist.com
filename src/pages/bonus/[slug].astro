---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isBonus, getPostUrl, sortByDate } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.filter(isBonus).map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const d = post.data;

const lastUpdated = d.updatedAt || d.publishedAt;
const lastUpdatedFormatted = lastUpdated
  ? new Date(lastUpdated).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : null;

// Author data
const authors = await getCollection("authors");
const authorData = authors.find((a) => a.data.slug === d.authorSlug);

const allPosts = await getCollection("posts");
const currentTags = d.tags || [];
const currentType = d.bonusType;

const relatedBonuses = allPosts
  .filter(isBonus)
  .filter((b) => b.data.slug !== d.slug)
  .filter((b) => {
    if (currentTags.length > 0 && b.data.tags) {
      if (b.data.tags.some((tag: string) => currentTags.includes(tag))) return true;
    }
    if (currentType && b.data.bonusType === currentType) return true;
    return false;
  })
  .slice(0, 3);

const displayRelated =
  relatedBonuses.length > 0
    ? relatedBonuses
    : allPosts.filter(isBonus).filter((b) => b.data.slug !== d.slug).slice(0, 3);

const claimUrl = d.claim_url
  ? (d.claim_url.includes("/") ? `/go/${d.slug}` : `/go/${d.claim_url}`)
  : d.website
    ? `/go/${d.slug}`
    : null;

const robots = d.robots || (d.noIndex ? "noindex, nofollow" : "index, follow");

// Canonical: always derive from actual route
const canonical = `https://cryptobonuslist.com/bonus/${d.slug}`;

// Build JSON-LD from frontmatter
const siteUrl = "https://cryptobonuslist.com";
const pageUrl = `${siteUrl}/bonus/${d.slug}`;

const articleSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: d.title,
  description: d.description,
  url: pageUrl,
  datePublished: d.publishedAt ? new Date(d.publishedAt).toISOString() : undefined,
  dateModified: lastUpdated ? new Date(lastUpdated).toISOString() : undefined,
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  publisher: { "@type": "Organization", name: "cryptobonuslist.com", url: siteUrl },
};
if (d.author) {
  articleSchema.author = { "@type": "Person", name: d.author, ...(d.authorSlug ? { url: `${siteUrl}/team/${d.authorSlug}` } : {}) };
}
if (d.image) {
  articleSchema.image = { "@type": "ImageObject", url: d.image.startsWith("http") ? d.image : `${siteUrl}${d.image}`, width: d.imageWidth || 1792, height: d.imageHeight || 1024, ...(d.imageAlt ? { caption: d.imageAlt } : {}) };
}
if (d.tags?.length) articleSchema.keywords = d.tags.join(", ");

const schemas: Record<string, any>[] = [articleSchema];

// Product + AggregateRating + Offer
if (d.ourRating || d.playerRating) {
  const prodSchema: Record<string, any> = {
    "@context": "https://schema.org",
    "@type": "Product",
    name: d.casino_name || d.casinoName || d.title,
    description: d.description,
  };
  if (d.playerRating && d.playerRatingCount) {
    prodSchema.aggregateRating = { "@type": "AggregateRating", ratingValue: String(d.playerRating), bestRating: "10", worstRating: "0", ratingCount: String(d.playerRatingCount) };
  } else if (d.ourRating) {
    prodSchema.aggregateRating = { "@type": "AggregateRating", ratingValue: String(d.ourRating), bestRating: "10", worstRating: "0", ratingCount: "1" };
  }
  if (d.bonus) {
    prodSchema.offers = { "@type": "Offer", name: d.bonus, description: d.description, ...(d.expires_at ? { validThrough: new Date(d.expires_at).toISOString() } : {}), ...(d.code ? { discountCode: d.code } : {}), availability: "https://schema.org/InStock" };
  }
  schemas.push(prodSchema);
}

// FAQ schema from faqs field
if (d.faqs && d.faqs.length > 0) {
  schemas.push({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: d.faqs.map((faq: { question: string; answer: string }) => ({
      "@type": "Question", name: faq.question, acceptedAnswer: { "@type": "Answer", text: faq.answer },
    })),
  });
}

const jsonld = JSON.stringify(schemas);

// Casino info rows - only populated ones render
const casinoName = d.casino_name || d.casinoName;
const infoRows: { label: string; value: string }[] = [];
if (d.established) infoRows.push({ label: "Established", value: d.established });
if (d.licences) infoRows.push({ label: "Licences", value: d.licences });
if (d.currencies) infoRows.push({ label: "Currencies", value: d.currencies });
if (d.depositMethods || d.deposit_methods) infoRows.push({ label: "Deposit Methods", value: (d.depositMethods || d.deposit_methods)! });
if (d.withdrawalMethods || d.withdrawal_methods) infoRows.push({ label: "Withdrawal Methods", value: (d.withdrawalMethods || d.withdrawal_methods)! });
if (d.withdrawalTimes || d.withdrawal_time) infoRows.push({ label: "Withdrawal Time", value: (d.withdrawalTimes || d.withdrawal_time)! });
if (d.withdrawalFees) infoRows.push({ label: "Withdrawal Fees", value: d.withdrawalFees });
if (d.minimumDeposit || d.minimum_deposit) infoRows.push({ label: "Min Deposit", value: (d.minimumDeposit || d.minimum_deposit)! });
if (d.minimumWithdrawalAmount) infoRows.push({ label: "Min Withdrawal", value: d.minimumWithdrawalAmount });
if (d.gameProviders || d.game_providers) infoRows.push({ label: "Game Providers", value: (d.gameProviders || d.game_providers)! });
if (d.liveChat || d.live_chat) infoRows.push({ label: "Live Chat", value: (d.liveChat || d.live_chat)! });
if (d.emailSupport || d.email_support) infoRows.push({ label: "Email Support", value: (d.emailSupport || d.email_support)! });
if (d.vipLoyaltyProgram) infoRows.push({ label: "VIP Program", value: d.vipLoyaltyProgram });

const expiresFormatted = d.expires_at
  ? new Date(d.expires_at).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })
  : null;

const reviewUrl = d.casinoReviewUrl || null;

const wordCount = d.wordCount || (post.body ? post.body.split(/\s+/).filter(Boolean).length : 0);
const readingTime = d.readingTime || (Math.ceil(wordCount / 200) || 1) + " min read";
---

<Layout
  title={d.seoTitle}
  description={d.description}
  jsonld={jsonld}
  ogType="article"
  ogImage={d.image || "/favicon.svg"}
  canonical={canonical}
  robots={robots}
>
  {/* Reading progress bar */}
  <div id="progress-bar" class="fixed top-0 left-0 h-[3px] bg-[#39FF14] z-[100] transition-all duration-100" style="width: 0%"></div>

  <article class="px-6 py-10 pb-24 md:pb-12">
    <div class="max-w-4xl mx-auto">
      {/* Breadcrumbs */}
      <nav aria-label="Breadcrumb" class="mb-6 text-sm font-[JetBrains_Mono]">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="text-[#D4D4D4] hover:text-[#39FF14]">Home</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li><a href="/bonus" class="text-[#D4D4D4] hover:text-[#39FF14]">Bonuses</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li class="text-white truncate max-w-[300px]" aria-current="page">{d.title}</li>
        </ol>
      </nav>

      {/* Hero image */}
      {d.image && (
        <div class="relative">
          <img
            src={d.image}
            alt={d.imageAlt}
            width={d.imageWidth}
            height={d.imageHeight}
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto border-[3px] border-white"
          />
          {/* Badges overlay */}
          <div class="absolute top-0 left-0 flex gap-2 p-3">
            {d.bonusType && (
              <span class="bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                {d.bonusType}
              </span>
            )}
            {d.verified && (
              <span class="bg-[#39FF14] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                VERIFIED
              </span>
            )}
            {d.exclusive && (
              <span class="bg-[#FAFF00] text-black text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">
                EXCLUSIVE
              </span>
            )}
          </div>
          {/* Rating overlay */}
          {d.ourRating && (
            <div class="absolute top-0 right-0 p-3">
              <div class="bg-black/80 border-2 border-[#FAFF00] px-3 py-2 flex items-center gap-1.5">
                <span class="text-[#FAFF00] font-[Space_Grotesk] font-bold text-2xl">{d.ourRating}</span>
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">/10</span>
              </div>
            </div>
          )}
        </div>
      )}

      {/* Main bonus banner — connected to image */}
      <div class={`border-[3px] border-white bg-black p-6 md:p-8 mb-8 shadow-[6px_6px_0px_0px_#39FF14] ${d.image ? '-mt-[3px]' : ''}`}>
        {/* Meta row */}
        <div class="flex flex-wrap items-center gap-3 mb-4">
          {lastUpdatedFormatted && (
            <div class="inline-flex items-center gap-2 bg-[#1a1a1a] border border-[#333] px-3 py-1.5">
              <span class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold">LAST TESTED:</span>
              <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">{lastUpdatedFormatted}</span>
            </div>
          )}
          {expiresFormatted && (
            <div class="inline-flex items-center gap-2 bg-[#1a1a1a] border border-[#FAFF00] px-3 py-1.5">
              <span class="text-[#FAFF00] font-[JetBrains_Mono] text-xs font-bold">VALID UNTIL:</span>
              <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">{expiresFormatted}</span>
            </div>
          )}
          <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">{readingTime}</span>
        </div>

        {/* Title row with logo */}
        <div class="flex items-start gap-4 mb-4">
          {d.logo && (
            <img src={d.logo} alt={casinoName || d.title} class="w-14 h-14 md:w-16 md:h-16 object-contain border-2 border-white bg-white shrink-0 mt-1" />
          )}
          <div class="flex-1">
            <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight">
              {d.title}
            </h1>
          </div>
        </div>

        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-6">{d.description}</p>

        {/* Stats grid */}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-3 mb-6">
          {d.bonus && (
            <div class="border-2 border-[#39FF14] p-3">
              <div class="text-[#39FF14] text-[10px] font-[JetBrains_Mono] font-bold mb-1">BONUS AMOUNT</div>
              <div class="text-white font-[JetBrains_Mono] font-bold text-sm">{d.bonus}</div>
            </div>
          )}
          {d.freeSpins && d.freeSpins !== "None" && d.freeSpins !== "0" && (
            <div class="border-2 border-[#39FF14] p-3">
              <div class="text-[#39FF14] text-[10px] font-[JetBrains_Mono] font-bold mb-1">FREE SPINS</div>
              <div class="text-white font-[JetBrains_Mono] font-bold text-sm">{d.freeSpins}</div>
            </div>
          )}
          {d.wageringRequirements && (
            <div class="border-2 border-white p-3">
              <div class="text-[#FAFF00] text-[10px] font-[JetBrains_Mono] font-bold mb-1">WAGERING</div>
              <div class="text-white font-[JetBrains_Mono] font-bold text-sm">{d.wageringRequirements}</div>
            </div>
          )}
          {(d.minimum_deposit || d.minimumDeposit) && (
            <div class="border-2 border-white p-3">
              <div class="text-[#FAFF00] text-[10px] font-[JetBrains_Mono] font-bold mb-1">MIN DEPOSIT</div>
              <div class="text-white font-[JetBrains_Mono] font-bold text-sm">{d.minimum_deposit || d.minimumDeposit}</div>
            </div>
          )}
        </div>

        {/* Bonus code */}
        {d.code && d.code.trim() !== "" && (
          <div class="mb-6 p-4 bg-[#39FF14] border-[3px] border-black flex items-center justify-between">
            <div>
              <span class="text-black font-[JetBrains_Mono] text-sm font-bold">BONUS CODE:</span>
              <span class="text-black font-[Space_Grotesk] text-xl font-bold ml-2">{d.code}</span>
            </div>
          </div>
        )}

        {/* CTA */}
        {claimUrl && (
          <div class="mb-6">
            <a
              href={claimUrl}
              class="block w-full bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-8 py-5 text-center text-xl md:text-2xl border-[3px] border-black shadow-[8px_8px_0px_0px_#000000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[4px_4px_0px_0px_#000000] transition-all uppercase tracking-wide"
            >
              CLAIM BONUS NOW
            </a>
          </div>
        )}

        {/* Casino + rating footer */}
        <div class="flex items-center justify-between flex-wrap gap-4 pt-4 border-t-2 border-[#333]">
          <div class="flex items-center gap-4">
            {casinoName && (
              <div class="text-white font-[JetBrains_Mono] text-sm">
                <span class="text-[#FAFF00]">Casino:</span>{" "}
                {reviewUrl ? (
                  <a href={reviewUrl} class="text-[#39FF14] hover:underline">{casinoName}</a>
                ) : (
                  <span>{casinoName}</span>
                )}
              </div>
            )}
          </div>
          <div class="flex items-center gap-4 flex-wrap">
            {d.ourRating && !d.image && (
              <div class="flex items-center gap-2">
                <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">OUR RATING:</span>
                <span class="text-white font-[Space_Grotesk] font-bold text-2xl">{d.ourRating}</span>
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">/10</span>
              </div>
            )}
            {d.playerRating && Number(d.playerRating) > 0 && (
              <div class="flex items-center gap-2">
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">PLAYERS:</span>
                <span class="text-white font-[Space_Grotesk] font-bold text-lg">{d.playerRating}</span>
                <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">/10</span>
                {d.playerRatingCount && Number(d.playerRatingCount) > 0 && (
                  <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">({d.playerRatingCount} votes)</span>
                )}
              </div>
            )}
          </div>
        </div>
      </div>

      {/* Pros & Cons */}
      {(d.pros || d.cons) && (
        <div class="grid md:grid-cols-2 gap-6 mb-8">
          {d.pros && d.pros.length > 0 && (
            <div class="border-[3px] border-[#39FF14] bg-black p-6">
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#39FF14] mb-4">PROS</h3>
              <ul class="space-y-2">
                {d.pros.map((pro: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-[#39FF14] mt-0.5 shrink-0">+</span>
                    <span>{pro.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {d.cons && d.cons.length > 0 && (
            <div class="border-[3px] border-white bg-black p-6">
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-4">CONS</h3>
              <ul class="space-y-2">
                {d.cons.map((con: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-[#D4D4D4] mt-0.5 shrink-0">&minus;</span>
                    <span>{con.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      {/* Casino Info Table */}
      {infoRows.length > 0 && (
        <div class="mb-8 border-[3px] border-white bg-black">
          <div class="bg-[#1a1a1a] border-b-[3px] border-white px-6 py-3 flex items-center justify-between">
            <h2 class="font-[Space_Grotesk] text-lg font-bold text-[#FAFF00]">
              {casinoName ? `${casinoName} Details` : "Casino Details"}
            </h2>
            {reviewUrl && (
              <a href={reviewUrl} class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold hover:underline">
                FULL REVIEW &rarr;
              </a>
            )}
          </div>
          <div class="divide-y divide-[#333]">
            {infoRows.map((row) => (
              <div class="grid grid-cols-3 px-6 py-3">
                <div class="text-[#FAFF00] font-[JetBrains_Mono] text-xs font-bold col-span-1">{row.label}</div>
                <div class="text-[#D4D4D4] font-[Public_Sans] text-sm col-span-2">{row.value}</div>
              </div>
            ))}
          </div>
        </div>
      )}

      {/* Content */}
      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h1:text-3xl prose-h1:mt-0 prose-h1:mb-6 prose-h1:border-b-[3px] prose-h1:border-[#39FF14] prose-h1:pb-3
        prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#39FF14] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:leading-relaxed prose-p:mb-4 prose-p:text-[17px]
        prose-li:text-[#D4D4D4] prose-li:text-[17px] prose-li:leading-relaxed
        prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
        prose-blockquote:border-l-4 prose-blockquote:border-[#39FF14] prose-blockquote:bg-[#1a1a1a] prose-blockquote:p-4 prose-blockquote:text-[#FAFF00]
        prose-a:text-[#39FF14] prose-a:underline prose-a:decoration-[#39FF14] prose-a:underline-offset-4 prose-a:decoration-2
        prose-img:border-[3px] prose-img:border-white prose-img:shadow-[4px_4px_0px_0px_#39FF14]
        prose-hr:border-[#39FF14] prose-hr:border-t-[3px] prose-hr:my-10
      ">
        <Content />
      </div>

      {/* Mid-article CTA */}
      {claimUrl && (
        <div class="mt-10 mb-4 border-[3px] border-[#39FF14] bg-black p-6 text-center">
          <p class="text-white font-[Space_Grotesk] font-bold text-lg md:text-xl mb-4">
            Ready to claim the {casinoName || ""} bonus?
          </p>
          <a
            href={claimUrl}
            class="inline-block bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-10 py-4 text-lg border-[3px] border-black shadow-[6px_6px_0px_0px_#000] hover:translate-x-1 hover:translate-y-1 hover:shadow-[3px_3px_0px_0px_#000] transition-all uppercase tracking-wide"
          >
            CLAIM BONUS NOW
          </a>
        </div>
      )}

      {/* Author card */}
      {authorData ? (
        <div class="mt-8 border-[3px] border-white bg-black p-6 md:p-8">
          <div class="flex items-start gap-5">
            {authorData.data.avatar ? (
              <img src={authorData.data.avatar} alt={authorData.data.name} class="w-16 h-16 md:w-20 md:h-20 border-[3px] border-[#39FF14] object-cover shrink-0" />
            ) : (
              <div class="w-16 h-16 md:w-20 md:h-20 border-[3px] border-[#39FF14] bg-[#1a1a1a] flex items-center justify-center shrink-0">
                <span class="text-[#39FF14] font-[Space_Grotesk] font-bold text-2xl">{authorData.data.name.charAt(0)}</span>
              </div>
            )}
            <div class="flex-1">
              <span class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold tracking-wider">REVIEWED BY</span>
              <a href={`/team/${authorData.data.slug}`} class="block font-[Space_Grotesk] text-xl md:text-2xl font-bold text-white hover:text-[#39FF14] transition-colors mt-1">
                {authorData.data.name}
              </a>
              {authorData.data.role && (
                <p class="text-[#D4D4D4] text-sm font-[JetBrains_Mono] mt-1">{authorData.data.role}</p>
              )}
              {authorData.data.bio && (
                <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mt-3 leading-relaxed">{authorData.data.bio}</p>
              )}
              {authorData.data.expertise && authorData.data.expertise.length > 0 && (
                <div class="flex flex-wrap gap-2 mt-3">
                  {authorData.data.expertise.map((exp: string) => (
                    <span class="text-[#39FF14] text-xs font-[JetBrains_Mono] border border-[#39FF14]/40 px-2 py-0.5">{exp}</span>
                  ))}
                </div>
              )}
              {lastUpdatedFormatted && (
                <p class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs mt-3">Last updated: {lastUpdatedFormatted}</p>
              )}
            </div>
          </div>
        </div>
      ) : (
        <aside class="mt-8 p-6 border-[3px] border-[#333] bg-[#0d0d0d]">
          <div class="flex items-center justify-between flex-wrap gap-4">
            <div class="flex items-center gap-3">
              <span class="text-[#D4D4D4] font-[Public_Sans] text-sm">Reviewed by:</span>
              {d.authorSlug ? (
                <a href={`/team/${d.authorSlug}`} class="text-[#39FF14] font-[Space_Grotesk] font-bold hover:underline">
                  {d.author}
                </a>
              ) : (
                <span class="text-white font-[Space_Grotesk] font-bold">{d.author}</span>
              )}
            </div>
            {lastUpdatedFormatted && (
              <div class="text-[#D4D4D4] font-[JetBrains_Mono] text-xs">Last updated: {lastUpdatedFormatted}</div>
            )}
          </div>
        </aside>
      )}

      {/* Related bonuses */}
      {displayRelated.length > 0 && (
        <section class="mt-12 pt-8 border-t-[3px] border-white">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-6 text-[#FAFF00]">SIMILAR BONUSES</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {displayRelated.map((related) => (
              <a href={`/bonus/${related.data.slug}`} class="group block bg-black border-[3px] border-white shadow-none hover:shadow-[6px_6px_0px_0px_#39FF14] transition-all">
                {related.data.image && (
                  <div class="overflow-hidden border-b-[3px] border-white">
                    <img
                      src={related.data.image}
                      alt={related.data.imageAlt || related.data.title}
                      width={related.data.imageWidth}
                      height={related.data.imageHeight}
                      loading="lazy"
                      class="w-full h-auto group-hover:scale-[1.02] transition-transform duration-300"
                    />
                  </div>
                )}
                <div class="p-4">
                  {related.data.bonusType && (
                    <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-2 py-0.5 uppercase tracking-wider mb-2">
                      {related.data.bonusType}
                    </span>
                  )}
                  <h3 class="font-[Space_Grotesk] text-sm font-bold text-white mb-2 line-clamp-2 group-hover:text-[#39FF14] transition-colors">{related.data.title}</h3>
                  {related.data.bonus && (
                    <p class="text-[#39FF14] font-[JetBrains_Mono] text-xs font-bold">{related.data.bonus}</p>
                  )}
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="mt-12 pt-8 border-t-[3px] border-white">
        <a href="/bonus" class="inline-block bg-transparent text-white font-[Space_Grotesk] font-bold px-6 py-3 border-[3px] border-white shadow-[6px_6px_0px_0px_#39FF14] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#39FF14] transition-all">
          BACK TO BONUSES
        </a>
      </div>
    </div>
  </article>

  {/* Sticky Mobile CTA */}
  {claimUrl && (
    <div class="fixed bottom-0 left-0 right-0 z-50 md:hidden bg-black border-t-[3px] border-[#39FF14] p-4 shadow-[0_-4px_20px_rgba(57,255,20,0.3)]">
      <a href={claimUrl} class="block w-full bg-[#39FF14] text-black font-[Space_Grotesk] font-bold px-6 py-4 text-center text-lg border-[3px] border-white shadow-[4px_4px_0px_0px_#FFFFFF]">
        CLAIM BONUS
      </a>
    </div>
  )}

  {/* Reading progress script */}
  <script>
    const bar = document.getElementById('progress-bar');
    if (bar) {
      window.addEventListener('scroll', () => {
        const docH = document.documentElement.scrollHeight - window.innerHeight;
        const pct = docH > 0 ? Math.min((window.scrollY / docH) * 100, 100) : 0;
        bar.style.width = pct + '%';
      }, { passive: true });
    }
  </script>
</Layout>
