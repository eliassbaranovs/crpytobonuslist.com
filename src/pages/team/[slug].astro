---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getAllNews, isBonus } from "../../lib/posts";

export async function getStaticPaths() {
  const authors = await getCollection("authors");
  return authors.map((author) => ({
    params: { slug: author.data.slug },
    props: { author },
  }));
}

const { author } = Astro.props;
const allPosts = await getCollection("posts");
const authorBonuses = allPosts.filter(isBonus).filter(
  (b) => b.data.authorSlug === author.data.slug || b.data.author === author.data.name
);
const allNewsItems = await getAllNews();
const authorNews = allNewsItems.filter(
  (n) => n.data.authorSlug === author.data.slug || n.data.author === author.data.name
);

// Dynamic statistics
const totalBonuses = authorBonuses.length;
const totalNews = authorNews.length;
const totalContributions = totalBonuses + totalNews;
const bonusesToShow = 6;
const newsToShow = 4;
const hasMoreBonuses = totalBonuses > bonusesToShow;
const hasMoreNews = totalNews > newsToShow;

// Resolve author image (image field takes precedence over avatar)
const authorImage = author.data.image || author.data.avatar;
const authorImageUrl = authorImage
  ? (authorImage.startsWith("http") ? authorImage : `https://cryptobonuslist.com${authorImage.startsWith("/") ? "" : "/"}${authorImage}`)
  : undefined;

// Build enriched Person schema
const personSchema: Record<string, any> = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: author.data.name,
  jobTitle: author.data.role,
  description: author.data.bio,
  url: `https://cryptobonuslist.com/team/${author.data.slug}`,
  worksFor: { "@type": "Organization", name: "CryptoBonusList", url: "https://cryptobonuslist.com" },
};

if (authorImageUrl) {
  personSchema.image = authorImageUrl;
}

if (author.data.expertise && author.data.expertise.length > 0) {
  personSchema.knowsAbout = author.data.expertise;
}

if (author.data.credentials && author.data.credentials.length > 0) {
  personSchema.hasCredential = author.data.credentials.map((c: string) => ({
    "@type": "EducationalOccupationalCredential",
    credentialCategory: c,
  }));
}

if (author.data.yearsExperience) {
  personSchema.hasOccupationalExperience = {
    "@type": "OccupationalExperienceRequirements",
    monthsOfExperience: author.data.yearsExperience * 12,
  };
}

if (author.data.socialLinks) {
  const sameAs = Object.values(author.data.socialLinks).filter(Boolean);
  if (sameAs.length > 0) {
    personSchema.sameAs = sameAs;
  }
}

const schemaJsonLd = JSON.stringify(personSchema);
---

<Layout title={`${author.data.name} | CryptoBonusList Team`} description={author.data.bio} jsonld={schemaJsonLd}>
  <article class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <header class="border-[3px] border-white bg-black p-8 shadow-[6px_6px_0px_0px_#39FF14] mb-10">
        <div class="flex gap-6 items-start mb-6">
          {(author.data.image || author.data.avatar) && (
            <img
              src={author.data.image || author.data.avatar}
              alt={author.data.name}
              class="w-24 h-24 md:w-32 md:h-32 rounded-full border-4 border-[#39FF14] object-cover flex-shrink-0"
              loading="eager"
            />
          )}
          <div class="flex-1">
            <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold mb-2">{author.data.name}</h1>
            <p class="text-[#39FF14] font-[JetBrains_Mono] text-sm uppercase tracking-wider mb-4">{author.data.role}</p>
          </div>
        </div>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg leading-relaxed">{author.data.bio}</p>
        {author.data.expertise && (
          <div class="mt-6 flex flex-wrap gap-2">
            {author.data.expertise.map((skill: string) => (
              <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider">{skill}</span>
            ))}
          </div>
        )}
        {author.data.credentials && author.data.credentials.length > 0 && (
          <div class="mt-4 space-y-1">
            {author.data.credentials.map((cred: string) => (
              <div class="flex items-center gap-2 text-[#D4D4D4] font-[Public_Sans] text-sm">
                <span class="text-[#FAFF00] shrink-0">&#9670;</span>
                <span>{cred}</span>
              </div>
            ))}
          </div>
        )}
        <div class="mt-6 flex flex-wrap gap-4 text-[#D4D4D4] font-[JetBrains_Mono] text-xs">
          {author.data.joinedAt && (
            <p>Team member since {new Date(author.data.joinedAt).toLocaleDateString("en-US", { month: "long", year: "numeric" })}</p>
          )}
          {author.data.yearsExperience && (
            <p>{author.data.yearsExperience}+ years in iGaming</p>
          )}
          {totalContributions > 0 && (
            <p class="text-[#39FF14]">
              {totalContributions} {totalContributions === 1 ? 'contribution' : 'contributions'}
              {totalBonuses > 0 && totalNews > 0 && ` (${totalBonuses} ${totalBonuses === 1 ? 'bonus' : 'bonuses'}, ${totalNews} ${totalNews === 1 ? 'article' : 'articles'})`}
            </p>
          )}
        </div>
      </header>

      <section class="mb-12">
        <div class="flex items-center justify-between mb-6 border-b-[3px] border-[#39FF14] pb-2">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold">
            BONUSES BY {author.data.name.toUpperCase()}
            {totalBonuses > 0 && <span class="text-[#39FF14] text-lg ml-2">({totalBonuses})</span>}
          </h2>
        </div>
        {totalBonuses > 0 ? (
          <>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              {authorBonuses.slice(0, bonusesToShow).map((bonus) => (
                <a href={`/bonus/${bonus.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-4 shadow-[6px_6px_0px_0px_#39FF14]">
                  <h3 class="font-[Space_Grotesk] text-lg font-bold text-white mb-1">{bonus.data.title}</h3>
                  {bonus.data.bonus && <p class="text-[#39FF14] font-[JetBrains_Mono] text-sm">{bonus.data.bonus}</p>}
                </a>
              ))}
            </div>
            {hasMoreBonuses && (
              <div class="mt-6 text-center">
                <a href="/bonus" class="inline-block bg-[#39FF14] text-black font-[JetBrains_Mono] font-bold px-6 py-3 uppercase tracking-wider hover:bg-white transition-colors">
                  View All {totalBonuses} Bonuses →
                </a>
              </div>
            )}
          </>
        ) : (
          <p class="text-[#D4D4D4] font-[Public_Sans] italic">No bonuses reviewed yet. Coming soon!</p>
        )}
      </section>

      <section>
        <div class="flex items-center justify-between mb-6 border-b-[3px] border-[#39FF14] pb-2">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold">
            NEWS BY {author.data.name.toUpperCase()}
            {totalNews > 0 && <span class="text-[#39FF14] text-lg ml-2">({totalNews})</span>}
          </h2>
        </div>
        {totalNews > 0 ? (
          <>
            <div class="space-y-4">
              {authorNews.slice(0, newsToShow).map((news) => (
                <a href={`/news/${news.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-4 shadow-[6px_6px_0px_0px_#8A2BE2]">
                  <h3 class="font-[Space_Grotesk] text-lg font-bold text-white mb-1">{news.data.title}</h3>
                  <p class="text-[#D4D4D4] font-[Public_Sans] text-sm line-clamp-2">{news.data.description}</p>
                </a>
              ))}
            </div>
            {hasMoreNews && (
              <div class="mt-6 text-center">
                <a href="/news" class="inline-block bg-[#8A2BE2] text-white font-[JetBrains_Mono] font-bold px-6 py-3 uppercase tracking-wider hover:bg-[#39FF14] hover:text-black transition-colors">
                  View All {totalNews} Articles →
                </a>
              </div>
            )}
          </>
        ) : (
          <p class="text-[#D4D4D4] font-[Public_Sans] italic">No articles published yet. Coming soon!</p>
        )}
      </section>
    </div>
  </article>
</Layout>
