---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const authors = await getCollection("authors");
---

<Layout title="Our Team | CryptoBonusList" description="Meet the people behind CryptoBonusList. Crypto gambling analysts and writers who test casinos with real money.">
  <section class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        OUR <span class="text-[#39FF14]">TEAM</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-2xl">
        Everyone on this list deposits real money, plays through wagering requirements, and deals with withdrawal processes firsthand. No theoretical reviews.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {authors.map((author) => (
          <a
            href={`/team/${author.data.slug}`}
            class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#39FF14]"
          >
            <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-1">
              {author.data.name}
            </h2>
            <p class="text-[#39FF14] font-[JetBrains_Mono] text-xs uppercase tracking-wider mb-3">
              {author.data.role}
            </p>
            <p class="text-[#D4D4D4] font-[Public_Sans] text-sm line-clamp-3">
              {author.data.bio}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
