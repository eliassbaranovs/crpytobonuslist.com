---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getRatingBg, getReviewUrl } from "../../lib/casino-filters";

const allPosts = await getCollection("posts");
const casinoA = allPosts.find(p => p.data.slug === "trino-casino-review");
const casinoB = allPosts.find(p => p.data.slug === "starz-spins-casino-review");

if (!casinoA || !casinoB) {
  return Astro.redirect("/404");
}

const a = casinoA.data;
const b = casinoB.data;

const title = "Trino Casino vs Starz Spins Casino: Which Is Better in 2026?";
const description = "Head-to-head comparison of Trino Casino and Starz Spins Casino. We break down bonuses, wagering, withdrawal speed, licensing, and more to help you pick the right crypto casino.";

const hasCryptoA = (a.depositMethods || "").toLowerCase().includes("bitcoin");
const hasCryptoB = (b.depositMethods || "").toLowerCase().includes("bitcoin");

const faqItems = [
  {
    question: "Which casino has better bonuses, Trino Casino or Starz Spins Casino?",
    answer: "Trino Casino offers a multi-part welcome package worth up to \u20AC2,500 with 150 free spins at 40x wagering. Starz Spins Casino counters with 100% up to $5,000 at an incredibly low 1x wagering requirement. For raw bonus value, Starz Spins wins on wagering terms."
  },
  {
    question: "Is Trino Casino safer than Starz Spins Casino?",
    answer: "Trino Casino holds a Curacao Gaming Control Board license, which is a well-known regulatory body. Starz Spins Casino is licensed by the Anjouan Gaming Board, a newer and less established authority. Trino has a slight edge on trust."
  },
  {
    question: "Which casino has faster crypto withdrawals?",
    answer: "Both casinos process crypto withdrawals within 0-24 hours (Trino) and 0-6 hours (Starz Spins). Starz Spins has a tighter window on paper, making it the faster option for crypto payouts."
  },
  {
    question: "Do both Trino Casino and Starz Spins Casino accept Bitcoin?",
    answer: "Yes. Both casinos accept Bitcoin along with other cryptocurrencies like Ethereum, Tether, and Litecoin."
  }
];

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(f => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": { "@type": "Answer", "text": f.answer }
  }))
});
---

<Layout title={title} description={description} jsonld={faqSchema}>
  <main class="min-h-screen bg-[#0A0A0A] text-white font-[Public_Sans]">
    <div class="max-w-5xl mx-auto px-4 py-12">

      <!-- Breadcrumb -->
      <nav class="text-sm text-gray-400 mb-8">
        <a href="/" class="hover:text-[#39FF14]">Home</a>
        <span class="mx-2">/</span>
        <span class="text-white">Trino Casino vs Starz Spins Casino</span>
      </nav>

      <h1 class="font-[Space_Grotesk] text-4xl md:text-5xl font-bold mb-6">
        Trino Casino vs Starz Spins Casino: Which Is Better in 2026?
      </h1>

      <p class="text-lg text-gray-300 mb-8">
        Two crypto-friendly casinos going head to head. Trino Casino launched in 2024 with a Curacao license and solid game library. Starz Spins Casino arrived in 2025 with an Anjouan license and one of the lowest wagering requirements we have seen. Let's break it down.
      </p>

      <!-- Quick Verdict -->
      <div class="border-[3px] border-white shadow-[6px_6px_0px_0px_#39FF14] p-6 mb-12 bg-[#111]">
        <h2 class="font-[Space_Grotesk] text-2xl font-bold text-[#39FF14] mb-3">Quick Verdict</h2>
        <p class="text-gray-200">
          Trino Casino scores <span class="font-[JetBrains_Mono] text-[#FAFF00]">{a.ourRating}/10</span> while Starz Spins Casino sits at <span class="font-[JetBrains_Mono] text-[#FAFF00]">{b.ourRating}/10</span>. Trino edges ahead on licensing and overall trust. Starz Spins fights back with a 1x wagering requirement that is hard to beat. Pick Trino for reliability, Starz Spins for bonus value.
        </p>
      </div>

      <!-- Side-by-Side Table -->
      <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-6">Side-by-Side Comparison</h2>
      <div class="overflow-x-auto mb-12">
        <table class="w-full border-[3px] border-white text-left">
          <thead>
            <tr class="bg-[#1a1a1a]">
              <th class="font-[Space_Grotesk] p-4 border-b-[3px] border-white">Category</th>
              <th class="font-[Space_Grotesk] p-4 border-b-[3px] border-l-[3px] border-white">Trino Casino</th>
              <th class="font-[Space_Grotesk] p-4 border-b-[3px] border-l-[3px] border-white">Starz Spins Casino</th>
            </tr>
          </thead>
          <tbody class="font-[JetBrains_Mono] text-sm">
            <tr class="border-b border-gray-700">
              <td class="p-4 font-[Public_Sans] font-semibold">Rating</td>
              <td class="p-4 border-l-[3px] border-white">
                <span class={`px-2 py-1 font-bold ${getRatingBg(a.ourRating || 0)}`}>{a.ourRating}/10</span>
              </td>
              <td class="p-4 border-l-[3px] border-white">
                <span class={`px-2 py-1 font-bold ${getRatingBg(b.ourRating || 0)}`}>{b.ourRating}/10</span>
              </td>
            </tr>
            <tr class="border-b border-gray-700 bg-[#111]">
              <td class="p-4 font-[Public_Sans] font-semibold">License</td>
              <td class="p-4 border-l-[3px] border-white">{a.licences || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.licences || "N/A"}</td>
            </tr>
            <tr class="border-b border-gray-700">
              <td class="p-4 font-[Public_Sans] font-semibold">Welcome Bonus</td>
              <td class="p-4 border-l-[3px] border-white">{a.bonus || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.bonus || "N/A"}</td>
            </tr>
            <tr class="border-b border-gray-700 bg-[#111]">
              <td class="p-4 font-[Public_Sans] font-semibold">Wagering</td>
              <td class="p-4 border-l-[3px] border-white">{a.wageringRequirements || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.wageringRequirements || "N/A"}</td>
            </tr>
            <tr class="border-b border-gray-700">
              <td class="p-4 font-[Public_Sans] font-semibold">Crypto Support</td>
              <td class="p-4 border-l-[3px] border-white">{hasCryptoA ? "Yes" : "No"}</td>
              <td class="p-4 border-l-[3px] border-white">{hasCryptoB ? "Yes" : "No"}</td>
            </tr>
            <tr class="border-b border-gray-700 bg-[#111]">
              <td class="p-4 font-[Public_Sans] font-semibold">Withdrawal Speed</td>
              <td class="p-4 border-l-[3px] border-white">{a.withdrawalTimes || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.withdrawalTimes || "N/A"}</td>
            </tr>
            <tr class="border-b border-gray-700">
              <td class="p-4 font-[Public_Sans] font-semibold">Minimum Deposit</td>
              <td class="p-4 border-l-[3px] border-white">{a.minimumDeposit || a.minimum_deposit || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.minimumDeposit || b.minimum_deposit || "N/A"}</td>
            </tr>
            <tr class="border-b border-gray-700 bg-[#111]">
              <td class="p-4 font-[Public_Sans] font-semibold">Live Chat</td>
              <td class="p-4 border-l-[3px] border-white">{a.liveChat || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.liveChat || "N/A"}</td>
            </tr>
            <tr>
              <td class="p-4 font-[Public_Sans] font-semibold">VIP Program</td>
              <td class="p-4 border-l-[3px] border-white">{a.vipLoyaltyProgram || "N/A"}</td>
              <td class="p-4 border-l-[3px] border-white">{b.vipLoyaltyProgram || "N/A"}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- Category Breakdowns -->
      <div class="space-y-12 mb-12">

        <!-- Bonus Value -->
        <section>
          <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-4">Bonus Value</h2>
          <p class="text-gray-300 mb-3">
            Trino Casino gives you a 200% match up to EUR 2,000 on your first deposit, plus a 150% match up to EUR 500 and 150 free spins. The bonus code is <span class="font-[JetBrains_Mono] text-[#39FF14]">200LUCKY</span>. Wagering sits at 40x, which is about average for the industry.
          </p>
          <p class="text-gray-300 mb-4">
            Starz Spins Casino keeps it simple with a 100% match up to $5,000. The standout here is the 1x wagering requirement. That means you deposit, get your bonus, and need to wager the total amount only once before withdrawing. That is almost unheard of.
          </p>
          <div class="border-[3px] border-[#39FF14] bg-[#0d1a0d] px-4 py-3 inline-block">
            <span class="font-[Space_Grotesk] font-bold text-[#39FF14]">Winner: Starz Spins Casino</span> <span class="text-gray-400">- 1x wagering crushes the competition</span>
          </div>
        </section>

        <!-- Withdrawal Speed -->
        <section>
          <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-4">Withdrawal Speed</h2>
          <p class="text-gray-300 mb-3">
            Trino Casino processes crypto withdrawals within 0-24 hours. E-wallets follow the same timeline. Bank transfers take up to 72 hours. The pending time stretches up to 72 hours on top of that.
          </p>
          <p class="text-gray-300 mb-4">
            Starz Spins Casino processes crypto payouts within 0-6 hours. That is a tighter window. E-wallets take up to 24 hours and bank transfers stretch to 3-10 days. Pending time is shorter at 0-24 hours.
          </p>
          <div class="border-[3px] border-[#39FF14] bg-[#0d1a0d] px-4 py-3 inline-block">
            <span class="font-[Space_Grotesk] font-bold text-[#39FF14]">Winner: Starz Spins Casino</span> <span class="text-gray-400">- faster crypto payouts and shorter pending time</span>
          </div>
        </section>

        <!-- Licensing and Trust -->
        <section>
          <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-4">Licensing and Trust</h2>
          <p class="text-gray-300 mb-3">
            Trino Casino operates under a Curacao Gaming Control Board license. Curacao is not the strongest regulator, but it is well-established and recognized across the industry. The casino also has 24/7 live chat and a VIP loyalty program.
          </p>
          <p class="text-gray-300 mb-4">
            Starz Spins Casino holds an Anjouan Gaming Board license. Anjouan is a newer licensing authority with limited track record. No live chat support is a red flag for some players. No VIP program either.
          </p>
          <div class="border-[3px] border-[#39FF14] bg-[#0d1a0d] px-4 py-3 inline-block">
            <span class="font-[Space_Grotesk] font-bold text-[#39FF14]">Winner: Trino Casino</span> <span class="text-gray-400">- more established license and better support</span>
          </div>
        </section>

        <!-- Game Selection -->
        <section>
          <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-4">Game Selection</h2>
          <p class="text-gray-300 mb-3">
            Trino Casino packs a strong lineup with providers like Pragmatic Play, NetEnt, Evolution Gaming, Play'n GO, and Hacksaw Gaming. The casino covers slots, live dealer, and sports betting. Mobile apps are available for iOS and Android.
          </p>
          <p class="text-gray-300 mb-4">
            Starz Spins Casino brings an even wider range of providers including Nolimit City, Playtech, and BGaming alongside the usual names. PvP battles add a unique twist. No mobile app is a downside for on-the-go players.
          </p>
          <div class="border-[3px] border-[#39FF14] bg-[#0d1a0d] px-4 py-3 inline-block">
            <span class="font-[Space_Grotesk] font-bold text-[#39FF14]">Winner: Tie</span> <span class="text-gray-400">- both offer deep game libraries from top providers</span>
          </div>
        </section>

        <!-- Support -->
        <section>
          <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-4">Support</h2>
          <p class="text-gray-300 mb-3">
            Trino Casino offers 24/7 live chat and email support at support@trinocasino.com. Complaint response time is 24 hours. This is solid for a mid-tier casino.
          </p>
          <p class="text-gray-300 mb-4">
            Starz Spins Casino has no live chat. Email support is available at support@starzspins.com with complaint responses taking 1-5 days. That is a significant gap in player support.
          </p>
          <div class="border-[3px] border-[#39FF14] bg-[#0d1a0d] px-4 py-3 inline-block">
            <span class="font-[Space_Grotesk] font-bold text-[#39FF14]">Winner: Trino Casino</span> <span class="text-gray-400">- 24/7 live chat makes a big difference</span>
          </div>
        </section>

      </div>

      <!-- Final Verdict -->
      <div class="border-[3px] border-white shadow-[6px_6px_0px_0px_#8A2BE2] p-8 mb-12 bg-[#111]">
        <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-6 text-[#FAFF00]">Which Casino Fits You?</h2>
        <div class="grid md:grid-cols-2 gap-6">
          <div>
            <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#39FF14] mb-3">Pick Trino Casino if you...</h3>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Want a more trusted license (Curacao)</li>
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Need 24/7 live chat support</li>
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Prefer a VIP loyalty program</li>
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Want mobile apps for iOS and Android</li>
            </ul>
            <a href={getReviewUrl(casinoA)} class="inline-block mt-4 border-[3px] border-[#39FF14] text-[#39FF14] font-[Space_Grotesk] font-bold px-6 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">
              Read Trino Casino Review
            </a>
          </div>
          <div>
            <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#39FF14] mb-3">Pick Starz Spins Casino if you...</h3>
            <ul class="space-y-2 text-gray-300">
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Want the lowest wagering requirement (1x)</li>
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Prefer faster crypto withdrawals (0-6 hours)</li>
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Like a higher max bonus ($5,000)</li>
              <li class="flex items-start gap-2"><span class="text-[#39FF14] mt-1">+</span> Enjoy PvP battle features</li>
            </ul>
            <a href={getReviewUrl(casinoB)} class="inline-block mt-4 border-[3px] border-[#39FF14] text-[#39FF14] font-[Space_Grotesk] font-bold px-6 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">
              Read Starz Spins Casino Review
            </a>
          </div>
        </div>
      </div>

      <!-- FAQ -->
      <section class="mb-12">
        <h2 class="font-[Space_Grotesk] text-3xl font-bold mb-6">FAQ</h2>
        <div class="space-y-4">
          {faqItems.map(faq => (
            <details class="border-[3px] border-white bg-[#111] group">
              <summary class="font-[Space_Grotesk] font-bold p-4 cursor-pointer hover:text-[#39FF14] list-none flex justify-between items-center">
                {faq.question}
                <span class="text-[#39FF14] group-open:rotate-45 transition-transform text-2xl">+</span>
              </summary>
              <p class="px-4 pb-4 text-gray-300">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <!-- Internal Links -->
      <div class="border-t-[3px] border-gray-700 pt-8">
        <h3 class="font-[Space_Grotesk] text-xl font-bold mb-4">Related Pages</h3>
        <ul class="space-y-2 text-gray-300">
          <li><a href={getReviewUrl(casinoA)} class="text-[#39FF14] hover:underline">Trino Casino Full Review</a></li>
          <li><a href={getReviewUrl(casinoB)} class="text-[#39FF14] hover:underline">Starz Spins Casino Full Review</a></li>
          <li><a href="/best-crypto-casinos" class="text-[#39FF14] hover:underline">Best Crypto Casinos 2026</a></li>
          <li><a href="/methodology" class="text-[#39FF14] hover:underline">Our Review Methodology</a></li>
        </ul>
      </div>

    </div>
  </main>
</Layout>
