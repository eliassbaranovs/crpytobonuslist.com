---
import Layout from "../../layouts/Layout.astro";
import { getAllNews } from "../../lib/posts";
import type { GetStaticPaths, Page } from "astro";
import type { AnyPost } from "../../lib/posts";

export const getStaticPaths = (async ({ paginate }) => {
  const sortedNews = await getAllNews();
  return paginate(sortedNews, { pageSize: 10 });
}) satisfies GetStaticPaths;

interface Props {
  page: Page<AnyPost>;
}

const { page } = Astro.props;
---

<Layout title="Crypto Casino News | CryptoBonusList" description="Crypto gambling news. Regulation changes, network updates, and what affects your deposits and withdrawals.">
  <section class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        CRYPTO <span class="text-[#FAFF00]">NEWS</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-2xl">
        What is moving in crypto gambling. Regulation shifts, new features, network changes, and the updates that affect how you deposit and play.
      </p>

      <div class="space-y-0">
        {page.data.map((article, i) => (
          <a
            href={`/news/${article.data.slug}`}
            class:list={[
              "card-brutal block bg-black border-[3px] border-white p-6",
              i > 0 && "-mt-[3px]",
              "shadow-none hover:shadow-[6px_6px_0px_0px_#FAFF00] hover:z-10 hover:relative transition-all"
            ]}
          >
            <div class="flex items-center gap-4 mb-2">
              <span class="text-[#39FF14] text-xs font-[JetBrains_Mono] font-bold">
                {new Date(article.data.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
              </span>
              <span class="text-[#D4D4D4] text-xs font-[Public_Sans]">{article.data.author}</span>
            </div>
            <h2 class="font-[Space_Grotesk] text-xl md:text-2xl font-bold text-white mb-2">{article.data.title}</h2>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans] mb-3">{article.data.description}</p>
            <div class="flex flex-wrap gap-2">
              {article.data.tags.map((tag: string) => (
                <span class="text-[#FAFF00] text-xs font-[JetBrains_Mono] border border-[#FAFF00] px-2 py-1">{tag}</span>
              ))}
            </div>
          </a>
        ))}
      </div>

      <!-- Pagination Navigation -->
      {(page.url.prev || page.url.next) && (
        <nav class="flex justify-between items-center mt-12 pt-8 border-t-[3px] border-white">
          <div>
            {page.url.prev ? (
              <a
                href={page.url.prev}
                class="card-brutal inline-block bg-black border-[3px] border-white px-6 py-3 font-[Space_Grotesk] font-bold text-white hover:shadow-[6px_6px_0px_0px_#FAFF00] transition-all"
              >
                ← Previous
              </a>
            ) : (
              <span class="inline-block opacity-30 px-6 py-3 font-[Space_Grotesk] font-bold text-[#D4D4D4]">
                ← Previous
              </span>
            )}
          </div>

          <div class="text-center font-[JetBrains_Mono] text-sm text-[#D4D4D4]">
            Page {page.currentPage} of {page.lastPage}
          </div>

          <div>
            {page.url.next ? (
              <a
                href={page.url.next}
                class="card-brutal inline-block bg-black border-[3px] border-white px-6 py-3 font-[Space_Grotesk] font-bold text-white hover:shadow-[6px_6px_0px_0px_#FAFF00] transition-all"
              >
                Next →
              </a>
            ) : (
              <span class="inline-block opacity-30 px-6 py-3 font-[Space_Grotesk] font-bold text-[#D4D4D4]">
                Next →
              </span>
            )}
          </div>
        </nav>
      )}
    </div>
  </section>
</Layout>
