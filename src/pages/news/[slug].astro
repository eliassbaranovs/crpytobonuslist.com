---
import { render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { getAllNews } from "../../lib/posts";

export async function getStaticPaths() {
  const allNews = await getAllNews();
  return allNews.map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const jsonld = post.data.schema_jsonld;
const lastUpdated = post.data.updatedAt || post.data.publishedAt;
const publishedDate = new Date(post.data.publishedAt);
const now = new Date();
const diffMs = now.getTime() - publishedDate.getTime();
const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

const wordCount = post.body ? post.body.split(/\s+/).filter(Boolean).length : 0;
const readingTime = post.data.readingTime || (Math.ceil(wordCount / 200) || 1) + " min read";

const wasUpdated = lastUpdated.getTime() - publishedDate.getTime() > 86400000;

let relativeTime: string;
if (diffDays === 0) {
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  relativeTime = diffHours === 0 ? "Just now" : diffHours + " hour" + (diffHours > 1 ? "s" : "") + " ago";
} else if (diffDays === 1) {
  relativeTime = "Yesterday";
} else if (diffDays < 7) {
  relativeTime = diffDays + " days ago";
} else if (diffDays < 30) {
  const weeks = Math.floor(diffDays / 7);
  relativeTime = weeks + " week" + (weeks > 1 ? "s" : "") + " ago";
} else {
  relativeTime = publishedDate.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" });
}

const newsItems = await getAllNews();
const currentTags = post.data.tags || [];

const relatedNews = newsItems
  .filter((n) => n.data.slug !== post.data.slug)
  .filter((n) => currentTags.length > 0 && n.data.tags?.some((tag: string) => currentTags.includes(tag)))
  .slice(0, 3);

const displayRelated = relatedNews.length > 0 ? relatedNews : newsItems.filter((n) => n.data.slug !== post.data.slug).slice(0, 3);

const robots = post.data.robots || (post.data.noIndex ? "noindex, nofollow" : "index, follow");
---

<Layout
  title={post.data.seoTitle}
  description={post.data.description}
  jsonld={jsonld}
  ogType="article"
  ogImage={post.data.image || "/favicon.svg"}
  canonical={post.data.canonical || undefined}
  robots={robots}
>
  <article class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-6 text-sm font-[JetBrains_Mono]">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="text-[#D4D4D4] hover:text-[#39FF14]">Home</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li><a href="/news" class="text-[#D4D4D4] hover:text-[#39FF14]">News</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li class="text-white" aria-current="page">{post.data.title}</li>
        </ol>
      </nav>

      <header class="border-[3px] border-white bg-black p-8 mb-8 shadow-[6px_6px_0px_0px_#FAFF00]">
        {post.data.featured && (
          <div class="mb-4">
            <span class="inline-block bg-[#FAFF00] text-black font-[Space_Grotesk] font-bold text-xs px-3 py-1 tracking-wider">FEATURED</span>
          </div>
        )}
        <div class="flex items-center gap-4 mb-4 flex-wrap">
          <span class="text-[#39FF14] text-sm font-[JetBrains_Mono] font-bold">{relativeTime}</span>
          {wasUpdated && (
            <span class="text-[#FAFF00] text-sm font-[JetBrains_Mono] font-bold border border-[#FAFF00] px-2 py-0.5">
              Updated {lastUpdated.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" })}
            </span>
          )}
          <span class="text-[#D4D4D4] text-sm font-[Public_Sans]">&bull;</span>
          <span class="text-[#D4D4D4] text-sm font-[JetBrains_Mono]">{readingTime}</span>
          <span class="text-[#D4D4D4] text-sm font-[Public_Sans]">&bull;</span>
          {post.data.authorSlug ? (
            <a href={`/team/${post.data.authorSlug}`} class="text-[#39FF14] text-sm font-[Public_Sans] font-bold hover:underline">
              {post.data.author}
            </a>
          ) : (
            <span class="text-white text-sm font-[Public_Sans] font-bold">{post.data.author}</span>
          )}
        </div>
        <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight mb-4">{post.data.title}</h1>
        {post.data.excerpt && (
          <p class="text-[#D4D4D4] text-lg font-[Public_Sans] leading-relaxed mb-4">{post.data.excerpt}</p>
        )}
        <div class="flex flex-wrap gap-2">
          {post.data.tags.map((tag: string) => (
            <span class="text-[#FAFF00] text-sm font-[JetBrains_Mono] border border-[#FAFF00] px-3 py-1">{tag}</span>
          ))}
        </div>
      </header>

      {post.data.image && (
        <div class="mb-8">
          <img
            src={post.data.image}
            alt={post.data.imageAlt}
            width={post.data.imageWidth}
            height={post.data.imageHeight}
            loading="eager"
            fetchpriority="high"
            class="w-full h-auto border-[3px] border-white shadow-[6px_6px_0px_0px_#FAFF00]"
          />
        </div>
      )}

      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#FAFF00] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-[#D4D4D4]
        prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
        prose-blockquote:border-l-4 prose-blockquote:border-[#FAFF00] prose-blockquote:bg-[#1a1a1a] prose-blockquote:p-4 prose-blockquote:text-[#FAFF00]
      ">
        <Content />
      </div>

      {displayRelated.length > 0 && (
        <aside class="mt-12 pt-8 border-t-[3px] border-white">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-6 text-[#FAFF00]">RELATED NEWS</h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {displayRelated.map((related) => (
              <a href={`/news/${related.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-4 shadow-[6px_6px_0px_0px_#FAFF00]">
                <div class="text-[#FAFF00] text-xs font-[JetBrains_Mono] mb-2">
                  {new Date(related.data.publishedAt).toLocaleDateString("en-US", { month: "short", day: "numeric" })}
                </div>
                <h3 class="font-[Space_Grotesk] text-sm font-bold text-white line-clamp-2">{related.data.title}</h3>
              </a>
            ))}
          </div>
        </aside>
      )}

      <div class="mt-12 pt-8 border-t-[3px] border-white">
        <a href="/news" class="inline-block bg-transparent text-white font-[Space_Grotesk] font-bold px-6 py-3 border-[3px] border-white shadow-[6px_6px_0px_0px_#FAFF00] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#FAFF00] transition-all">
          BACK TO NEWS
        </a>
      </div>
    </div>
  </article>
</Layout>
