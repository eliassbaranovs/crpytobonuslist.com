---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const news = await getCollection("news");
  return news.map((article) => ({
    params: { slug: article.data.slug },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

// Schema is pre-generated by automation and stored in schema_jsonld
const jsonld = article.data.schema_jsonld;

// Get last updated date
const lastUpdated = article.data.updatedAt || article.data.publishedAt;
const publishedDate = new Date(article.data.publishedAt);
const now = new Date();
const diffMs = now.getTime() - publishedDate.getTime();
const diffDays = Math.floor(diffMs / (1000 * 60 * 60 * 24));

// Calculate reading time (average 200 words per minute)
const wordCount = article.body ? article.body.split(/\s+/).filter(Boolean).length : 0;
const readingTime = Math.ceil(wordCount / 200) || 1;

// Check if article was updated (more than 1 day after publish)
const wasUpdated = lastUpdated.getTime() - publishedDate.getTime() > 86400000;

// Relative time for news
let relativeTime: string;
if (diffDays === 0) {
  const diffHours = Math.floor(diffMs / (1000 * 60 * 60));
  if (diffHours === 0) {
    relativeTime = "Just now";
  } else {
    relativeTime = `${diffHours} hour${diffHours > 1 ? 's' : ''} ago`;
  }
} else if (diffDays === 1) {
  relativeTime = "Yesterday";
} else if (diffDays < 7) {
  relativeTime = `${diffDays} days ago`;
} else if (diffDays < 30) {
  const weeks = Math.floor(diffDays / 7);
  relativeTime = `${weeks} week${weeks > 1 ? 's' : ''} ago`;
} else {
  relativeTime = publishedDate.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' });
}

// Get related news (same tags)
const allNews = await getCollection("news");
const currentTags = article.data.tags || [];

const relatedNews = allNews
  .filter((n) => n.data.slug !== article.data.slug)
  .filter((n) => {
    if (currentTags.length > 0 && n.data.tags) {
      return n.data.tags.some((tag: string) => currentTags.includes(tag));
    }
    return false;
  })
  .slice(0, 3);

// Fallback to latest if no related
const displayRelated = relatedNews.length > 0 ? relatedNews : allNews.filter((n) => n.data.slug !== article.data.slug).slice(0, 3);

// Author slug (derive from author name if not provided)
const authorSlug = article.data.authorSlug || (article.data.author === "CryptoBonusList Team" ? "cryptobonuslist-team" : null);

// Prepare SEO fields
const robots = article.data.robots || (article.data.noIndex ? "noindex, nofollow" : "index, follow");
const ogImage = article.data.image || "/favicon.svg";
---

<Layout
  title={article.data.seoTitle || article.data.title}
  description={article.data.description || article.data.excerpt || article.data.title}
  jsonld={jsonld}
  ogType="article"
  ogImage={ogImage}
  canonical={article.data.canonical || undefined}
  robots={robots}
>
  <article class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <!-- Breadcrumbs -->
      <nav aria-label="Breadcrumb" class="mb-6 text-sm font-[JetBrains_Mono]">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="text-[#D4D4D4] hover:text-[#39FF14]">Home</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li><a href="/news" class="text-[#D4D4D4] hover:text-[#39FF14]">News</a></li>
          {article.data.category && article.data.category !== 'news' && (
            <>
              <li class="text-[#D4D4D4]">/</li>
              <li class="text-[#D4D4D4]">{article.data.category}</li>
            </>
          )}
          <li class="text-[#D4D4D4]">/</li>
          <li class="text-white" aria-current="page">{article.data.title}</li>
        </ol>
      </nav>

      <!-- Banner -->
      <header class="border-[3px] border-white bg-black p-8 mb-8 shadow-[6px_6px_0px_0px_#FAFF00]">
        {article.data.featured && (
          <div class="mb-4">
            <span class="inline-block bg-[#FAFF00] text-black font-[Space_Grotesk] font-bold text-xs px-3 py-1 tracking-wider">FEATURED</span>
          </div>
        )}
        <div class="flex items-center gap-4 mb-4 flex-wrap">
          <span class="text-[#39FF14] text-sm font-[JetBrains_Mono] font-bold">
            {relativeTime}
          </span>
          {wasUpdated && (
            <span class="text-[#FAFF00] text-sm font-[JetBrains_Mono] font-bold border border-[#FAFF00] px-2 py-0.5">
              Updated {lastUpdated.toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
          )}
          <span class="text-[#D4D4D4] text-sm font-[Public_Sans]">•</span>
          <span class="text-[#D4D4D4] text-sm font-[JetBrains_Mono]">
            {readingTime} min read
          </span>
          <span class="text-[#D4D4D4] text-sm font-[Public_Sans]">•</span>
          <span class="text-[#D4D4D4] text-sm font-[Public_Sans]">by</span>
          {authorSlug ? (
            <a href={`/team/${authorSlug}`} class="text-[#39FF14] text-sm font-[Public_Sans] font-bold hover:underline">
              {article.data.author}
            </a>
          ) : (
            <span class="text-white text-sm font-[Public_Sans] font-bold">
              {article.data.author}
            </span>
          )}
        </div>
        <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight mb-4">
          {article.data.title}
        </h1>
        {article.data.excerpt && (
          <p class="text-[#D4D4D4] text-lg font-[Public_Sans] leading-relaxed mb-4">
            {article.data.excerpt}
          </p>
        )}
        <div class="flex flex-wrap gap-2">
          {article.data.category && (
            <span class="text-[#39FF14] text-sm font-[JetBrains_Mono] border border-[#39FF14] px-3 py-1 bg-[#39FF14]/10">
              {article.data.category}
            </span>
          )}
          {article.data.tags.map((tag: string) => (
            <span class="text-[#FAFF00] text-sm font-[JetBrains_Mono] border border-[#FAFF00] px-3 py-1">
              {tag}
            </span>
          ))}
        </div>
      </header>

      <!-- Featured Image -->
      {article.data.image && (
        <div class="mb-8">
          <img
            src={article.data.image}
            alt={article.data.imageAlt || article.data.title}
            class="w-full h-auto border-[3px] border-white shadow-[6px_6px_0px_0px_#FAFF00]"
          />
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#FAFF00] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-[#D4D4D4]
        prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
        prose-blockquote:border-l-4 prose-blockquote:border-[#FAFF00] prose-blockquote:bg-[#1a1a1a] prose-blockquote:p-4 prose-blockquote:text-[#FAFF00]
      ">
        <Content />
      </div>

      <!-- Related News -->
      {displayRelated.length > 0 && (
        <aside class="mt-12 pt-8 border-t-[3px] border-white">
          <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-6 text-[#FAFF00]">
            RELATED NEWS
          </h2>
          <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            {displayRelated.map((related) => (
              <a
                href={`/news/${related.data.slug}`}
                class="card-brutal block bg-black border-[3px] border-white p-4 shadow-[6px_6px_0px_0px_#FAFF00]"
              >
                <div class="text-[#FAFF00] text-xs font-[JetBrains_Mono] mb-2">
                  {new Date(related.data.publishedAt).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                </div>
                <h3 class="font-[Space_Grotesk] text-sm font-bold text-white line-clamp-2">
                  {related.data.title}
                </h3>
              </a>
            ))}
          </div>
        </aside>
      )}

      <!-- Back link -->
      <div class="mt-12 pt-8 border-t-[3px] border-white">
        <a
          href="/news"
          class="inline-block bg-transparent text-white font-[Space_Grotesk] font-bold px-6 py-3 border-[3px] border-white shadow-[6px_6px_0px_0px_#FAFF00] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#FAFF00] transition-all"
        >
          BACK TO NEWS
        </a>
      </div>
    </div>
  </article>
</Layout>
