---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isGuide, sortByDate } from "../../lib/posts";

const allPosts = await getCollection("posts");
const guides = sortByDate(allPosts.filter(isGuide));
---

<Layout title="Crypto Casino Guides | CryptoBonusList" description="How-to guides for crypto gambling. From beginner basics to advanced strategy.">
  <section class="px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        CRYPTO <span class="text-[#39FF14]">GUIDES</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-2xl">
        From getting started with crypto deposits to advanced bonus strategies. Practical guides, no fluff.
      </p>

      {guides.length > 0 ? (
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {guides.map((guide) => (
            <a href={`/guides/${guide.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#39FF14]">
              {guide.data.difficulty && (
                <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-2 py-1 uppercase tracking-wider mb-3">
                  {guide.data.difficulty}
                </span>
              )}
              <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{guide.data.title}</h2>
              <p class="text-[#D4D4D4] text-sm font-[Public_Sans] line-clamp-3">{guide.data.description}</p>
            </a>
          ))}
        </div>
      ) : (
        <p class="text-[#D4D4D4] font-[Public_Sans]">Guides coming soon. Check back later.</p>
      )}
    </div>
  </section>
</Layout>
