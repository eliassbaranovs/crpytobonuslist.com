---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isGuide, sortByDate } from "../../lib/posts";

const allPosts = await getCollection("posts");
const collectionGuides = sortByDate(allPosts.filter(isGuide));

// Static guides (not from content collection)
const staticGuides = [
  {
    slug: "is-crypto-gambling-safe",
    title: "Is Crypto Gambling Safe? What You Need to Know",
    description: "Blockchain security, licensed vs unlicensed casinos, wallet safety, provably fair tech, and the real risks of anonymous gambling.",
    category: "Safety",
  },
  {
    slug: "crypto-casino-vs-regular-casino",
    title: "Crypto Casino vs Regular Casino: Key Differences",
    description: "Speed, privacy, fees, bonuses, regulation, and game selection compared side by side. Which one fits your situation.",
    category: "Comparison",
  },
  {
    slug: "crypto-casino-fees-explained",
    title: "Crypto Casino Fees Explained: What Does It Cost?",
    description: "Network fees by coin, casino deposit and withdrawal fees, hidden costs, and how to keep more of your money.",
    category: "Finance",
  },
  {
    slug: "is-crypto-gambling-legal",
    title: "Is Crypto Gambling Legal? A Country Guide",
    description: "Legal status by country, licensed jurisdictions, grey areas, VPN risks, and what players need to know about regulation.",
    category: "Legal",
  },
  {
    slug: "how-crypto-casino-withdrawals-work",
    title: "How Crypto Casino Withdrawals Work",
    description: "Step-by-step withdrawal process, KYC verification, pending periods, blockchain confirmations, limits, and troubleshooting.",
    category: "How-To",
  },
];

const schemaJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Crypto Casino Guides",
  "description": "Educational guides for crypto gambling. Safety, fees, legality, withdrawals, and comparisons.",
  "url": "https://cryptobonuslist.com/guides",
  "publisher": {
    "@type": "Organization",
    "name": "CryptoBonusList",
    "url": "https://cryptobonuslist.com"
  }
});
---

<Layout
  title="Crypto Casino Guides | CryptoBonusList"
  description="How-to guides for crypto gambling. Safety, fees, legality, withdrawals, and comparisons. Written from experience, not textbooks."
  jsonld={schemaJsonLd}
>
  <section class="px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        CRYPTO <span class="text-[#39FF14]">GUIDES</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-2xl">
        Practical guides for crypto casino players. How things work, what things cost, and what to watch out for. No fluff.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {/* Static guides */}
        {staticGuides.map((guide) => (
          <a href={`/guides/${guide.slug}`} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#39FF14]">
            <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-2 py-1 uppercase tracking-wider mb-3">
              {guide.category}
            </span>
            <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{guide.title}</h2>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans] line-clamp-3">{guide.description}</p>
          </a>
        ))}

        {/* Collection-based guides (from pipeline) */}
        {collectionGuides.map((guide) => (
          <a href={`/guides/${guide.data.slug}`} class="card-brutal block bg-black border-[3px] border-white p-6 shadow-[6px_6px_0px_0px_#39FF14]">
            {guide.data.difficulty && (
              <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-2 py-1 uppercase tracking-wider mb-3">
                {guide.data.difficulty}
              </span>
            )}
            <h2 class="font-[Space_Grotesk] text-xl font-bold text-white mb-3">{guide.data.title}</h2>
            <p class="text-[#D4D4D4] text-sm font-[Public_Sans] line-clamp-3">{guide.data.description}</p>
          </a>
        ))}
      </div>

      <!-- Related -->
      <div class="mt-12 border-t-[3px] border-white pt-8">
        <p class="text-[#D4D4D4] font-[Public_Sans]">
          Looking for casino reviews? Check our <a href="/casinos" class="text-[#39FF14] underline">casino reviews</a> or <a href="/best-crypto-casinos" class="text-[#39FF14] underline">best crypto casinos</a> ranking.
        </p>
      </div>
    </div>
  </section>
</Layout>
