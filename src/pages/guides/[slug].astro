---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import { isGuide } from "../../lib/posts";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.filter(isGuide).map((post) => ({
    params: { slug: post.data.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const slug = post.data.slug;
const computedCanonical = `https://cryptobonuslist.com/guides/${slug}`;
const robots = post.data.robots || (post.data.noIndex ? "noindex, nofollow" : "index, follow");

// Build JSON-LD: merge existing schema with BreadcrumbList in @graph
const existingSchema = post.data.schema_jsonld ? JSON.parse(post.data.schema_jsonld) : null;
const breadcrumbLd = {
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://cryptobonuslist.com/" },
    { "@type": "ListItem", "position": 2, "name": "Guides", "item": "https://cryptobonuslist.com/guides" },
    { "@type": "ListItem", "position": 3, "name": post.data.title, "item": computedCanonical }
  ]
};

let graphItems: any[] = [breadcrumbLd];
if (existingSchema) {
  if (existingSchema["@graph"]) {
    graphItems = [...existingSchema["@graph"], breadcrumbLd];
  } else {
    const { "@context": _ctx, ...rest } = existingSchema;
    graphItems = [rest, breadcrumbLd];
  }
}

const jsonld = JSON.stringify({ "@context": "https://schema.org", "@graph": graphItems });
---

<Layout
  title={post.data.seoTitle || post.data.title}
  description={post.data.description}
  jsonld={jsonld}
  ogType="article"
  ogImage={post.data.image || "/images/og-default.jpg"}
  canonical={computedCanonical}
  robots={robots}
>
  <article class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <nav aria-label="Breadcrumb" class="mb-6 text-sm font-[JetBrains_Mono]">
        <ol class="flex flex-wrap items-center gap-2">
          <li><a href="/" class="text-[#D4D4D4] hover:text-[#39FF14]">Home</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li><a href="/guides" class="text-[#D4D4D4] hover:text-[#39FF14]">Guides</a></li>
          <li class="text-[#D4D4D4]">/</li>
          <li class="text-white" aria-current="page">{post.data.title}</li>
        </ol>
      </nav>

      <header class="border-[3px] border-white bg-black p-8 mb-8 shadow-[6px_6px_0px_0px_#39FF14]">
        {post.data.difficulty && (
          <span class="inline-block bg-[#8A2BE2] text-white text-xs font-[JetBrains_Mono] font-bold px-3 py-1 uppercase tracking-wider mb-4">
            {post.data.difficulty}
          </span>
        )}
        <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight mb-4">{post.data.title}</h1>
        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg">{post.data.description}</p>
      </header>

      {post.data.image && (
        <div class="mb-8">
          <img src={post.data.image} alt={post.data.imageAlt} width={post.data.imageWidth} height={post.data.imageHeight} loading="eager" fetchpriority="high" class="w-full h-auto border-[3px] border-white shadow-[6px_6px_0px_0px_#39FF14]" />
        </div>
      )}

      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#39FF14] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-[#D4D4D4] prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
      ">
        <Content />
      </div>
    </div>
  </article>
</Layout>
