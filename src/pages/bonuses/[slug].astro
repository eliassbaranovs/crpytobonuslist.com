---
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const bonuses = await getCollection("bonuses");
  return bonuses.map((bonus) => ({
    params: { slug: bonus.id.replace(/\.md$/, '') },
    props: { bonus },
  }));
}

const { bonus } = Astro.props;
const { Content } = await render(bonus);
const seoTitle = bonus.data.title + " | CryptoBonusList";
---

<Layout title={seoTitle} description={bonus.data.description}>
  <article class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <!-- Banner -->
      <div class="border-[3px] border-white bg-black p-8 mb-8 shadow-[6px_6px_0px_0px_#39FF14]">
        <div class="flex items-center justify-between gap-4 mb-4">
          <div class="flex items-center gap-3">
            {bonus.data.bonusType && (
              <span class="inline-block bg-[#8A2BE2] text-white text-sm font-[JetBrains_Mono] font-bold px-4 py-2 uppercase tracking-wider">
                {bonus.data.bonusType}
              </span>
            )}
            {bonus.data.verified && (
              <span class="inline-block bg-[#39FF14] text-black text-sm font-[JetBrains_Mono] font-bold px-4 py-2 uppercase tracking-wider">
                VERIFIED
              </span>
            )}
          </div>
          {bonus.data.publishDate && (
            <span class="text-[#39FF14] text-sm font-[JetBrains_Mono]">
              {new Date(bonus.data.publishDate).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}
            </span>
          )}
        </div>
        
        <h1 class="font-[Space_Grotesk] text-3xl md:text-5xl font-bold text-white leading-tight mb-4">
          {bonus.data.title}
        </h1>
        
        <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-6">
          {bonus.data.description}
        </p>

        {/* Key Bonus Info */}
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-6">
          {bonus.data.bonus && (
            <div class="border-[2px] border-[#39FF14] p-3">
              <div class="text-[#39FF14] text-xs font-[JetBrains_Mono] mb-1">BONUS AMOUNT</div>
              <div class="text-white font-[JetBrains_Mono] font-bold">{bonus.data.bonus}</div>
            </div>
          )}
          {bonus.data.freeSpins && bonus.data.freeSpins > 0 && (
            <div class="border-[2px] border-[#39FF14] p-3">
              <div class="text-[#39FF14] text-xs font-[JetBrains_Mono] mb-1">FREE SPINS</div>
              <div class="text-white font-[JetBrains_Mono] font-bold">{bonus.data.freeSpins}</div>
            </div>
          )}
          {bonus.data.wageringRequirements && (
            <div class="border-[2px] border-white p-3">
              <div class="text-[#FAFF00] text-xs font-[JetBrains_Mono] mb-1">WAGERING</div>
              <div class="text-white font-[JetBrains_Mono] font-bold">{bonus.data.wageringRequirements}</div>
            </div>
          )}
          {bonus.data.minimumDeposit && (
            <div class="border-[2px] border-white p-3">
              <div class="text-[#FAFF00] text-xs font-[JetBrains_Mono] mb-1">MIN DEPOSIT</div>
              <div class="text-white font-[JetBrains_Mono] font-bold">{bonus.data.minimumDeposit}</div>
            </div>
          )}
        </div>

        {/* Casino & Rating */}
        <div class="flex items-center justify-between flex-wrap gap-4 pt-4 border-t-[2px] border-[#333]">
          {bonus.data.casinoName && (
            <div class="text-white font-[JetBrains_Mono]">
              <span class="text-[#FAFF00]">Casino:</span> {bonus.data.casinoName.replace(/Bonus:.*$/, '').trim()}
            </div>
          )}
          {bonus.data.ourRating && (
            <div class="flex items-center gap-2">
              <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm">OUR RATING:</span>
              <span class="text-white font-[Space_Grotesk] font-bold text-2xl">{bonus.data.ourRating}</span>
              <span class="text-[#D4D4D4] font-[JetBrains_Mono] text-sm">/10</span>
            </div>
          )}
        </div>

        {bonus.data.code && bonus.data.code.trim() !== "" && (
          <div class="mt-4 p-4 bg-[#39FF14] border-[3px] border-black">
            <span class="text-black font-[JetBrains_Mono] text-sm font-bold">BONUS CODE:</span>
            <span class="text-black font-[Space_Grotesk] text-xl font-bold ml-2">{bonus.data.code}</span>
          </div>
        )}
      </div>

      {/* Pros & Cons */}
      {(bonus.data.pros || bonus.data.cons) && (
        <div class="grid md:grid-cols-2 gap-6 mb-8">
          {bonus.data.pros && (
            <div class="border-[3px] border-[#39FF14] bg-black p-6">
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-[#39FF14] mb-4 flex items-center gap-2">
                <span>✓</span> PROS
              </h3>
              <ul class="space-y-2">
                {bonus.data.pros.split('|').map((pro: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-[#39FF14] mt-1">•</span>
                    <span>{pro.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
          {bonus.data.cons && (
            <div class="border-[3px] border-white bg-black p-6">
              <h3 class="font-[Space_Grotesk] text-xl font-bold text-white mb-4 flex items-center gap-2">
                <span>✗</span> CONS
              </h3>
              <ul class="space-y-2">
                {bonus.data.cons.split('|').map((con: string) => (
                  <li class="text-[#D4D4D4] font-[Public_Sans] text-sm flex items-start gap-2">
                    <span class="text-white mt-1">•</span>
                    <span>{con.trim()}</span>
                  </li>
                ))}
              </ul>
            </div>
          )}
        </div>
      )}

      <!-- Content -->
      <div class="prose prose-invert prose-brutal max-w-none font-[Public_Sans]
        prose-headings:font-[Space_Grotesk] prose-headings:text-white prose-headings:font-bold
        prose-h2:text-2xl prose-h2:mt-10 prose-h2:mb-4 prose-h2:border-b-[3px] prose-h2:border-[#39FF14] prose-h2:pb-2
        prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-[#D4D4D4] prose-p:leading-relaxed prose-p:mb-4
        prose-li:text-[#D4D4D4]
        prose-strong:text-white
        prose-code:text-[#39FF14] prose-code:font-[JetBrains_Mono]
      ">
        <Content />
      </div>

      <!-- Back link -->
      <div class="mt-12 pt-8 border-t-[3px] border-white">
        <a
          href="/bonuses"
          class="inline-block bg-transparent text-white font-[Space_Grotesk] font-bold px-6 py-3 border-[3px] border-white shadow-[6px_6px_0px_0px_#39FF14] hover:translate-x-1 hover:translate-y-1 hover:shadow-[2px_2px_0px_0px_#39FF14] transition-all"
        >
          BACK TO BONUSES
        </a>
      </div>
    </div>
  </article>
</Layout>
