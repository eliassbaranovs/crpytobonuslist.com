      <div class="space-y-10">
        <!-- Section 1 -->
        <div>
          <h2 class="font-[Space_Grotesk] text-2xl font-bold mb-4 border-b-[3px] border-[#39FF14] pb-2">
            1. ACCEPTANCE OF TERMS
          </h2>
