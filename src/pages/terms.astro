<Layout title="Terms & Conditions | CryptoBonusList" description="Terms of use for CryptoBonusList.com. Read before using the site.">
  <section class="px-6 py-12">
    <div class="max-w-4xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        TERMS & <span class="text-[#39FF14]">CONDITIONS</span>
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-sm mb-10">
        Last updated: March 1, 2026
