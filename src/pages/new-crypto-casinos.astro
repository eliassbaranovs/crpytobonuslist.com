---
import { getCollection } from "astro:content";
import Layout from "../layouts/Layout.astro";
import {
  getReviews,
  isNewCasino,
  getRatingBg,
  getReviewUrl,
  getClaimUrl,
  getWithdrawalSpeedLabel,
} from "../lib/casino-filters";

const allPosts = await getCollection("posts");
const reviews = getReviews(allPosts).filter((r) => isNewCasino(r));

const faqItems = [
  {
    question: "Are new crypto casinos safe?",
    answer: "Some are, some are not. A valid gaming license, transparent ownership, and provably fair games are the minimum. New does not mean unsafe, but it does mean less track record to verify.",
  },
  {
    question: "Why do new casinos offer bigger bonuses?",
    answer: "They need players. A new site with zero users will offer aggressive welcome bonuses, cashback deals, and VIP perks to fill their tables. Once they build a player base, these offers typically shrink.",
  },
  {
    question: "How do you identify a trustworthy new casino?",
    answer: "Check the license first. Then look at the team behind it. Many new casinos are launched by experienced operators with a track record at other brands. That is a good sign. Anonymous operators with no license are a red flag.",
  },
  {
    question: "Do new casinos have fewer games?",
    answer: "Not necessarily. Most new casinos launch with thousands of games from major providers like Pragmatic Play, Evolution, and Play'n GO. The game library depends on provider partnerships, not age.",
  },
  {
    question: "Should I deposit large amounts at a new casino?",
    answer: "Start small. Test deposits, bonus terms, and withdrawal speed with a small amount first. If everything checks out, scale up. This applies to any casino but especially new ones with limited reputation.",
  },
];

const siteUrl = "https://cryptobonuslist.com";
const jsonld = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
    "@type": "FAQPage",
    mainEntity: faqItems.map((faq) => ({
      "@type": "Question",
      name: faq.question,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.answer,
      },
    })),
  },
    {
      "@type": "CollectionPage",
      name: "New Crypto Casinos 2026",
      description: "New crypto casinos launched in 2025 and 2026.",
      url: `${siteUrl}/new-crypto-casinos`,
    },
    {
      "@type": "ItemList",
      name: "New Crypto Casinos 2026",
      numberOfItems: reviews.length,
      itemListElement: reviews.map((r, i) => ({
        "@type": "ListItem",
        position: i + 1,
        url: `${siteUrl}${getReviewUrl(r)}`,
        name: r.data.casino_name || r.data.casinoName || r.data.title,
      })),
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [
        { "@type": "ListItem", position: 1, name: "Home", item: siteUrl },
        { "@type": "ListItem", position: 2, name: "New Casinos" },
      ],
    },
  ],
});
---

<Layout
  title="New Crypto Casinos 2026 | Fresh Sites Reviewed"
  description="New crypto casinos launched in 2025 and 2026. Tested with real deposits. See which new sites are worth your time and which ones to avoid."
  jsonld={jsonld}
>
  <section class="px-6 py-12">
    <div class="max-w-7xl mx-auto">
      <h1 class="font-[Space_Grotesk] text-4xl md:text-6xl font-bold mb-4">
        NEW <span class="text-[#FAFF00]">CRYPTO</span> CASINOS 2026
      </h1>
      <p class="text-[#D4D4D4] font-[Public_Sans] text-lg mb-10 max-w-3xl">
        Fresh crypto casinos pop up every week. Most are not worth your time. We test the new ones with real money and list only the sites that pass our review process.
      </p>

      {reviews.length > 0 ? (
        <div class="overflow-x-auto mb-16">
          <table class="w-full border-[3px] border-white text-left font-[Public_Sans]">
            <thead>
              <tr class="bg-white text-black font-[Space_Grotesk] text-sm uppercase tracking-wider">
                <th class="px-4 py-3">#</th>
                <th class="px-4 py-3">Casino</th>
                <th class="px-4 py-3">Rating</th>
                <th class="px-4 py-3">Withdrawal Speed</th>
                <th class="px-4 py-3">Bonus</th>
                <th class="px-4 py-3"></th>
              </tr>
            </thead>
            <tbody>
              {reviews.map((review, i) => (
                <tr class="border-t-[2px] border-white/20 hover:bg-white/5 transition-colors">
                  <td class="px-4 py-4 font-[JetBrains_Mono] text-[#FAFF00] font-bold">{i + 1}</td>
                  <td class="px-4 py-4">
                    <a href={getReviewUrl(review)} class="flex items-center gap-3 font-bold text-white hover:text-[#FAFF00] transition-colors">
                      {review.data.logo && (
                        <img src={review.data.logo} alt={`${review.data.title.replace(/ Review.*$/, "")} logo`} width="32" height="32" loading="lazy" />
                      )}
                      {review.data.title.replace(/ Review.*$/, "")}
                    </a>
                  </td>
                  <td class="px-4 py-4">
                    <span class={`inline-block px-2 py-1 font-[JetBrains_Mono] text-sm font-bold ${getRatingBg(review.data.ourRating || 0)}`}>
                      {review.data.ourRating}/10
                    </span>
                  </td>
                  <td class="px-4 py-4 font-[JetBrains_Mono] text-sm">{getWithdrawalSpeedLabel(review)}</td>
                  <td class="px-4 py-4 text-sm">
                    <a href={getReviewUrl(review)} class="text-[#FAFF00] hover:underline">{review.data.bonus || "See review"}</a>
                  </td>
                  <td class="px-4 py-4">
                    <a
                      href={getClaimUrl(review)}
                      target="_blank"
                      rel="noopener noreferrer nofollow"
                      class="inline-block bg-[#FAFF00] text-black font-[Space_Grotesk] font-bold text-sm px-4 py-2 border-[2px] border-white shadow-[3px_3px_0px_0px_white] hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-none transition-all"
                    >
                      CLAIM
                    </a>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      ) : (
        <div class="border-[3px] border-[#FAFF00] bg-[#FAFF00]/10 p-6 mb-16">
          <p class="font-[Public_Sans] text-[#FAFF00] font-bold">We have not reviewed any casinos matching this filter yet. Check back as we add more reviews.</p>
        </div>
      )}

      <div class="max-w-4xl space-y-12 mb-16">
        <section>
          <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-bold mb-4 text-[#FAFF00]">Why Try a New Casino?</h2>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed mb-4">
            Better bonuses. New casinos need players, so they throw money at welcome offers. You will find bigger deposit matches, more free spins, and lower wagering requirements at fresh sites compared to established ones.
          </p>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed mb-4">
            Modern tech is another perk. New casinos launch with the latest platform software, instant crypto processing, and mobile-first design. No legacy code slowing things down.
          </p>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
            The risk: no track record. An established casino with five years of payouts is a known quantity. A three-month-old site is still proving itself. That is the trade-off.
          </p>
        </section>

        <section>
          <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-bold mb-4 text-[#FAFF00]">Red Flags at New Casinos</h2>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed mb-4">
            No license listed anywhere on the site? Walk away. Anonymous ownership with no company information? Same thing. Bonus terms buried in tiny print with 60x wagering? That is not a bonus, it is a trap.
          </p>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed mb-4">
            Watch for copied content and stolen game thumbnails. Some scam sites clone the look of legitimate casinos. Check whether the games load from real providers by verifying the game URLs.
          </p>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
            Slow or nonexistent customer support is a warning sign. Test live chat before depositing. If nobody responds within 10 minutes, imagine what happens when you have a withdrawal problem.
          </p>
        </section>

        <section>
          <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-bold mb-4 text-[#FAFF00]">How We Review New Sites</h2>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed mb-4">
            Same process as every review. We deposit crypto, play through bonuses, request withdrawals, and contact support with questions. New casinos get no special treatment, positive or negative.
          </p>
          <p class="text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
            We re-check new casinos more frequently. A site that pays out well in month one might change behavior by month six. We update ratings as new information comes in.
          </p>
        </section>
      </div>

      <div class="max-w-4xl mb-16">
        <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-bold mb-6 text-white">FAQ</h2>
        <div class="space-y-4">
          {faqItems.map((faq) => (
            <details class="group border-[3px] border-white bg-black">
              <summary class="flex items-center justify-between px-6 py-4 cursor-pointer font-[Space_Grotesk] font-bold text-white hover:text-[#FAFF00] transition-colors">
                {faq.question}
                <span class="ml-4 text-[#FAFF00] group-open:rotate-45 transition-transform text-xl">+</span>
              </summary>
              <div class="px-6 pb-4 text-[#D4D4D4] font-[Public_Sans] leading-relaxed">
                {faq.answer}
              </div>
            </details>
          ))}
        </div>
      </div>

      <div class="border-t-[3px] border-white pt-8">
        <h2 class="font-[Space_Grotesk] text-xl font-bold mb-4 text-white">Related Pages</h2>
        <div class="flex flex-wrap gap-4">
          <a href="/bitcoin-casinos" class="font-[Public_Sans] text-sm text-[#39FF14] border-[2px] border-[#39FF14] px-4 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">Bitcoin Casinos</a>
          <a href="/fast-withdrawal-crypto-casinos" class="font-[Public_Sans] text-sm text-[#39FF14] border-[2px] border-[#39FF14] px-4 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">Fast Withdrawal Casinos</a>
          <a href="/no-wagering-crypto-casinos" class="font-[Public_Sans] text-sm text-[#39FF14] border-[2px] border-[#39FF14] px-4 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">Low Wagering Casinos</a>
          <a href="/ethereum-casinos" class="font-[Public_Sans] text-sm text-[#39FF14] border-[2px] border-[#39FF14] px-4 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">Ethereum Casinos</a>
          <a href="/no-kyc-crypto-casinos" class="font-[Public_Sans] text-sm text-[#39FF14] border-[2px] border-[#39FF14] px-4 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">No KYC Casinos</a>
          <a href="/casinos" class="font-[Public_Sans] text-sm text-[#39FF14] border-[2px] border-[#39FF14] px-4 py-2 hover:bg-[#39FF14] hover:text-black transition-colors">All Casinos</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Browse by Category -->
  <section class="py-12 border-t-[3px] border-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="font-[Space_Grotesk] text-2xl md:text-3xl font-bold text-white uppercase mb-8">
        BROWSE BY <span class="text-[#39FF14]">CATEGORY</span>
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <a href="/best-crypto-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Best Crypto Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Top-rated crypto casinos ranked by real testing</p>
      </a>
      <a href="/no-kyc-crypto-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">No KYC Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Play and withdraw without identity verification</p>
      </a>
      <a href="/bitcoin-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Bitcoin Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Best BTC gambling sites tested with real deposits</p>
      </a>
      <a href="/fast-withdrawal-crypto-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Fast Withdrawal Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Crypto casinos that pay out in under 6 hours</p>
      </a>
      <a href="/crypto-casino-bonuses" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Crypto Casino Bonuses</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Welcome offers and free spins claimed with crypto</p>
      </a>
      <a href="/ethereum-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Ethereum Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Top ETH gambling sites with fast deposits</p>
      </a>
      <a href="/solana-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Solana Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">SOL casinos with sub-second transactions</p>
      </a>
      <a href="/no-wagering-crypto-casinos" class="block border-[3px] border-white bg-[#0A0A0A] p-6 shadow-[6px_6px_0px_0px_#39FF14] hover:shadow-none hover:translate-x-[6px] hover:translate-y-[6px] transition-all">
        <h3 class="font-[Space_Grotesk] text-lg font-bold text-white uppercase mb-2">Low Wagering Casinos</h3>
        <p class="text-[#D4D4D4] text-sm font-[Public_Sans]">Bonuses with 10x wagering or less</p>
      </a>
      </div>
    </div>
  </section>
</Layout>
