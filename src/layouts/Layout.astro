---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  jsonld?: string;
  ogType?: string;
  ogImage?: string;
  canonical?: string;
  robots?: string;
}

const {
  title,
  description = "Raw crypto casino bonuses. No fluff.",
  jsonld,
  ogType = "website",
  ogImage = "/images/og-default.jpg",
  canonical,
  robots = "index, follow",
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
const currentPath = Astro.url.pathname;

function isActive(prefix: string): boolean {
  if (prefix === '/casinos') return currentPath === '/casinos' || currentPath.startsWith('/casinos/');
  if (prefix === '/bonus') return currentPath === '/bonus' || currentPath.startsWith('/bonus/');
  if (prefix === '/guides') return currentPath === '/guides' || currentPath.startsWith('/guides/');
  if (prefix === '/news') return currentPath === '/news' || currentPath.startsWith('/news/');
  return false;
}
