---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  jsonld?: string;
  ogType?: string;
  ogImage?: string;
  canonical?: string;
  robots?: string;
}

const {
  title,
  description = "Raw crypto casino bonuses. No fluff.",
  jsonld,
  ogType = "website",
  ogImage = "/favicon.svg",
  canonical,
  robots = "index, follow",
} = Astro.props;

const canonicalUrl = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <title>{title}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={new URL(ogImage, Astro.site).href} />
    <meta property="og:site_name" content="CryptoBonusList" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, Astro.site).href} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Public+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    {jsonld && <script type="application/ld+json" set:html={jsonld} />}
  </head>
  <body class="bg-[#0A0A0A] text-white min-h-screen flex flex-col">
    <!-- Skip to content -->
    <a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:z-50 focus:bg-[#39FF14] focus:text-black focus:px-4 focus:py-2 focus:font-bold focus:border-[3px] focus:border-white">
      Skip to content
    </a>

    <!-- Header -->
    <header class="border-b-[3px] border-white px-6 py-4 relative z-50">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <a href="/" class="font-[Space_Grotesk] text-xl md:text-2xl font-bold text-[#39FF14] tracking-tight">
          [ CRYPTO_BONUS_LIST ]
        </a>
        <nav aria-label="Main navigation" class="hidden md:flex gap-6 text-sm font-[Public_Sans] font-semibold uppercase tracking-widest">
          <!-- Casinos dropdown -->
          <div class="relative group">
            <a href="/casinos" class="text-white hover:text-[#39FF14] transition-colors flex items-center gap-1">
              Casinos
              <svg class="w-3 h-3 mt-0.5 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="absolute top-full left-0 pt-2 hidden group-hover:block">
              <div class="bg-black border-[3px] border-white shadow-[4px_4px_0px_0px_#39FF14] min-w-55">
                <a href="/casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">All Reviews</a>
                <a href="/best-crypto-casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Best Crypto Casinos</a>
                <a href="/bitcoin-casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Bitcoin Casinos</a>
                <a href="/ethereum-casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Ethereum Casinos</a>
                <a href="/fast-withdrawal-crypto-casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Fast Withdrawals</a>
                <a href="/no-wagering-crypto-casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">No Wagering</a>
                <a href="/new-crypto-casinos" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 text-xs tracking-wider">New Casinos</a>
              </div>
            </div>
          </div>
          <a href="/bonus" class="text-white hover:text-[#39FF14] transition-colors">Bonuses</a>
          <!-- Guides dropdown -->
          <div class="relative group">
            <a href="/guides" class="text-white hover:text-[#39FF14] transition-colors flex items-center gap-1">
              Guides
              <svg class="w-3 h-3 mt-0.5 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M19 9l-7 7-7-7"/></svg>
            </a>
            <div class="absolute top-full right-0 pt-2 hidden group-hover:block">
              <div class="bg-black border-[3px] border-white shadow-[4px_4px_0px_0px_#39FF14] min-w-70">
                <a href="/guides" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">All Guides</a>
                <a href="/guides/is-crypto-gambling-safe" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Is Crypto Gambling Safe?</a>
                <a href="/guides/crypto-casino-vs-regular-casino" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Crypto vs Regular Casino</a>
                <a href="/guides/crypto-casino-fees-explained" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Fees Explained</a>
                <a href="/guides/is-crypto-gambling-legal" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 border-b border-white/20 text-xs tracking-wider">Is It Legal?</a>
                <a href="/guides/how-crypto-casino-withdrawals-work" class="block px-4 py-3 text-[#D4D4D4] hover:text-[#39FF14] hover:bg-white/5 text-xs tracking-wider">How Withdrawals Work</a>
              </div>
            </div>
          </div>
          <a href="/news" class="text-white hover:text-[#39FF14] transition-colors">News</a>
        </nav>
        <!-- Mobile menu button -->
        <button id="mobile-menu-btn" class="md:hidden text-white" aria-label="Open menu">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
      <!-- Mobile menu -->
      <div id="mobile-menu" class="hidden md:hidden mt-4 border-t-[3px] border-white pt-4">
        <nav class="flex flex-col gap-1 text-sm font-[Public_Sans] font-semibold uppercase tracking-widest">
          <p class="text-[#39FF14] font-[JetBrains_Mono] text-xs px-2 py-1">Casinos</p>
          <a href="/casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">All Reviews</a>
          <a href="/best-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Best Crypto Casinos</a>
          <a href="/bitcoin-casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Bitcoin Casinos</a>
          <a href="/ethereum-casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Ethereum Casinos</a>
          <a href="/fast-withdrawal-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Fast Withdrawals</a>
          <a href="/no-wagering-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">No Wagering</a>
          <a href="/new-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">New Casinos</a>
          <div class="border-t border-white/20 my-2"></div>
          <a href="/bonus" class="text-white hover:text-[#39FF14] px-2 py-2">Bonuses</a>
          <div class="border-t border-white/20 my-2"></div>
          <p class="text-[#39FF14] font-[JetBrains_Mono] text-xs px-2 py-1">Guides</p>
          <a href="/guides" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">All Guides</a>
          <a href="/guides/is-crypto-gambling-safe" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Is Crypto Gambling Safe?</a>
          <a href="/guides/crypto-casino-vs-regular-casino" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Crypto vs Regular</a>
          <a href="/guides/crypto-casino-fees-explained" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Fees Explained</a>
          <a href="/guides/is-crypto-gambling-legal" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">Is It Legal?</a>
          <a href="/guides/how-crypto-casino-withdrawals-work" class="text-[#D4D4D4] hover:text-[#39FF14] px-4 py-2">How Withdrawals Work</a>
          <div class="border-t border-white/20 my-2"></div>
          <a href="/news" class="text-white hover:text-[#39FF14] px-2 py-2">News</a>
        </nav>
      </div>
    </header>

    <!-- Marquee -->
    <div class="border-b-[3px] border-white bg-black overflow-hidden py-2">
      <div class="flex whitespace-nowrap animate-marquee">
        <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm font-bold tracking-wider px-8">
          &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt;
        </span>
        <span class="text-[#FAFF00] font-[JetBrains_Mono] text-sm font-bold tracking-wider px-8">
          &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt; UNREGULATED YIELDS &gt; 0% KYC OPTIONS &gt; DECENTRALIZED PAYOUTS &gt;
        </span>
      </div>
    </div>

    <!-- Main Content -->
    <main id="main-content" class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t-[3px] border-white mt-16">
      <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 divide-y md:divide-y-0 md:divide-x divide-white">
        <div class="p-8">
          <p class="font-[Space_Grotesk] text-lg font-bold text-[#39FF14] mb-4">[ CRYPTO_BONUS_LIST ]</p>
          <p class="text-[#D4D4D4] text-sm font-[Public_Sans] leading-relaxed">
            Crypto casino bonuses, reviewed by people who use them. No fluff. No hype.
          </p>
        </div>
        <nav aria-label="Footer pages" class="p-8">
          <p class="font-[Space_Grotesk] text-lg font-bold text-white mb-4">PAGES</p>
          <ul class="space-y-2 text-sm font-[Public_Sans]">
            <li><a href="/casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Casino Reviews</a></li>
            <li><a href="/best-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Best Crypto Casinos</a></li>
            <li><a href="/bonus" class="text-[#D4D4D4] hover:text-[#39FF14]">Bonuses</a></li>
            <li><a href="/guides" class="text-[#D4D4D4] hover:text-[#39FF14]">Guides</a></li>
            <li><a href="/news" class="text-[#D4D4D4] hover:text-[#39FF14]">News</a></li>
            <li><a href="/bitcoin-casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Bitcoin Casinos</a></li>
            <li><a href="/ethereum-casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Ethereum Casinos</a></li>
            <li><a href="/fast-withdrawal-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">Fast Withdrawals</a></li>
            <li><a href="/no-wagering-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">No Wagering</a></li>
            <li><a href="/new-crypto-casinos" class="text-[#D4D4D4] hover:text-[#39FF14]">New Casinos</a></li>
          </ul>
        </nav>
        <nav aria-label="Company links" class="p-8">
          <p class="font-[Space_Grotesk] text-lg font-bold text-white mb-4">COMPANY</p>
          <ul class="space-y-2 text-sm font-[Public_Sans]">
            <li><a href="/about" class="text-[#D4D4D4] hover:text-[#39FF14]">About Us</a></li>
            <li><a href="/team" class="text-[#D4D4D4] hover:text-[#39FF14]">Our Team</a></li>
            <li><a href="/methodology" class="text-[#D4D4D4] hover:text-[#39FF14]">How We Review</a></li>
            <li><a href="/contact" class="text-[#D4D4D4] hover:text-[#39FF14]">Contact</a></li>
          </ul>
        </nav>
        <nav aria-label="Legal and trust links" class="p-8">
          <p class="font-[Space_Grotesk] text-lg font-bold text-white mb-4">LEGAL & TRUST</p>
          <ul class="space-y-2 text-sm font-[Public_Sans]">
            <li><a href="/affiliate-disclosure" class="text-[#D4D4D4] hover:text-[#39FF14]">Affiliate Disclosure</a></li>
            <li><a href="/responsible-gambling" class="text-[#D4D4D4] hover:text-[#39FF14]">Responsible Gambling</a></li>
            <li><a href="/privacy" class="text-[#D4D4D4] hover:text-[#39FF14]">Privacy Policy</a></li>
            <li><a href="/terms" class="text-[#D4D4D4] hover:text-[#39FF14]">Terms & Conditions</a></li>
          </ul>
        </nav>
      </div>
      <div class="border-t-[3px] border-white p-6">
        <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-[#D4D4D4] text-xs font-[Public_Sans]">
            &copy; 2026 CryptoBonusList.com. 18+ Only. Gambling involves risk. Content is for informational purposes.
          </p>
          <p class="text-[#D4D4D4] text-xs font-[Public_Sans]">
            <a href="/responsible-gambling" class="text-[#FAFF00] hover:underline">Play Responsibly</a>
          </p>
        </div>
      </div>
    </footer>
    <script>
      const btn = document.getElementById("mobile-menu-btn");
      const menu = document.getElementById("mobile-menu");
      if (btn && menu) {
        btn.addEventListener("click", () => {
          menu.classList.toggle("hidden");
        });
      }
    </script>
  </body>
</html>
